<body>

<div id="loading">
    <div id="loading-title">Archers vs Knights</div>
    <div id="loading-steps">
        <div class="load-step" id="step-load">1. Download and compile engine</div>
        <div class="load-step" id="step-init">2. Initialize game world</div>
    </div>
</div>

<div id="game-area">
    <div id="back-link" style="width:100%;text-align:left;display:none;"><a href="../" style="color:#666;text-decoration:none;font-size:0.85em;">&larr; Games</a></div>
    <script>if(location.hostname.indexOf('github.io')>=0)document.getElementById('back-link').style.display='';</script>
    <h1>Archers vs Knights <span id="info-btn" title="About">?</span></h1>
    <div id="status">Initializing...</div>
    <div id="game-over-msg"></div>
    <div id="about-panel">
        <h3>About</h3>
        <p>Built in C with Flecs ECS, it simulates 1,127 archers (red) fighting 2,649 knights (blue) on a 320x144 grid. Combat is turn-based -- all units move one tile per turn. Knights have range 1 and 35 HP. Archers have range 3 and 10 HP. All attacks deal 5 damage.</p>
        <p>The initial knight AI "move toward the closest archer" was terrible. Knights myopically blocked each other, creating traffic jams while archers kited freely. The fix was a tiered tiebreaker system for choosing between equally scored moves:</p>
        <ol>
            <li><strong>Spread:</strong> prefer moving away from an adjacent ally, so the knight behind you can advance into your space. This naturally forms surrounding formations.</li>
            <li><strong>Center bias:</strong> prefer moves closer to the center of the map. This drives archers toward walls where they can't kite.</li>
        </ol>
        <p>Surrounding is the only way knights can kill archers -- with equal movement speed and shorter range, knights need to corner them against walls or each other.</p>
    </div>
    <canvas id="canvas"></canvas>
    <div id="scrub-bar"><div id="scrub-fill"></div><div id="scrub-head"></div></div>
    <div id="scrub-label"></div>
    <div id="version" style="font-size:0.6em;color:#555;margin-top:2px;flex-shrink:0;"></div>
</div>
<div id="ui-area">
    <div id="controls">
        <button id="btn-play" title="Space">Play</button>
        <button id="btn-step" title="Right Arrow">Step</button>
        <button id="btn-rewind" title="Left Arrow">Rewind</button>
        <button id="btn-new">New Game</button>
        <div id="fps-bar-outer">
            <div id="fps-bar-inner"><span id="fps-text"></span></div>
        </div>
    </div>
    <div id="legend">
        <span class="red">&#9632; Archer</span>
        <span class="blue">&#9632; Knight</span>
        <span class="white">&#9632; Hit</span>
        <span>Space: Play/Pause</span>
        <span>&#8594;: Step</span>
        <span>&#8592;: Rewind</span>
    </div>
    <div id="profile" style="font-family:monospace;font-size:0.75em;color:#666;margin-top:4px;"></div>
</div>

<script src="flecs-ecs.js"></script>
<script>
(function() {
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const statusEl = document.getElementById('status');
    const gameOverEl = document.getElementById('game-over-msg');
    const btnPlay = document.getElementById('btn-play');
    const btnStep = document.getElementById('btn-step');
    const btnRewind = document.getElementById('btn-rewind');
    const btnNew = document.getElementById('btn-new');
    const loadingEl = document.getElementById('loading');

    let engine = null;
    let playing = false;
    let playInterval = null;
    let mapW = 150, mapH = 48;
    let CELL_W = 6, CELL_H = 6;
    const frameTimes = [];
    let lastFrameTime = 0;
    let heldKey = null;
    let heldInterval = null;
    let maxTurnReached = 0;
    let scrubbing = false;

    /* Colors */
    const BG_COLOR = '#0f0f23';
    const GRID_COLOR = '#1a1a30';
    const ARCHER_COLOR = '#ff6b6b';
    const KNIGHT_COLOR = '#4dabf7';
    const HIT_COLOR = '#ffffff';
    const BORDER_COLOR = '#333355';

    function resizeCanvas() {
        var pad = 16;
        var controlsH = 120;
        var availW = window.innerWidth - pad;
        var availH = window.innerHeight - controlsH;
        /* Square cells ŌĆö use the smaller dimension to fit */
        var cell = Math.max(1, Math.min(Math.floor(availW / mapW), Math.floor(availH / mapH)));
        CELL_W = cell;
        CELL_H = cell;
        canvas.width = mapW * CELL_W;
        canvas.height = mapH * CELL_H;
    }

    window.addEventListener('resize', function() {
        resizeCanvas();
        if (engine) render();
    });

    function render() {
        if (!engine) return;

        const unitCount = engine.getUnitCount();
        const turn = engine.getTurn();
        const gameOver = engine.isGameOver();

        /* Clear */
        ctx.fillStyle = BG_COLOR;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        /* Grid lines (subtle) */
        ctx.strokeStyle = GRID_COLOR;
        ctx.lineWidth = 0.5;
        for (let x = 0; x <= mapW; x += 10) {
            ctx.beginPath();
            ctx.moveTo(x * CELL_W, 0);
            ctx.lineTo(x * CELL_W, canvas.height);
            ctx.stroke();
        }
        for (let y = 0; y <= mapH; y += 10) {
            ctx.beginPath();
            ctx.moveTo(0, y * CELL_H);
            ctx.lineTo(canvas.width, y * CELL_H);
            ctx.stroke();
        }

        /* Border */
        ctx.strokeStyle = BORDER_COLOR;
        ctx.lineWidth = 2;
        ctx.strokeRect(0, 0, canvas.width, canvas.height);

        /* Draw units */
        let archerCount = 0, knightCount = 0;

        for (let i = 0; i < unitCount; i++) {
            const x = engine.getUnitX(i);
            const y = engine.getUnitY(i);
            const faction = engine.getUnitFaction(i);
            const tookDamage = engine.getUnitDamaged(i);

            if (faction === 0) archerCount++;
            else if (faction === 1) knightCount++;

            if (tookDamage) {
                ctx.fillStyle = HIT_COLOR;
            } else if (faction === 0) {
                ctx.fillStyle = ARCHER_COLOR;
            } else {
                ctx.fillStyle = KNIGHT_COLOR;
            }

            ctx.fillRect(x * CELL_W + 1, y * CELL_H + 1, CELL_W - 1, CELL_H - 1);
        }

        /* FPS */
        const now = performance.now();
        if (lastFrameTime > 0) {
            frameTimes.push(now - lastFrameTime);
            if (frameTimes.length > 5) frameTimes.shift();
        }
        lastFrameTime = now;
        const avgMs = frameTimes.length ? frameTimes.reduce((a,b) => a+b) / frameTimes.length : 0;
        const fps = avgMs > 0 ? Math.round(1000 / avgMs) : 0;

        /* FPS bar ŌĆö always blue, full = 240 fps */
        var fpsBar = document.getElementById('fps-bar-inner');
        var fpsText = document.getElementById('fps-text');
        fpsBar.style.width = Math.min(100, (fps / 240) * 100) + '%';
        fpsText.textContent = fps + ' fps';

        /* Scrub bar */
        if (turn > maxTurnReached) maxTurnReached = turn;
        if (maxTurnReached > 0) {
            var scrubPct = (turn / maxTurnReached) * 100;
            document.getElementById('scrub-fill').style.width = '100%';
            document.getElementById('scrub-head').style.left = scrubPct + '%';
            document.getElementById('scrub-label').textContent = 'Turn ' + turn + ' / ' + maxTurnReached;
        }

        /* Profiling ŌĆö top 3 systems by time */
        var sysNames = ['rewind','start_of_turn','app_start','movement','attack','despawn','spawn','app_stop','history'];
        var sysCount = engine.getSystemCount();
        var totalMs = engine.getTotalTime();
        var entries = [];
        for (var s = 0; s < sysCount && s < sysNames.length; s++) {
            entries.push({name: sysNames[s], ms: engine.getSystemTime(s)});
        }
        var collectMs = engine.getCollectTime();
        if (collectMs > 0) entries.push({name: 'collect', ms: collectMs});
        entries.sort(function(a, b) { return b.ms - a.ms; });
        var top3 = entries.slice(0, 3).map(function(e) { return e.name + ' ' + e.ms.toFixed(1) + 'ms'; });
        document.getElementById('profile').textContent = top3.join(', ') + '  (' + totalMs.toFixed(1) + 'ms total)';

        /* Status */
        statusEl.innerHTML = `Turn ${turn} &nbsp;|&nbsp; <span class="red">Archers: ${archerCount}</span> &nbsp;|&nbsp; <span class="blue">Knights: ${knightCount}</span>`;

        if (gameOver) {
            const msg = engine.getMessage();
            gameOverEl.textContent = msg;
            stopPlaying();
        } else {
            gameOverEl.textContent = '';
        }
    }

    function tick() {
        if (!engine) return;
        if (engine.isGameOver()) return;
        engine.turn();
        render();
    }

    function step() {
        if (playing) stopPlaying();
        tick();
    }

    function startPlaying() {
        if (playing) return;
        playing = true;
        btnPlay.textContent = 'Pause';
        btnPlay.classList.add('active');
        schedulePlay();
    }

    function stopPlaying() {
        playing = false;
        btnPlay.textContent = 'Play';
        btnPlay.classList.remove('active');
        if (playInterval) {
            clearInterval(playInterval);
            playInterval = null;
        }
    }

    function schedulePlay() {
        if (playInterval) clearInterval(playInterval);
        const ms = 0;
        playInterval = setInterval(() => {
            if (!playing || !engine) { stopPlaying(); return; }
            tick();
            if (engine.isGameOver()) stopPlaying();
        }, ms);
    }

    function togglePlay() {
        if (playing) { stopPlaying(); return; }
        if (engine && engine.isGameOver()) { newGame(); startPlaying(); return; }
        startPlaying();
    }

    function rewind() {
        if (!engine) return;
        if (playing) stopPlaying();
        const turn = engine.getTurn();
        if (turn <= 1) return;
        engine.rewind(turn - 1);
        render();
    }

    function newGame() {
        if (!engine) return;
        stopPlaying();
        engine.reset();
        maxTurnReached = 0;
        engine.turn();
        render();
        gameOverEl.textContent = '';
    }

    /* About toggle */
    var aboutShowing = false;
    document.getElementById('info-btn').addEventListener('click', function() {
        aboutShowing = !aboutShowing;
        document.getElementById('about-panel').style.display = aboutShowing ? 'block' : 'none';
        canvas.style.display = aboutShowing ? 'none' : '';
        document.getElementById('scrub-bar').style.display = aboutShowing ? 'none' : '';
        document.getElementById('scrub-label').style.display = aboutShowing ? 'none' : '';
    });

    /* Controls */
    btnPlay.addEventListener('click', togglePlay);
    btnStep.addEventListener('click', step);
    btnRewind.addEventListener('click', rewind);
    btnNew.addEventListener('click', newGame);

    /* Keyboard ŌĆö single step on press, fast-forward after 500ms hold */
    let heldTimeout = null;

    function doRewind() {
        if (!engine) return;
        var turn = engine.getTurn();
        if (turn <= 1) return;
        engine.rewind(turn - 1);
        render();
    }

    function startHold(key, fn) {
        if (heldKey === key) return;
        stopHold();
        heldKey = key;
        fn();
        heldTimeout = setTimeout(function() {
            heldInterval = setInterval(fn, 0);
        }, 500);
    }

    function stopHold() {
        heldKey = null;
        if (heldTimeout) { clearTimeout(heldTimeout); heldTimeout = null; }
        if (heldInterval) { clearInterval(heldInterval); heldInterval = null; }
    }

    document.addEventListener('keydown', (e) => {
        if (e.code === 'Space') { e.preventDefault(); e.stopPropagation(); togglePlay(); }
        else if (e.code === 'ArrowRight' || e.code === 'Period') {
            e.preventDefault(); e.stopPropagation();
            if (playing) stopPlaying();
            startHold('right', tick);
        }
        else if (e.code === 'ArrowLeft') {
            e.preventDefault(); e.stopPropagation();
            if (playing) stopPlaying();
            startHold('left', doRewind);
        }
    }, true);

    document.addEventListener('keyup', (e) => {
        if (e.code === 'ArrowRight' || e.code === 'Period' || e.code === 'ArrowLeft') {
            stopHold();
        }
    }, true);

    /* Scrub bar drag */
    var scrubBar = document.getElementById('scrub-bar');

    function scrubTo(e) {
        if (!engine || maxTurnReached <= 1) return;
        var rect = scrubBar.getBoundingClientRect();
        var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        var targetTurn = Math.max(1, Math.round(pct * maxTurnReached));
        var currentTurn = engine.getTurn();
        if (targetTurn === currentTurn) return;

        if (targetTurn < currentTurn) {
            engine.rewind(targetTurn);
        } else {
            for (var t = currentTurn; t < targetTurn; t++) {
                engine.turn();
                if (engine.isGameOver()) break;
            }
        }
        /* Force scrub head update */
        var turn = engine.getTurn();
        var headPct = maxTurnReached > 0 ? (turn / maxTurnReached) * 100 : 0;
        document.getElementById('scrub-head').style.left = headPct + '%';
        document.getElementById('scrub-label').textContent = 'Turn ' + turn + ' / ' + maxTurnReached;
        render();
    }

    scrubBar.addEventListener('mousedown', function(e) {
        scrubbing = true;
        if (playing) stopPlaying();
        scrubTo(e);
    });
    document.addEventListener('mousemove', function(e) {
        if (scrubbing) scrubTo(e);
    });
    document.addEventListener('mouseup', function() {
        scrubbing = false;
    });

    /* Init */
    const stepLoad = document.getElementById('step-load');
    const stepInit = document.getElementById('step-init');
    const loadStart = Date.now();

    function elapsed() { return ((Date.now() - loadStart) / 1000).toFixed(1); }

    function markActive(el) { el.className = 'load-step active'; }
    function markDone(el) {
        el.className = 'load-step done';
        el.innerHTML = el.textContent + '<span class="elapsed">' + elapsed() + 's</span>';
    }

    markActive(stepLoad);

    FlecsECS().then(function(M) {
        window.WasmModule = M;
        markDone(stepLoad);
        markActive(stepInit);

        try {
            engine = {
                init: M.cwrap('wasm_init', 'number', []),
                turn: M.cwrap('wasm_turn', 'number', []),
                getTurn: M.cwrap('wasm_get_turn', 'number', []),
                getUnitCount: M.cwrap('wasm_get_unit_count', 'number', []),
                getUnitX: M.cwrap('wasm_get_unit_x', 'number', ['number']),
                getUnitY: M.cwrap('wasm_get_unit_y', 'number', ['number']),
                getUnitFaction: M.cwrap('wasm_get_unit_faction', 'number', ['number']),
                getUnitDamaged: M.cwrap('wasm_get_unit_took_damage', 'number', ['number']),
                getMapX: M.cwrap('wasm_get_map_x', 'number', []),
                getMapY: M.cwrap('wasm_get_map_y', 'number', []),
                isGameOver: M.cwrap('wasm_is_game_over', 'number', []),
                getMessage: M.cwrap('wasm_get_game_over_message', 'string', []),
                rewind: M.cwrap('wasm_rewind', 'number', ['number']),
                reset: M.cwrap('wasm_reset', 'number', []),
                free: M.cwrap('wasm_free', null, []),
                getSystemCount: M.cwrap('wasm_get_system_count', 'number', []),
                getSystemTime: M.cwrap('wasm_get_system_time', 'number', ['number']),
                getCollectTime: M.cwrap('wasm_get_collect_time', 'number', []),
                getTotalTime: M.cwrap('wasm_get_total_time', 'number', []),
            };

            if (!engine.init()) {
                stepInit.textContent = '2. Engine init returned false';
                stepInit.style.color = '#ff6b6b';
                return;
            }

            /* Run first turn to trigger app_start (creates Map, spawns units) */
            engine.turn();

            /* Read map size (Map entity exists after first turn) */
            mapW = engine.getMapX() || 150;
            mapH = engine.getMapY() || 48;

            resizeCanvas();
            render();

            markDone(stepInit);

            setTimeout(function() {
                loadingEl.style.display = 'none';
                statusEl.textContent = 'Turn 1  |  Ready - press Play or Space';
            }, 500);
        } catch(e) {
            stepInit.textContent = '2. Error: ' + e.message;
            stepInit.style.color = '#ff6b6b';
            console.error('Init error:', e);
        }
    }).catch(function(e) {
        stepLoad.textContent = '1. Error: ' + e.message;
        stepLoad.style.color = '#ff6b6b';
        console.error('Load error:', e);
    });

})();
</script>
</body>
</html>
/*
 * WASM entry point for Archers vs Knights.
 * Exposes engine functions to JavaScript via EMSCRIPTEN_KEEPALIVE.
 */
#include <emscripten.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>

#include "engine/engine.h"
#include "engine/simulation.h"
#include "engine/app.h"
#include "engine/history.h"
#include "engine/components.h"
#include "engine/systems.h"

/* ŌöĆŌöĆ Static state ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static Engine *g_engine = NULL;

/* Per-system timing */
#define MAX_SYSTEMS 16
static double g_system_times[MAX_SYSTEMS];
static int g_system_count = 0;
static double g_collect_time = 0;
static double g_total_time = 0;

/* Unit data passed to JS as flat int32 array */
typedef struct {
    int32_t x, y;
    int32_t health;
    int32_t faction;     /* 0=red(archer), 1=blue(knight) */
    int32_t unit_type;   /* 0=archer, 1=knight */
    int32_t took_damage; /* 0 or 1 */
    int32_t entity_id;
} WasmUnit;

#define MAX_UNITS 4096
static WasmUnit g_units[MAX_UNITS];
static int g_unit_count = 0;
static int32_t g_map_size[2] = {0, 0};

/* ŌöĆŌöĆ Helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void collect_wasm_units(Engine *engine) {
    ecs_entity_t loc_comp  = ecs_lookup(engine->world, "Location");
    ecs_entity_t hp_comp   = ecs_lookup(engine->world, "Health");
    ecs_entity_t red_comp  = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    ecs_entity_t td_comp   = ecs_lookup(engine->world, "TookDamage");

    if (!loc_comp || !hp_comp) { g_unit_count = 0; return; }

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {
            { .id = loc_comp },
            { .id = hp_comp },
            { .id = engine->user_entity_tag },
        },
        .cache_kind = EcsQueryCacheNone
    });

    int count = 0;
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count && count < MAX_UNITS; i++) {
            ecs_entity_t eid = it.entities[i];

            const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, eid, hp_comp);
            if (!hp || *hp <= 0) continue;

            WasmUnit *u = &g_units[count];

            /* Location */
            const void *loc = ecs_get_id(engine->world, eid, loc_comp);
            if (loc) {
                u->x = *(const int32_t *)loc;
                u->y = *((const int32_t *)loc + 1);
            }

            u->health = *hp;

            /* Faction */
            if (red_comp && ecs_has_id(engine->world, eid, red_comp))
                u->faction = 0;
            else if (blue_comp && ecs_has_id(engine->world, eid, blue_comp))
                u->faction = 1;
            else
                u->faction = -1;

            /* Unit type from name */
            const char *name = ecs_get_name(engine->world, eid);
            if (name && strstr(name, "Archer"))
                u->unit_type = 0;
            else if (name && strstr(name, "Knight"))
                u->unit_type = 1;
            else
                u->unit_type = -1;

            /* TookDamage */
            u->took_damage = 0;
            if (td_comp && ecs_has_id(engine->world, eid, td_comp)) {
                u->took_damage = 1;
            }

            /* EntityId */
            const int32_t *eid_val = (const int32_t *)ecs_get_id(
                engine->world, eid, engine->entity_id_comp);
            u->entity_id = eid_val ? *eid_val : 0;

            count++;
        }
    }
    ecs_query_fini(q);
    g_unit_count = count;
}

static void read_map_size(Engine *engine) {
    ecs_entity_t map_ent = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    if (map_ent && ms_comp && ecs_has_id(engine->world, map_ent, ms_comp)) {
        const void *data = ecs_get_id(engine->world, map_ent, ms_comp);
        if (data) {
            g_map_size[0] = *(const int32_t *)data;
            g_map_size[1] = *((const int32_t *)data + 1);
        }
    }
}

/* ŌöĆŌöĆ Exported API ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

EMSCRIPTEN_KEEPALIVE
int wasm_init(void) {
    if (g_engine) engine_fini(g_engine);

    g_engine = engine_init(NULL);
    if (!g_engine) return 0;

    if (!engine_sandbox_select(g_engine, "avk")) {
        engine_fini(g_engine);
        g_engine = NULL;
        return 0;
    }

    AppStartResult asr;
    if (!engine_app_start(g_engine, NULL, &asr)) {
        engine_fini(g_engine);
        g_engine = NULL;
        return 0;
    }

    return 1;
}

static void unpause(void) {
    ecs_entity_t gs = ecs_lookup(g_engine->world, "GameState");
    ecs_entity_t sp = ecs_lookup(g_engine->world, "SimulationPaused");
    if (gs && sp && ecs_has_id(g_engine->world, gs, sp))
        ecs_remove_id(g_engine->world, gs, sp);
}

EMSCRIPTEN_KEEPALIVE
int wasm_turn(void) {
    if (!g_engine) return -1;

    unpause();

    double frame_start = emscripten_get_now();

    /* Time each system individually */
    g_system_count = 0;
    if (g_engine->game_over) return g_engine->turn_counter;

    int order_count = g_engine->system_order_count;
    for (int i = 0; i < order_count && i < MAX_SYSTEMS; i++) {
        if (g_engine->game_over) break;
        const char *name = g_engine->system_order[i];

        double t0 = emscripten_get_now();
        engine_system_run_one(g_engine, name);
        g_system_times[g_system_count++] = emscripten_get_now() - t0;
    }

    if (!is_simulation_paused(g_engine))
        g_engine->turn_counter++;

    /* Time unit collection */
    double t0 = emscripten_get_now();
    collect_wasm_units(g_engine);
    g_collect_time = emscripten_get_now() - t0;

    g_total_time = emscripten_get_now() - frame_start;

    return g_engine->turn_counter;
}

EMSCRIPTEN_KEEPALIVE
int wasm_get_system_count(void) { return g_system_count; }

EMSCRIPTEN_KEEPALIVE
double wasm_get_system_time(int i) {
    return (i >= 0 && i < g_system_count) ? g_system_times[i] : 0;
}

EMSCRIPTEN_KEEPALIVE
double wasm_get_collect_time(void) { return g_collect_time; }

EMSCRIPTEN_KEEPALIVE
double wasm_get_total_time(void) { return g_total_time; }

EMSCRIPTEN_KEEPALIVE
int wasm_get_turn(void) {
    return g_engine ? g_engine->turn_counter : 0;
}

EMSCRIPTEN_KEEPALIVE
int wasm_get_unit_count(void) {
    return g_unit_count;
}

EMSCRIPTEN_KEEPALIVE
int wasm_get_unit_x(int i) { return (i >= 0 && i < g_unit_count) ? g_units[i].x : 0; }

EMSCRIPTEN_KEEPALIVE
int wasm_get_unit_y(int i) { return (i >= 0 && i < g_unit_count) ? g_units[i].y : 0; }

EMSCRIPTEN_KEEPALIVE
int wasm_get_unit_faction(int i) { return (i >= 0 && i < g_unit_count) ? g_units[i].faction : -1; }

EMSCRIPTEN_KEEPALIVE
int wasm_get_unit_took_damage(int i) { return (i >= 0 && i < g_unit_count) ? g_units[i].took_damage : 0; }

EMSCRIPTEN_KEEPALIVE
int wasm_get_map_x(void) {
    if (g_engine) read_map_size(g_engine);
    return g_map_size[0];
}

EMSCRIPTEN_KEEPALIVE
int wasm_get_map_y(void) {
    if (g_engine) read_map_size(g_engine);
    return g_map_size[1];
}

EMSCRIPTEN_KEEPALIVE
int wasm_is_game_over(void) {
    return g_engine ? g_engine->game_over : 0;
}

EMSCRIPTEN_KEEPALIVE
const char *wasm_get_game_over_message(void) {
    return g_engine ? g_engine->game_over_message : "";
}

EMSCRIPTEN_KEEPALIVE
int wasm_rewind(int target_turn) {
    if (!g_engine) return 0;
    bool ok = engine_sim_rewind(g_engine, target_turn);
    if (ok) collect_wasm_units(g_engine);
    return ok ? 1 : 0;
}


EMSCRIPTEN_KEEPALIVE
int wasm_reset(void) {
    if (!g_engine) return 0;

    engine_sim_reset(g_engine);

    if (!engine_sandbox_select(g_engine, "avk")) return 0;

    AppStartResult asr;
    if (!engine_app_start(g_engine, NULL, &asr)) return 0;

    read_map_size(g_engine);
    collect_wasm_units(g_engine);
    return 1;
}

EMSCRIPTEN_KEEPALIVE
void wasm_free(void) {
    if (g_engine) {
        engine_fini(g_engine);
        g_engine = NULL;
    }
}

EMSCRIPTEN_KEEPALIVE
void wasm_run_headless(void) {
    if (!g_engine) return;
    for (int t = 0; t < 1000 && !g_engine->game_over; t++) {
        TurnResult tr;
        bool ok = engine_sim_turn(g_engine, &tr);
        if (ok) engine_turn_result_free(&tr);
        collect_wasm_units(g_engine);

        /* Count factions */
        int archers = 0, knights = 0;
        for (int i = 0; i < g_unit_count; i++) {
            if (g_units[i].faction == 0) archers++;
            else if (g_units[i].faction == 1) knights++;
        }
        fprintf(stderr, "turn %d: %dA %dK\n", g_engine->turn_counter, archers, knights);

        if (g_engine->game_over) {
            fprintf(stderr, "game over: %s\n", g_engine->game_over_message);
            break;
        }
    }
}

int main(void) { return 0; }
