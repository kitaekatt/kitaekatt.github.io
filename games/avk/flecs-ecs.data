#include "systems.h"
#include "engine/systems.h"
#include "engine/components.h"
#include "engine/templates.h"
#include "engine/history.h"
#include "engine/app.h"
#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <math.h>
#include <time.h>

/* ŌöĆŌöĆ Helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

typedef struct {
    ecs_entity_t eid;
    int entity_id;
    int x, y;
    int health;
    int speed, energy;
    int range, damage;
    int faction;  /* enum index: 0=red, 1=blue */
    int move_type; /* enum index: 0=kite, 1=charge */
} UnitData;

static int manhattan(int x1, int y1, int x2, int y2) {
    return abs(x1 - x2) + abs(y1 - y2);
}

/* Collect living units from query into array, return count */
static int collect_units(Engine *engine, UnitData *units, int max_units) {
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    ecs_entity_t spd_comp = ecs_lookup(engine->world, "MovementSpeed");
    ecs_entity_t rng_comp = ecs_lookup(engine->world, "Weapon");
    ecs_entity_t dmg_comp = ecs_lookup(engine->world, "AttackDamage");
    ecs_entity_t red_comp = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    ecs_entity_t mt_comp = ecs_lookup(engine->world, "MovementType");

    if (!loc_comp || !hp_comp) return 0;

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {
            { .id = loc_comp },
            { .id = hp_comp },
            { .id = engine->user_entity_tag },
        },
        .cache_kind = EcsQueryCacheNone
    });

    int count = 0;
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count && count < max_units; i++) {
            ecs_entity_t eid = it.entities[i];

            /* Read Health */
            const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, eid, hp_comp);
            if (!hp || *hp <= 0) continue;

            UnitData *u = &units[count];
            u->eid = eid;
            u->health = *hp;

            /* EntityId */
            const int32_t *eid_val = (const int32_t *)ecs_get_id(engine->world, eid, engine->entity_id_comp);
            u->entity_id = eid_val ? *eid_val : 0;

            /* Location */
            const void *loc_data = ecs_get_id(engine->world, eid, loc_comp);
            if (loc_data) {
                u->x = *(const int32_t *)loc_data;
                u->y = *((const int32_t *)loc_data + 1);
            }
            /* MovementSpeed */
            if (spd_comp && ecs_has_id(engine->world, eid, spd_comp)) {
                const void *spd_data = ecs_get_id(engine->world, eid, spd_comp);
                if (spd_data) {
                    u->speed = *(const int32_t *)spd_data;
                    u->energy = u->speed;
                }
            }

            /* Weapon (range is first field) */
            if (rng_comp && ecs_has_id(engine->world, eid, rng_comp)) {
                const int32_t *r = (const int32_t *)ecs_get_id(engine->world, eid, rng_comp);
                if (r) u->range = *r;
            }

            /* AttackDamage */
            if (dmg_comp && ecs_has_id(engine->world, eid, dmg_comp)) {
                const int32_t *d = (const int32_t *)ecs_get_id(engine->world, eid, dmg_comp);
                if (d) u->damage = *d;
            }

            /* Faction (marker components) */
            if (red_comp && ecs_has_id(engine->world, eid, red_comp))
                u->faction = 0; /* red */
            else if (blue_comp && ecs_has_id(engine->world, eid, blue_comp))
                u->faction = 1; /* blue */

            /* MovementType (enum) */
            if (mt_comp && ecs_has_id(engine->world, eid, mt_comp)) {
                const int32_t *m = (const int32_t *)ecs_get_id(engine->world, eid, mt_comp);
                if (m) u->move_type = *m;
            }

            count++;
        }
    }
    ecs_query_fini(q);

    /* Sort by entity_id */
    for (int i = 0; i < count - 1; i++)
        for (int j = i + 1; j < count; j++)
            if (units[j].entity_id < units[i].entity_id) {
                UnitData tmp = units[i]; units[i] = units[j]; units[j] = tmp;
            }

    return count;
}

/* ŌöĆŌöĆ Helper: ensure TookDamage component exists ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static ecs_entity_t ensure_took_damage_comp(Engine *engine) {
    ecs_entity_t td = ecs_lookup(engine->world, "TookDamage");
    if (td) return td;

    /* Register it */
    td = ecs_entity(engine->world, { .name = "TookDamage" });
    ecs_set(engine->world, td, EcsComponent, {
        .size = sizeof(ecs_bool_t), .alignment = ECS_ALIGNOF(ecs_bool_t)
    });
    ecs_struct(engine->world, {
        .entity = td,
        .members = {{ .name = "value", .type = ecs_id(ecs_bool_t) }}
    });
    return td;
}

/* ŌöĆŌöĆ Spatial grid for O(1) occupancy lookups ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

#define GRID_MAX_X 512
#define GRID_MAX_Y 256
static int16_t g_occ_grid[GRID_MAX_X * GRID_MAX_Y]; /* unit index+1, 0=empty */

static void grid_clear(int mx, int my) {
    (void)mx; (void)my;
    memset(g_occ_grid, 0, sizeof(g_occ_grid));
}

static void grid_set(int x, int y, int unit_idx) {
    if (x >= 0 && x < GRID_MAX_X && y >= 0 && y < GRID_MAX_Y)
        g_occ_grid[y * GRID_MAX_X + x] = (int16_t)(unit_idx + 1);
}

static bool grid_occupied(int x, int y) {
    if (x < 0 || x >= GRID_MAX_X || y < 0 || y >= GRID_MAX_Y) return true;
    return g_occ_grid[y * GRID_MAX_X + x] != 0;
}

static int grid_unit_at(int x, int y) {
    if (x < 0 || x >= GRID_MAX_X || y < 0 || y >= GRID_MAX_Y) return -1;
    return g_occ_grid[y * GRID_MAX_X + x] - 1;
}

/* ŌöĆŌöĆ start_of_turn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_start_of_turn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t td = ecs_lookup(engine->world, "TookDamage");
    ecs_entity_t wpn_comp = ecs_lookup(engine->world, "Weapon");

    /* Clear TookDamage markers */
    if (td) {
        ecs_entity_t to_clear[4096];
        int clear_count = 0;

        ecs_query_t *q = ecs_query(engine->world, {
            .terms = {{ .id = td }, { .id = engine->user_entity_tag }},
            .cache_kind = EcsQueryCacheNone
        });
        ecs_iter_t it = ecs_query_iter(engine->world, q);
        while (ecs_query_next(&it)) {
            for (int i = 0; i < it.count && clear_count < 4096; i++) {
                to_clear[clear_count++] = it.entities[i];
            }
        }
        ecs_query_fini(q);

        for (int i = 0; i < clear_count; i++) {
            ecs_remove_id(engine->world, to_clear[i], td);
        }
    }

    /* Clear Weapon.attacked field (set to 0) */
    if (wpn_comp) {
        ecs_query_t *q = ecs_query(engine->world, {
            .terms = {{ .id = wpn_comp }, { .id = engine->user_entity_tag }},
            .cache_kind = EcsQueryCacheNone
        });
        ecs_iter_t it = ecs_query_iter(engine->world, q);
        while (ecs_query_next(&it)) {
            for (int i = 0; i < it.count; i++) {
                void *wpn = ecs_get_mut_id(engine->world, it.entities[i], wpn_comp);
                if (wpn) {
                    ecs_entity_t *attacked = (ecs_entity_t *)((char *)wpn + sizeof(int32_t));
                    *attacked = 0;
                    ecs_modified_id(engine->world, it.entities[i], wpn_comp);
                }
            }
        }
        ecs_query_fini(q);
    }
}

/* ŌöĆŌöĆ game_start ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_app_start(Engine *engine) {
    /* Find Map entity for bounds */
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    if (!map) return;

    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    if (!ms_comp) return;
    const void *ms_data = ecs_get_id(engine->world, map, ms_comp);
    if (!ms_data) return;
    int mx = *(const int32_t *)ms_data;
    int my = *((const int32_t *)ms_data + 1);
    if (mx == 0 && my == 0) return;

    { static int seed_offset = 0; srand((unsigned)time(NULL) + seed_offset++); }

    ecs_entity_t sr_comp = ecs_lookup(engine->world, "SpawnRequest");
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    if (!sr_comp || !loc_comp) return;

    /* Read unit counts from app.yaml (use --overrides for balance testing) */
    StoredApp *app = engine_app_get(engine, engine->sandbox_name);
    if (!app || app->archers <= 0 || app->knights <= 0) {
        fprintf(stderr, "Error: archers/knights not set in app.yaml\n");
        return;
    }
    int num_archers = app->archers;
    int num_knights = app->knights;

    int total = num_archers + num_knights;
    int cells = (mx + 1) * (my + 1);
    if (total > cells) {
        fprintf(stderr, "Error: %d units > %d cells, can't place without overlap\n", total, cells);
        return;
    }

    fprintf(stderr, "Spawning %dA vs %dK\n", num_archers, num_knights);

    /* Placement grid to prevent overlaps */
    grid_clear(mx, my);

    /* knights */
    for (int k = 0; k < num_knights; k++) {
        char name[32]; snprintf(name, sizeof(name), "sk%d", k + 1);
        ecs_entity_t e = engine_entity_create(engine, name);
        if (!e) continue;
        ecs_add_id(engine->world, e, sr_comp);
        void *sr = ecs_get_mut_id(engine->world, e, sr_comp);
        if (sr) { *(char **)sr = ecs_os_strdup("Knight"); ecs_modified_id(engine->world, e, sr_comp); }

        int px, py;
        do { px = rand() % (mx + 1); py = rand() % (my + 1); } while (grid_occupied(px, py));
        grid_set(px, py, 1);

        ecs_add_id(engine->world, e, loc_comp);
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, e, loc_comp);
        if (loc) { loc[0] = px; loc[1] = py; ecs_modified_id(engine->world, e, loc_comp); }
    }

    /* archers */
    for (int a = 0; a < num_archers; a++) {
        char name[32]; snprintf(name, sizeof(name), "sa%d", a + 1);
        ecs_entity_t e = engine_entity_create(engine, name);
        if (!e) continue;
        ecs_add_id(engine->world, e, sr_comp);
        void *sr = ecs_get_mut_id(engine->world, e, sr_comp);
        if (sr) { *(char **)sr = ecs_os_strdup("Archer"); ecs_modified_id(engine->world, e, sr_comp); }

        int px, py;
        do { px = rand() % (mx + 1); py = rand() % (my + 1); } while (grid_occupied(px, py));
        grid_set(px, py, 1);

        ecs_add_id(engine->world, e, loc_comp);
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, e, loc_comp);
        if (loc) { loc[0] = px; loc[1] = py; ecs_modified_id(engine->world, e, loc_comp); }
    }

    engine_system_disable(engine, "app_start");
}

/* ŌöĆŌöĆ BFS distance fields ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * dist_to_red[y][x] = manhattan distance to nearest red (archer) unit
 * dist_to_blue[y][x] = manhattan distance to nearest blue (knight) unit
 * Built via BFS flood-fill from all enemy positions: O(cells) not O(units┬▓).
 * A cell with distance 0 contains an enemy ŌĆö the movement target and attack condition.
 */

static int16_t g_dist_to_red[GRID_MAX_Y * GRID_MAX_X];
static int16_t g_dist_to_blue[GRID_MAX_Y * GRID_MAX_X];

/* BFS queue ŌĆö max cells = GRID_MAX_X * GRID_MAX_Y */
#define BFS_MAX (GRID_MAX_X * GRID_MAX_Y)
static int32_t g_bfs_queue[BFS_MAX];

static void build_distance_field(int16_t *dist, UnitData *units, int count,
                                 int faction, int mx, int my) {
    int w = mx + 1, h = my + 1;
    /* Init all to -1 (unvisited) */
    for (int y = 0; y < h; y++)
        for (int x = 0; x < w; x++)
            dist[y * GRID_MAX_X + x] = -1;

    /* Seed BFS with all units of the target faction */
    int head = 0, tail = 0;
    for (int i = 0; i < count; i++) {
        if (units[i].faction != faction) continue;
        int x = units[i].x, y = units[i].y;
        if (x >= 0 && x < w && y >= 0 && y < h && dist[y * GRID_MAX_X + x] < 0) {
            dist[y * GRID_MAX_X + x] = 0;
            g_bfs_queue[tail++] = y * w + x;
        }
    }

    /* BFS flood fill */
    static const int dx[] = {0, 0, -1, 1};
    static const int dy[] = {-1, 1, 0, 0};
    while (head < tail) {
        int pos = g_bfs_queue[head++];
        int cy = pos / w, cx = pos % w;
        int16_t d = dist[cy * GRID_MAX_X + cx];
        for (int dir = 0; dir < 4; dir++) {
            int nx = cx + dx[dir], ny = cy + dy[dir];
            if (nx < 0 || nx >= w || ny < 0 || ny >= h) continue;
            if (dist[ny * GRID_MAX_X + nx] >= 0) continue;
            dist[ny * GRID_MAX_X + nx] = d + 1;
            g_bfs_queue[tail++] = ny * w + nx;
        }
    }
}

static int dist_field_get(int16_t *dist, int x, int y) {
    if (x < 0 || x >= GRID_MAX_X || y < 0 || y >= GRID_MAX_Y) return 9999;
    int16_t v = dist[y * GRID_MAX_X + x];
    return v >= 0 ? v : 9999;
}

/* Count enemies within manhattan range of (cx,cy) using the occupancy grid */
static int count_enemies_in_range(int cx, int cy, int range, int my_faction,
                                  UnitData *units) {
    int count = 0;
    for (int dy = -range; dy <= range; dy++) {
        int ax = range - abs(dy);
        for (int dx = -ax; dx <= ax; dx++) {
            int ui = grid_unit_at(cx + dx, cy + dy);
            if (ui >= 0 && units[ui].faction != my_faction && units[ui].health > 0)
                count++;
        }
    }
    return count;
}

/* Score a cell for movement using distance fields + grid */
static int score_cell(int nx, int ny, int move_type, int range,
                      int16_t *enemy_dist, int faction, UnitData *units) {
    int d = dist_field_get(enemy_dist, nx, ny);
    if (move_type == 1) {
        /* Knight: minimize distance to nearest enemy */
        return -d;
    } else {
        /* Archer: safe with targets in range is ideal */
        bool safe = (d >= range);
        if (safe) {
            int in_range = count_enemies_in_range(nx, ny, range, faction, units);
            if (in_range > 0)
                return 20000 + in_range;
            else
                return -d; /* safe but nothing to shoot, approach */
        } else {
            return d * 1000; /* too close, flee */
        }
    }
}

/* ŌöĆŌöĆ movement ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_movement(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    UnitData units[4096];
    int count = collect_units(engine, units, 4096);
    if (count == 0) return;

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Set energy */
    for (int i = 0; i < count; i++) units[i].energy = units[i].speed;

    /* Build spatial grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Build distance fields ŌĆö O(cells) via BFS */
    build_distance_field(g_dist_to_red, units, count, 0, mx, my);
    build_distance_field(g_dist_to_blue, units, count, 1, mx, my);

    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};
    int half_mx = mx / 2, half_my = my / 2;

    bool moved = true;
    while (moved) {
        moved = false;
        for (int i = 0; i < count; i++) {
            UnitData *ent = &units[i];
            if (ent->energy <= 0) continue;

            /* Enemy distance field for this unit */
            int16_t *enemy_dist = (ent->faction == 0) ? g_dist_to_blue : g_dist_to_red;

            /* Collect candidates with scores ŌĆö O(1) per direction via distance field */
            int cand_x[5], cand_y[5], cand_score[5], ncand = 0;
            int best_score = -999999;

            for (int d = 0; d < 5; d++) {
                int nx = ent->x + dirs[d][0];
                int ny = ent->y + dirs[d][1];

                if (nx < 0 || nx > mx || ny < 0 || ny > my) continue;
                if (d != 4 && grid_occupied(nx, ny)) continue;

                int score = score_cell(nx, ny, ent->move_type, ent->range,
                                       enemy_dist, ent->faction, units);

                cand_x[ncand] = nx;
                cand_y[ncand] = ny;
                cand_score[ncand] = score;
                ncand++;
                if (score > best_score) best_score = score;
            }

            /* Tiebreaker 1 (knights): prefer backed by ally ŌĆö O(1) grid check */
            int best_backed = 0;
            if (ent->move_type == 1) {
                for (int c = 0; c < ncand; c++) {
                    if (cand_score[c] != best_score) continue;
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (ally >= 0 && ally != i && units[ally].faction == ent->faction) {
                        best_backed = 1; break;
                    }
                }
            }

            /* Tiebreaker 2: most central */
            int best_cdist = 999999;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int cd = abs(cand_x[c] - half_mx) + abs(cand_y[c] - half_my);
                if (cd < best_cdist) best_cdist = cd;
            }

            /* Pick first matching candidate */
            int bx = ent->x, by = ent->y;
            bool found = false;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int cd = abs(cand_x[c] - half_mx) + abs(cand_y[c] - half_my);
                if (cd != best_cdist) continue;
                bx = cand_x[c]; by = cand_y[c];
                found = true;
                break;
            }

            if (found && (bx != ent->x || by != ent->y)) {
                g_occ_grid[ent->y * GRID_MAX_X + ent->x] = 0;
                ent->x = bx; ent->y = by;
                grid_set(bx, by, i);
                ent->energy--;

                int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, ent->eid, loc_comp);
                if (loc) { loc[0] = ent->x; loc[1] = ent->y; ecs_modified_id(engine->world, ent->eid, loc_comp); }
                moved = true;
            } else if (!found) {
                ent->energy = 0;
            }
        }
    }
}

/* ŌöĆŌöĆ attack ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_attack(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    UnitData units[4096];
    int count = collect_units(engine, units, 4096);

    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    ecs_entity_t wpn_comp = ecs_lookup(engine->world, "Weapon");
    ecs_entity_t td_comp = ensure_took_damage_comp(engine);
    if (!hp_comp) return;

    /* Get map bounds for center tiebreaking */
    ecs_entity_t map_ent = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 320, my = 144;
    if (map_ent && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map_ent, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }
    int cx = mx / 2, cy = my / 2;

    /* Build occupancy grid if not already built by movement */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    for (int i = 0; i < count; i++) {
        if (units[i].health <= 0) continue;
        int range = units[i].range;

        UnitData *target = NULL;
        int target_dist = 999999;
        int target_cdist = 999999;

        for (int dy = -range; dy <= range; dy++) {
            int ax = range - abs(dy);
            for (int dx = -ax; dx <= ax; dx++) {
                int tx = units[i].x + dx;
                int ty = units[i].y + dy;
                int ui = grid_unit_at(tx, ty);
                if (ui < 0) continue;
                if (units[ui].health <= 0 || units[ui].faction == units[i].faction) continue;

                int dist = abs(dx) + abs(dy);
                int cdist = abs(tx - cx) + abs(ty - cy);
                if (!target ||
                    units[ui].health < target->health ||
                    (units[ui].health == target->health && dist < target_dist) ||
                    (units[ui].health == target->health && dist == target_dist && cdist < target_cdist) ||
                    (units[ui].health == target->health && dist == target_dist && cdist == target_cdist && units[ui].entity_id < target->entity_id)) {
                    target = &units[ui];
                    target_dist = dist;
                    target_cdist = cdist;
                }
            }
        }

        if (target) {
            target->health -= units[i].damage;
            int32_t *hp = (int32_t *)ecs_get_mut_id(engine->world, target->eid, hp_comp);
            if (hp) { *hp = target->health; ecs_modified_id(engine->world, target->eid, hp_comp); }

            if (td_comp) {
                ecs_add_id(engine->world, target->eid, td_comp);
            }

            /* Record who this unit attacked (Weapon.attacked is second field, offset sizeof(int32_t)) */
            if (wpn_comp && ecs_has_id(engine->world, units[i].eid, wpn_comp)) {
                void *wpn = ecs_get_mut_id(engine->world, units[i].eid, wpn_comp);
                if (wpn) {
                    ecs_entity_t *attacked = (ecs_entity_t *)((char *)wpn + sizeof(int32_t));
                    *attacked = target->eid;
                    ecs_modified_id(engine->world, units[i].eid, wpn_comp);
                }
            }
        }
    }
}

/* ŌöĆŌöĆ despawn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_despawn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    if (!hp_comp) return;

    /* Collect entities to delete (can't delete during iteration) */
    ecs_entity_t to_delete[4096];
    int del_count = 0;

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {{ .id = hp_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count; i++) {
            const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, it.entities[i], hp_comp);
            if (hp && *hp <= 0 && del_count < 4096)
                to_delete[del_count++] = it.entities[i];
        }
    }
    ecs_query_fini(q);

    for (int i = 0; i < del_count; i++)
        ecs_delete(engine->world, to_delete[i]);
}

/* ŌöĆŌöĆ spawn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_spawn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t sr_comp = ecs_lookup(engine->world, "SpawnRequest");
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    if (!sr_comp || !loc_comp) return;

    /* Collect spawn requests */
    typedef struct { ecs_entity_t eid; char template[64]; int x, y; } SpawnReq;
    SpawnReq reqs[4096];
    int req_count = 0;

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {{ .id = sr_comp }, { .id = loc_comp }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count && req_count < 4096; i++) {
            ecs_entity_t eid = it.entities[i];
            const void *sr = ecs_get_id(engine->world, eid, sr_comp);
            const void *loc = ecs_get_id(engine->world, eid, loc_comp);
            if (!sr || !loc) continue;

            const char *tmpl = *(const char *const *)sr;
            if (!tmpl) continue;

            reqs[req_count].eid = eid;
            snprintf(reqs[req_count].template, 64, "%s", tmpl);
            reqs[req_count].x = *(const int32_t *)loc;
            reqs[req_count].y = *((const int32_t *)loc + 1);
            req_count++;
        }
    }
    ecs_query_fini(q);

    /* Process */
    for (int i = 0; i < req_count; i++) {
        ecs_entity_t spawned = engine_entity_spawn(engine, reqs[i].template, NULL);
        if (spawned && loc_comp) {
            ecs_add_id(engine->world, spawned, loc_comp);
            int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, spawned, loc_comp);
            if (loc) {
                loc[0] = reqs[i].x; loc[1] = reqs[i].y;
                ecs_modified_id(engine->world, spawned, loc_comp);
            }
        }
        ecs_delete(engine->world, reqs[i].eid);
    }
}

/* ŌöĆŌöĆ game_over ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_app_stop(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t red_comp = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    if (!red_comp || !blue_comp || !hp_comp) return;

    bool has_red = false, has_blue = false;

    /* Check for existing red units (not health ŌĆö despawn handles dead units next turn) */
    ecs_query_t *qr = ecs_query(engine->world, {
        .terms = {{ .id = red_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t itr = ecs_query_iter(engine->world, qr);
    while (ecs_query_next(&itr)) {
        if (itr.count > 0) { has_red = true; ecs_iter_fini(&itr); break; }
    }
    ecs_query_fini(qr);

    /* Check for existing blue units */
    ecs_query_t *qb = ecs_query(engine->world, {
        .terms = {{ .id = blue_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t itb = ecs_query_iter(engine->world, qb);
    while (ecs_query_next(&itb)) {
        if (itb.count > 0) { has_blue = true; ecs_iter_fini(&itb); break; }
    }
    ecs_query_fini(qb);

    if (!has_red) {
        engine->game_over = true;
        snprintf(engine->game_over_message, sizeof(engine->game_over_message), "Knights Win");
    }
    if (!has_blue) {
        engine->game_over = true;
        snprintf(engine->game_over_message, sizeof(engine->game_over_message), "Archers Win");
    }
}

/* ŌöĆŌöĆ Registration ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

void avk_register_native_systems(Engine *engine) {
    /* Ensure TookDamage component exists */
    ensure_took_damage_comp(engine);

    engine_system_register_native(engine, "start_of_turn", avk_start_of_turn);
    engine_system_register_native(engine, "app_start", avk_app_start);
    engine_system_register_native(engine, "movement", avk_movement);
    engine_system_register_native(engine, "attack", avk_attack);
    engine_system_register_native(engine, "despawn", avk_despawn);
    engine_system_register_native(engine, "spawn", avk_spawn);
    engine_system_register_native(engine, "app_stop", avk_app_stop);
}
#ifndef AVK_SYSTEMS_H
#define AVK_SYSTEMS_H

#include "engine/engine.h"

/* Register all native archer systems on an engine.
   Replaces Lua systems with C implementations for the same names. */
void avk_register_native_systems(Engine *engine);

#endif
#include "test.h"
#include "../src/engine/engine.h"
#include "../src/engine/simulation.h"
#include "../src/engine/app.h"
#include "../src/engine/history.h"
#include "../src/engine/components.h"

static Engine *engine;

static void count_factions(int *archers, int *knights) {
    *archers = 0; *knights = 0;
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    ecs_entity_t red_comp = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    if (!hp_comp) return;
    EntityList list = engine_entity_list(engine);
    for (int i = 0; i < list.count; i++) {
        ecs_entity_t eid = list.items[i].id;
        const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, eid, hp_comp);
        if (!hp || *hp <= 0) continue;
        if (red_comp && ecs_has_id(engine->world, eid, red_comp)) (*archers)++;
        else if (blue_comp && ecs_has_id(engine->world, eid, blue_comp)) (*knights)++;
    }
    engine_entity_list_free(&list);
}

static void setup_game(int map_size) {
    engine = engine_init(NULL);
    snprintf(engine->sandboxes_dir, sizeof(engine->sandboxes_dir), "./sandboxes/");
    engine_sandbox_select(engine, "avk");
    AppStartResult asr;
    engine_app_start(engine, NULL, &asr);
    ecs_entity_t map = engine_entity_create(engine, "Map");
    char vals[64];
    snprintf(vals, sizeof(vals), "x: %d, y: %d", map_size, map_size);
    engine_entity_add_component(engine, map, "MapSize", vals);
}

static void advance(int turns) {
    for (int i = 0; i < turns; i++) {
        TurnResult tr;
        if (!engine_sim_turn(engine, &tr)) break;
        engine_turn_result_free(&tr);
    }
}

static void unpause(void) {
    ecs_entity_t gs = ecs_lookup(engine->world, "GameState");
    ecs_entity_t sp = ecs_lookup(engine->world, "SimulationPaused");
    if (gs && sp) ecs_remove_id(engine->world, gs, sp);
}

/* ŌöĆŌöĆ Rewind basics ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(rewind_restores_turn_counter) {
    setup_game(100);
    advance(10);
    ASSERT_EQ(engine->turn_counter, 10);

    engine_sim_rewind(engine, 5);
    ASSERT_EQ(engine->turn_counter, 5);
    ASSERT(is_simulation_paused(engine));

    engine_fini(engine);
}

TEST(rewind_clears_game_over) {
    setup_game(100);  /* Large enough to last several turns */
    advance(1000);
    ASSERT(engine->game_over);

    /* Rewind to a turn that exists in history (before game ended) */
    int oldest = history_oldest_turn(engine);
    ASSERT(oldest > 0);

    engine_sim_rewind(engine, oldest);
    ASSERT(!engine->game_over);
    ASSERT_EQ(engine->turn_counter, oldest);

    engine_fini(engine);
}

TEST(rewind_out_of_range_fails) {
    setup_game(100);
    advance(5);

    ASSERT(!engine_sim_rewind(engine, 0));   /* before history */
    ASSERT(!engine_sim_rewind(engine, 99));  /* after history */
    ASSERT_EQ(engine->turn_counter, 5);      /* unchanged */

    engine_fini(engine);
}

/* ŌöĆŌöĆ Determinism: rewind to N, advance to M, verify counts match ŌöĆŌöĆŌöĆŌöĆ */

TEST(determinism_rewind_and_replay) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);
    int target_turn = engine->turn_counter;
    ASSERT(a_target > 0);  /* both factions still alive */
    ASSERT(k_target > 0);

    /* Rewind to 5, advance to 10 ŌĆö should match */
    engine_sim_rewind(engine, 5);
    unpause();
    advance(5);

    int a, k;
    count_factions(&a, &k);
    ASSERT_EQ(engine->turn_counter, target_turn);
    ASSERT_EQ(a, a_target);
    ASSERT_EQ(k, k_target);

    engine_fini(engine);
}

TEST(determinism_repeated_rewind_cycles) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);

    /* Rewind 5, advance 5, repeat 5 times ŌĆö every iteration should match */
    for (int trial = 0; trial < 5; trial++) {
        engine_sim_rewind(engine, 5);
        unpause();
        advance(5);

        int a, k;
        count_factions(&a, &k);
        ASSERT_EQ(a, a_target);
        ASSERT_EQ(k, k_target);
    }

    engine_fini(engine);
}

TEST(determinism_rewind_to_start) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);
    int target_turn = engine->turn_counter;

    /* Rewind to turn 1, replay all the way to target */
    engine_sim_rewind(engine, 1);
    unpause();
    advance(target_turn - 1);

    int a, k;
    count_factions(&a, &k);
    ASSERT_EQ(engine->turn_counter, target_turn);
    ASSERT_EQ(a, a_target);
    ASSERT_EQ(k, k_target);

    engine_fini(engine);
}

/* ŌöĆŌöĆ Pause behavior ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(paused_turn_does_not_advance) {
    setup_game(100);
    advance(5);

    int a_before, k_before;
    count_factions(&a_before, &k_before);

    engine_sim_rewind(engine, 3);
    /* Still paused ŌĆö run a turn, nothing should change */
    TurnResult tr;
    engine_sim_turn(engine, &tr);
    engine_turn_result_free(&tr);

    ASSERT_EQ(engine->turn_counter, 3);
    ASSERT(is_simulation_paused(engine));

    engine_fini(engine);
}

TEST(unpause_resumes_simulation) {
    setup_game(100);
    advance(5);

    engine_sim_rewind(engine, 3);
    ASSERT(is_simulation_paused(engine));

    unpause();
    ASSERT(!is_simulation_paused(engine));

    /* Advance should work now */
    TurnResult tr;
    engine_sim_turn(engine, &tr);
    engine_turn_result_free(&tr);
    ASSERT_EQ(engine->turn_counter, 4);

    engine_fini(engine);
}

/* ŌöĆŌöĆ History query ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(history_tracks_turns) {
    setup_game(100);
    advance(10);

    ASSERT_EQ(history_newest_turn(engine), 10);
    ASSERT_EQ(history_oldest_turn(engine), 1);

    engine_fini(engine);
}

TEST(history_truncated_on_rewind) {
    setup_game(100);
    advance(10);
    ASSERT_EQ(history_newest_turn(engine), 10);

    engine_sim_rewind(engine, 5);
    ASSERT_EQ(history_newest_turn(engine), 5);

    engine_fini(engine);
}

int main(void) {
    TEST_SUITE("Rewind Basics");
    RUN(rewind_restores_turn_counter);
    RUN(rewind_clears_game_over);
    RUN(rewind_out_of_range_fails);

    TEST_SUITE("Rewind Determinism");
    RUN(determinism_rewind_and_replay);
    RUN(determinism_repeated_rewind_cycles);
    RUN(determinism_rewind_to_start);

    TEST_SUITE("Pause Behavior");
    RUN(paused_turn_does_not_advance);
    RUN(unpause_resumes_simulation);

    TEST_SUITE("History");
    RUN(history_tracks_turns);
    RUN(history_truncated_on_rewind);

    TEST_RESULTS();
}
