#include "gifrecord.h"
#include "font8x14.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#ifdef _WIN32
#define popen  _popen
#define pclose _pclose
#endif

#define FONT_W 8
#define FONT_H 14

/* RGB palette indexed by color constants */
static const uint8_t PALETTE[6][3] = {
    {0x00, 0x00, 0x00},  /* 0: black */
    {0xCC, 0x00, 0x00},  /* 1: red (archer) */
    {0x55, 0x55, 0xFF},  /* 2: blue (knight) */
    {0xFF, 0xFF, 0xFF},  /* 3: white (damaged/header) */
    {0x80, 0x80, 0x80},  /* 4: gray (border) */
    {0xFF, 0xFF, 0x00},  /* 5: yellow (game over) */
};

struct GifRecorder {
    FILE *pipe;
    uint8_t *framebuf;
    int pixel_w, pixel_h;
    int cell_w, cell_h;
    int grid_cols, grid_rows;
};

GifRecorder *gif_recorder_open(const char *output_path, int cell_w, int cell_h,
                                int grid_cols, int grid_rows, int fps) {
    /* Check ffmpeg availability */
    FILE *check = popen("ffmpeg -version 2>/dev/null", "r");
    if (!check) {
        fprintf(stderr, "Error: ffmpeg not found. Install ffmpeg to use --record.\n");
        return NULL;
    }
    pclose(check);

    GifRecorder *rec = calloc(1, sizeof(GifRecorder));
    rec->cell_w = cell_w;
    rec->cell_h = cell_h;
    rec->grid_cols = grid_cols;
    rec->grid_rows = grid_rows;
    rec->pixel_w = grid_cols * cell_w;
    rec->pixel_h = grid_rows * cell_h;
    rec->framebuf = calloc(rec->pixel_w * rec->pixel_h * 3, 1);

    char cmd[1024];
    snprintf(cmd, sizeof(cmd),
        "ffmpeg -y -f rawvideo -pixel_format rgb24 -video_size %dx%d "
        "-framerate %d -i pipe:0 "
        "-vf \"split[s0][s1];[s0]palettegen=max_colors=16[p];[s1][p]paletteuse=dither=bayer\" "
        "-loop 0 \"%s\" 2>/dev/null",
        rec->pixel_w, rec->pixel_h, fps, output_path);

    rec->pipe = popen(cmd, "w");
    if (!rec->pipe) {
        fprintf(stderr, "Error: failed to start ffmpeg.\n");
        free(rec->framebuf);
        free(rec);
        return NULL;
    }

    return rec;
}

static void render_glyph(uint8_t *framebuf, int pixel_w,
                          int px, int py, char ch,
                          const uint8_t *rgb, int cell_w, int cell_h) {
    if (ch < 32 || ch > 126) return;
    const uint8_t *glyph = font_8x14[ch - 32];

    for (int gy = 0; gy < FONT_H && gy < cell_h; gy++) {
        uint8_t row = glyph[gy];
        for (int gx = 0; gx < FONT_W && gx < cell_w; gx++) {
            if (row & (0x80 >> gx)) {
                int fx = px + gx;
                int fy = py + gy;
                uint8_t *pixel = &framebuf[(fy * pixel_w + fx) * 3];
                pixel[0] = rgb[0];
                pixel[1] = rgb[1];
                pixel[2] = rgb[2];
            }
        }
    }
}

GifRecorder *gif_recorder_open_frames(const char *output_dir, int cell_w, int cell_h,
                                       int grid_cols, int grid_rows) {
    FILE *check = popen("ffmpeg -version 2>/dev/null", "r");
    if (!check) {
        fprintf(stderr, "Error: ffmpeg not found. Install ffmpeg to use --image.\n");
        return NULL;
    }
    pclose(check);

    GifRecorder *rec = calloc(1, sizeof(GifRecorder));
    rec->cell_w = cell_w;
    rec->cell_h = cell_h;
    rec->grid_cols = grid_cols;
    rec->grid_rows = grid_rows;
    rec->pixel_w = grid_cols * cell_w;
    rec->pixel_h = grid_rows * cell_h;
    rec->framebuf = calloc(rec->pixel_w * rec->pixel_h * 3, 1);

    char cmd[1024];
    snprintf(cmd, sizeof(cmd),
        "ffmpeg -y -f rawvideo -pixel_format rgb24 -video_size %dx%d "
        "-framerate 1 -i pipe:0 \"%s/frame_%%04d.png\" 2>/dev/null",
        rec->pixel_w, rec->pixel_h, output_dir);

    rec->pipe = popen(cmd, "w");
    if (!rec->pipe) {
        fprintf(stderr, "Error: failed to start ffmpeg.\n");
        free(rec->framebuf);
        free(rec);
        return NULL;
    }

    return rec;
}

bool gif_recorder_write_frame(GifRecorder *rec, const CellGrid *grid) {
    if (!rec || !rec->pipe) return false;

    /* Clear to black */
    memset(rec->framebuf, 0, rec->pixel_w * rec->pixel_h * 3);

    /* Render each cell */
    for (int r = 0; r < grid->rows && r < rec->grid_rows; r++) {
        for (int c = 0; c < grid->cols && c < rec->grid_cols; c++) {
            Cell *cell = &grid->cells[r * grid->cols + c];
            if (cell->ch == 0) continue;

            const uint8_t *rgb = PALETTE[cell->color < 6 ? cell->color : 0];
            int px = c * rec->cell_w;
            int py = r * rec->cell_h;
            render_glyph(rec->framebuf, rec->pixel_w, px, py, cell->ch, rgb,
                         rec->cell_w, rec->cell_h);
        }
    }

    size_t frame_size = rec->pixel_w * rec->pixel_h * 3;
    return fwrite(rec->framebuf, 1, frame_size, rec->pipe) == frame_size;
}

bool gif_recorder_close(GifRecorder *rec) {
    if (!rec) return false;
    bool ok = true;
    if (rec->pipe) {
        ok = (pclose(rec->pipe) == 0);
    }
    free(rec->framebuf);
    free(rec);
    return ok;
}
#ifndef GIFRECORD_H
#define GIFRECORD_H

#include <stdbool.h>
#include "cellgrid.h"

typedef struct GifRecorder GifRecorder;

/* Open ffmpeg pipe for GIF recording. Returns NULL on failure. */
GifRecorder *gif_recorder_open(const char *output_path, int cell_w, int cell_h,
                                int grid_cols, int grid_rows, int fps);

/* Write one frame from a CellGrid. */
bool gif_recorder_write_frame(GifRecorder *rec, const CellGrid *grid);

/* Open ffmpeg pipe for writing individual PNG frames to a directory. */
GifRecorder *gif_recorder_open_frames(const char *output_dir, int cell_w, int cell_h,
                                       int grid_cols, int grid_rows);

/* Close pipe, wait for ffmpeg. Returns true on success. */
bool gif_recorder_close(GifRecorder *rec);

#endif
