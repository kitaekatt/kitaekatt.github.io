    transition: width 0.15s ease, background 0.15s ease;
    min-width: 0;
}
#fps-text {
    font-size: 0.7em;
    font-family: monospace;
    color: #fff;
    position: absolute;
    left: 0; right: 0;
    text-align: center;
    line-height: 16px;
}
#speed-slider { width: 100px; }
#loading {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: #1a1a2e;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    z-index: 100;
}
#loading-title { font-size: 1.4em; color: #f0f0f0; }
#loading-steps {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.9em;
    font-family: monospace;
}
.load-step { color: #555; }
.load-step.active { color: #4dabf7; }
.load-step.done { color: #69db7c; }
.load-step .elapsed { color: #888; margin-left: 8px; font-size: 0.85em; }
#scrub-bar {
    width: 100%;
    max-width: 900px;
    height: 12px;
    background: #444;
    border-radius: 3px;
    position: relative;
    cursor: pointer;
    margin-top: 8px;
    flex-shrink: 0;
}
#scrub-fill {
    height: 100%;
