#include "systems.h"
#include "engine/systems.h"
#include "engine/components.h"
#include "engine/templates.h"
#include "engine/history.h"
#include "engine/app.h"
#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <math.h>
#include <time.h>
#include <stddef.h>
#ifndef _WIN32
#include <pthread.h>
#endif

/* ŌöĆŌöĆ Helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

typedef struct {
    ecs_entity_t eid;
    int entity_id;
    int x, y;
    int health;
    int speed, energy;
    int range, damage;
    int faction;  /* enum index: 0=red, 1=blue */
    int move_type; /* enum index: 0=kite, 1=charge */
} UnitData;

static int manhattan(int x1, int y1, int x2, int y2) {
    return abs(x1 - x2) + abs(y1 - y2);
}

/* Cached component entity IDs ŌĆö resolved once, reused across calls */
static ecs_entity_t c_loc=0, c_hp=0, c_spd=0, c_wpn=0, c_dmg=0, c_red=0, c_blue=0, c_mt=0;
static bool c_resolved = false;

static void resolve_component_ids(Engine *engine) {
    if (c_resolved) return;
    c_loc  = ecs_lookup(engine->world, "Location");
    c_hp   = ecs_lookup(engine->world, "Health");
    c_spd  = ecs_lookup(engine->world, "MovementSpeed");
    c_wpn  = ecs_lookup(engine->world, "Weapon");
    c_dmg  = ecs_lookup(engine->world, "AttackDamage");
    c_red  = ecs_lookup(engine->world, "RedFaction");
    c_blue = ecs_lookup(engine->world, "BlueFaction");
    c_mt   = ecs_lookup(engine->world, "MovementType");
    c_resolved = true;
}

static int unit_cmp_entity_id(const void *a, const void *b) {
    return ((const UnitData *)a)->entity_id - ((const UnitData *)b)->entity_id;
}

/* Collect living units from query into array, return count */
static int collect_units(Engine *engine, UnitData *units, int max_units) {
    resolve_component_ids(engine);
    ecs_entity_t loc_comp = c_loc;
    ecs_entity_t hp_comp = c_hp;
    ecs_entity_t spd_comp = c_spd;
    ecs_entity_t rng_comp = c_wpn;
    ecs_entity_t dmg_comp = c_dmg;
    ecs_entity_t red_comp = c_red;
    ecs_entity_t blue_comp = c_blue;
    ecs_entity_t mt_comp = c_mt;

    if (!loc_comp || !hp_comp) return 0;

    /* Query for entities with Location + Health + UserEntity.
     * Use ecs_field() for bulk access instead of per-entity ecs_get_id. */
    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {
            { .id = loc_comp },
            { .id = hp_comp },
            { .id = engine->user_entity_tag },
        },
        .cache_kind = EcsQueryCacheNone
    });

    int count = 0;
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        /* Bulk field access ŌĆö contiguous arrays for matched components */
        const int32_t *locs = (const int32_t *)ecs_field_w_size(&it, sizeof(int32_t) * 2, 0);  /* Location: {x, y} */
        const int32_t *hps = (const int32_t *)ecs_field_w_size(&it, sizeof(int32_t), 1);       /* Health: {base} */

        for (int i = 0; i < it.count && count < max_units; i++) {
            int32_t hp_val = hps[i];
            if (hp_val <= 0) continue;

            ecs_entity_t eid = it.entities[i];
            UnitData *u = &units[count];
            u->eid = eid;
            u->health = hp_val;
            u->x = locs[i * 2];
            u->y = locs[i * 2 + 1];

            /* EntityId */
            const int32_t *eid_val = (const int32_t *)ecs_get_id(engine->world, eid, engine->entity_id_comp);
            u->entity_id = eid_val ? *eid_val : 0;

            /* Per-entity reads for optional components */
            if (spd_comp) {
                const int32_t *spd = (const int32_t *)ecs_get_id(engine->world, eid, spd_comp);
                if (spd) { u->speed = *spd; u->energy = *spd; }
            }
            if (rng_comp) {
                const int32_t *r = (const int32_t *)ecs_get_id(engine->world, eid, rng_comp);
                if (r) u->range = *r;
            }
            if (dmg_comp) {
                const int32_t *d = (const int32_t *)ecs_get_id(engine->world, eid, dmg_comp);
                if (d) u->damage = *d;
            }
            if (red_comp && ecs_has_id(engine->world, eid, red_comp))
                u->faction = 0;
            else if (blue_comp && ecs_has_id(engine->world, eid, blue_comp))
                u->faction = 1;
            if (mt_comp) {
                const int32_t *m = (const int32_t *)ecs_get_id(engine->world, eid, mt_comp);
                if (m) u->move_type = *m;
            }

            count++;
        }
    }
    ecs_query_fini(q);

    /* Sort by entity_id ŌĆö O(n log n) via qsort */
    if (count > 1) {
        qsort(units, (size_t)count, sizeof(UnitData), unit_cmp_entity_id);
    }

    return count;
}

/* ŌöĆŌöĆ Helper: ensure TookDamage component exists ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static ecs_entity_t ensure_took_damage_comp(Engine *engine) {
    ecs_entity_t td = ecs_lookup(engine->world, "TookDamage");
    if (td) return td;

    /* Register it */
    td = ecs_entity(engine->world, { .name = "TookDamage" });
    ecs_set(engine->world, td, EcsComponent, {
        .size = sizeof(ecs_bool_t), .alignment = ECS_ALIGNOF(ecs_bool_t)
    });
    ecs_struct(engine->world, {
        .entity = td,
        .members = {{ .name = "value", .type = ecs_id(ecs_bool_t) }}
    });
    return td;
}

/* ŌöĆŌöĆ PerformanceStats singleton ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

typedef struct {
    int32_t df_full_rebuilds;     /* full BFS distance field rebuilds this turn */
    int32_t df_incremental;       /* incremental distance field updates this turn */
    int32_t df_full_total;        /* cumulative across all turns */
    int32_t df_incremental_total; /* cumulative across all turns */
    int32_t movement_iterations;  /* while(any_moved) iterations this turn */
    int32_t movement_iter_total;  /* cumulative */
    /* Sub-system timing within movement (microseconds, cumulative) */
    int32_t us_collect;           /* collect_units query time */
    int32_t us_df_rebuild;        /* distance field builds inside movement */
    int32_t us_decide;            /* per-unit move decision logic */
    int32_t us_apply;             /* move application + ECS writes */
    int32_t us_resolve;           /* collision/intent resolution */
} PerformanceStats;

static ecs_entity_t g_perf_comp = 0;

static PerformanceStats *perf_get(Engine *engine) {
    if (!g_perf_comp) {
        g_perf_comp = ecs_lookup(engine->world, "PerformanceStats");
        if (!g_perf_comp) {
            g_perf_comp = ecs_entity(engine->world, { .name = "PerformanceStats" });
            ecs_set(engine->world, g_perf_comp, EcsComponent, {
                .size = sizeof(PerformanceStats),
                .alignment = ECS_ALIGNOF(PerformanceStats)
            });
            ecs_struct(engine->world, {
                .entity = g_perf_comp,
                .members = {
                    { .name = "df_full_rebuilds",     .type = ecs_id(ecs_i32_t) },
                    { .name = "df_incremental",       .type = ecs_id(ecs_i32_t) },
                    { .name = "df_full_total",        .type = ecs_id(ecs_i32_t) },
                    { .name = "df_incremental_total",  .type = ecs_id(ecs_i32_t) },
                    { .name = "movement_iterations",  .type = ecs_id(ecs_i32_t) },
                    { .name = "movement_iter_total",  .type = ecs_id(ecs_i32_t) },
                    { .name = "us_collect",           .type = ecs_id(ecs_i32_t) },
                    { .name = "us_df_rebuild",        .type = ecs_id(ecs_i32_t) },
                    { .name = "us_decide",            .type = ecs_id(ecs_i32_t) },
                    { .name = "us_apply",             .type = ecs_id(ecs_i32_t) },
                    { .name = "us_resolve",           .type = ecs_id(ecs_i32_t) },
                }
            });
            /* Set as singleton (component on itself) */
            PerformanceStats empty = {0};
            ecs_set_id(engine->world, g_perf_comp, g_perf_comp, sizeof(PerformanceStats), &empty);
        }
    }
    return (PerformanceStats *)ecs_get_mut_id(engine->world, g_perf_comp, g_perf_comp);
}

static double perf_us(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return ts.tv_sec * 1e6 + ts.tv_nsec / 1e3;
}

static void perf_add_us(Engine *engine, int field_offset, double elapsed_us) {
    PerformanceStats *ps = perf_get(engine);
    if (!ps) return;
    int32_t *field = (int32_t *)((char *)ps + field_offset);
    *field += (int32_t)elapsed_us;
}

#define PERF_OFFSET(f) ((int)(offsetof(PerformanceStats, f)))

/* Call at start of each turn's movement to reset per-turn counters */
static void perf_begin_turn(Engine *engine) {
    PerformanceStats *ps = perf_get(engine);
    if (!ps) return;
    ps->df_full_rebuilds = 0;
    ps->df_incremental = 0;
    ps->movement_iterations = 0;
}

static void perf_record_df_full(Engine *engine) {
    PerformanceStats *ps = perf_get(engine);
    if (!ps) return;
    ps->df_full_rebuilds++;
    ps->df_full_total++;
    ecs_modified_id(engine->world, g_perf_comp, g_perf_comp);
}

static void perf_record_df_incremental(Engine *engine) {
    PerformanceStats *ps = perf_get(engine);
    if (!ps) return;
    ps->df_incremental++;
    ps->df_incremental_total++;
    ecs_modified_id(engine->world, g_perf_comp, g_perf_comp);
}

static void perf_record_iteration(Engine *engine) {
    PerformanceStats *ps = perf_get(engine);
    if (!ps) return;
    ps->movement_iterations++;
    ps->movement_iter_total++;
    ecs_modified_id(engine->world, g_perf_comp, g_perf_comp);
}

/* ŌöĆŌöĆ Spatial grid for O(1) occupancy lookups ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

#define GRID_MAX_X 1152
#define GRID_MAX_Y 768
static int32_t g_occ_grid[GRID_MAX_X * GRID_MAX_Y]; /* unit index+1, 0=empty */

static void grid_clear(int mx, int my) {
    (void)mx; (void)my;
    memset(g_occ_grid, 0, sizeof(g_occ_grid));
}

static void grid_set(int x, int y, int unit_idx) {
    if (x >= 1 && x < GRID_MAX_X && y >= 1 && y < GRID_MAX_Y)
        g_occ_grid[y * GRID_MAX_X + x] = unit_idx + 1;
}

static bool grid_occupied(int x, int y) {
    if (x < 1 || x >= GRID_MAX_X || y < 1 || y >= GRID_MAX_Y) return true;
    return g_occ_grid[y * GRID_MAX_X + x] != 0;
}

static int grid_unit_at(int x, int y) {
    if (x < 1 || x >= GRID_MAX_X || y < 1 || y >= GRID_MAX_Y) return -1;
    return g_occ_grid[y * GRID_MAX_X + x] - 1;
}

/* ŌöĆŌöĆ start_of_turn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_start_of_turn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t td = ecs_lookup(engine->world, "TookDamage");
    ecs_entity_t wpn_comp = ecs_lookup(engine->world, "Weapon");

    /* Clear TookDamage markers */
    if (td) {
        ecs_entity_t to_clear[65536];
        int clear_count = 0;

        ecs_query_t *q = ecs_query(engine->world, {
            .terms = {{ .id = td }, { .id = engine->user_entity_tag }},
            .cache_kind = EcsQueryCacheNone
        });
        ecs_iter_t it = ecs_query_iter(engine->world, q);
        while (ecs_query_next(&it)) {
            for (int i = 0; i < it.count && clear_count < 65536; i++) {
                to_clear[clear_count++] = it.entities[i];
            }
        }
        ecs_query_fini(q);

        for (int i = 0; i < clear_count; i++) {
            ecs_remove_id(engine->world, to_clear[i], td);
        }
    }

    /* Clear Weapon.attacked field (set to 0) */
    if (wpn_comp) {
        ecs_query_t *q = ecs_query(engine->world, {
            .terms = {{ .id = wpn_comp }, { .id = engine->user_entity_tag }},
            .cache_kind = EcsQueryCacheNone
        });
        ecs_iter_t it = ecs_query_iter(engine->world, q);
        while (ecs_query_next(&it)) {
            for (int i = 0; i < it.count; i++) {
                void *wpn = ecs_get_mut_id(engine->world, it.entities[i], wpn_comp);
                if (wpn) {
                    ecs_entity_t *attacked = (ecs_entity_t *)((char *)wpn + sizeof(int32_t));
                    *attacked = 0;
                    ecs_modified_id(engine->world, it.entities[i], wpn_comp);
                }
            }
        }
        ecs_query_fini(q);
    }
}

/* ŌöĆŌöĆ game_start ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_app_start(Engine *engine) {
    /* Find Map entity for bounds */
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    if (!map) return;

    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    if (!ms_comp) return;
    const void *ms_data = ecs_get_id(engine->world, map, ms_comp);
    if (!ms_data) return;
    int mx = *(const int32_t *)ms_data;
    int my = *((const int32_t *)ms_data + 1);
    if (mx == 0 && my == 0) return;

    { static int seed_offset = 0; srand((unsigned)time(NULL) + seed_offset++); }

    ecs_entity_t sr_comp = ecs_lookup(engine->world, "SpawnRequest");
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    if (!sr_comp || !loc_comp) return;

    /* Read unit counts from app.yaml (use --overrides for balance testing) */
    StoredApp *app = engine_app_get(engine, engine->sandbox_name);
    if (!app || app->archers <= 0 || app->knights <= 0) {
        fprintf(stderr, "Error: archers/knights not set in app.yaml\n");
        return;
    }
    int num_archers = app->archers;
    int num_knights = app->knights;

    int total = num_archers + num_knights;
    int cells = mx * my;
    if (total > cells) {
        fprintf(stderr, "Error: %d units > %d cells, can't place without overlap\n", total, cells);
        return;
    }

    fprintf(stderr, "Spawning %dA vs %dK\n", num_archers, num_knights);

    /* Placement grid to prevent overlaps */
    grid_clear(mx, my);

    /* knights */
    for (int k = 0; k < num_knights; k++) {
        char name[32]; snprintf(name, sizeof(name), "sk%d", k + 1);
        ecs_entity_t e = engine_entity_create(engine, name);
        if (!e) continue;
        ecs_add_id(engine->world, e, sr_comp);
        void *sr = ecs_get_mut_id(engine->world, e, sr_comp);
        if (sr) { *(char **)sr = ecs_os_strdup("Knight"); ecs_modified_id(engine->world, e, sr_comp); }

        int px, py;
        do { px = 1 + rand() % mx; py = 1 + rand() % my; } while (grid_occupied(px, py));
        grid_set(px, py, 1);

        ecs_add_id(engine->world, e, loc_comp);
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, e, loc_comp);
        if (loc) { loc[0] = px; loc[1] = py; ecs_modified_id(engine->world, e, loc_comp); }
    }

    /* archers */
    for (int a = 0; a < num_archers; a++) {
        char name[32]; snprintf(name, sizeof(name), "sa%d", a + 1);
        ecs_entity_t e = engine_entity_create(engine, name);
        if (!e) continue;
        ecs_add_id(engine->world, e, sr_comp);
        void *sr = ecs_get_mut_id(engine->world, e, sr_comp);
        if (sr) { *(char **)sr = ecs_os_strdup("Archer"); ecs_modified_id(engine->world, e, sr_comp); }

        int px, py;
        do { px = 1 + rand() % mx; py = 1 + rand() % my; } while (grid_occupied(px, py));
        grid_set(px, py, 1);

        ecs_add_id(engine->world, e, loc_comp);
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, e, loc_comp);
        if (loc) { loc[0] = px; loc[1] = py; ecs_modified_id(engine->world, e, loc_comp); }
    }

    engine_system_disable(engine, "app_start");
}

/* ŌöĆŌöĆ BFS distance fields ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * dist_to_red[y][x] = manhattan distance to nearest red (archer) unit
 * dist_to_blue[y][x] = manhattan distance to nearest blue (knight) unit
 * Built via BFS flood-fill from all enemy positions: O(cells) not O(units┬▓).
 * A cell with distance 0 contains an enemy ŌĆö the movement target and attack condition.
 *
 * Owner arrays track which unit index "owns" each cell (nearest source).
 * Used by incremental_update to walk Voronoi regions efficiently.
 */

static int16_t g_dist_to_red[GRID_MAX_Y * GRID_MAX_X];
static int16_t g_dist_to_blue[GRID_MAX_Y * GRID_MAX_X];
static int32_t g_owner_red[GRID_MAX_Y * GRID_MAX_X];
static int32_t g_owner_blue[GRID_MAX_Y * GRID_MAX_X];

/* BFS queues ŌĆö max cells = GRID_MAX_X * GRID_MAX_Y.
 * Two queues so red and blue BFS can run on separate threads. */
#define BFS_MAX (GRID_MAX_X * GRID_MAX_Y)
static int32_t g_bfs_queue[BFS_MAX];

/* Bitset for incremental update phases */
#define BITSET_SIZE ((GRID_MAX_X * GRID_MAX_Y + 63) / 64)
static uint64_t g_raised[BITSET_SIZE];
static uint64_t g_in_queue[BITSET_SIZE];

static inline void bit_set(uint64_t *bs, int idx) { bs[idx/64] |= (1ULL << (idx%64)); }
static inline void bit_clear(uint64_t *bs, int idx) { (void)bs; (void)idx; bs[idx/64] &= ~(1ULL << (idx%64)); }
static inline bool bit_test(uint64_t *bs, int idx) { return (bs[idx/64] >> (idx%64)) & 1; }

typedef struct { int unit_idx; int old_x, old_y, new_x, new_y; } MovedSite;

/* Scratch buffer to collect raised cell indices during phase 1 */
static int32_t g_raised_cells[BFS_MAX];

static void build_distance_field_q(int16_t *dist, int32_t *owner, UnitData *units,
                                   int count, int faction, int mx, int my,
                                   int32_t *queue) {
    memset(dist, 0xFF, (size_t)(my + 1) * GRID_MAX_X * sizeof(int16_t));
    memset(owner, 0xFF, (size_t)(my + 1) * GRID_MAX_X * sizeof(int32_t));

    int head = 0, tail = 0;
    for (int i = 0; i < count; i++) {
        if (units[i].faction != faction) continue;
        int x = units[i].x, y = units[i].y;
        if (x >= 1 && x <= mx && y >= 1 && y <= my && dist[y * GRID_MAX_X + x] < 0) {
            dist[y * GRID_MAX_X + x] = 0;
            owner[y * GRID_MAX_X + x] = i;
            queue[tail++] = y * (mx + 1) + x;
        }
    }

    static const int dx[] = {0, 0, -1, 1};
    static const int dy[] = {-1, 1, 0, 0};
    while (head < tail) {
        int pos = queue[head++];
        int cy = pos / (mx + 1), cx = pos % (mx + 1);
        int16_t d = dist[cy * GRID_MAX_X + cx];
        int16_t o = owner[cy * GRID_MAX_X + cx];
        for (int dir = 0; dir < 4; dir++) {
            int nx = cx + dx[dir], ny = cy + dy[dir];
            if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
            int ni = ny * GRID_MAX_X + nx;
            if (dist[ni] >= 0) continue;
            dist[ni] = d + 1;
            owner[ni] = o;
            queue[tail++] = ny * (mx + 1) + nx;
        }
    }
}

/* Convenience wrapper using the default queue */
static void build_distance_field(int16_t *dist, int32_t *owner, UnitData *units,
                                 int count, int faction, int mx, int my) {
    build_distance_field_q(dist, owner, units, count, faction, mx, my, g_bfs_queue);
}

/* ŌöĆŌöĆ Incremental distance field update ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * When a small number of sites (units) move, we can update the distance
 * field incrementally instead of doing a full BFS rebuild:
 *
 * Phase 1: For each moved site, walk its Voronoi region (cells owned by it)
 *   from the old position. Recompute distances using manhattan distance to the
 *   new position. Mark cells where distance increased as "raised".
 *
 * Phase 2: BFS repair from (a) new positions of moved sites and
 *   (b) non-raised neighbors of raised cells. This corrects any cells
 *   that should now be owned by a different (closer) site.
 */
static void incremental_update(int16_t *dist, int32_t *own,
                               MovedSite *moved, int nmoved,
                               UnitData *units, int mx, int my) {
    (void)units;
    static const int dx[] = {0, 0, -1, 1};
    static const int dy[] = {-1, 1, 0, 0};
    int W = GRID_MAX_X;

    /* Clear bitsets (only the portion we use) */
    size_t bitset_bytes = ((size_t)(my + 1) * W + 63) / 64 * sizeof(uint64_t);
    if (bitset_bytes > sizeof(g_raised)) bitset_bytes = sizeof(g_raised);
    memset(g_raised, 0, bitset_bytes);
    memset(g_in_queue, 0, bitset_bytes);

    int n_raised = 0;

    /* PHASE 1: Walk each moved site's Voronoi region, update distances.
     *
     * Two-pass per site:
     *   Pass A: BFS to collect all cells in this site's Voronoi region.
     *           Keep visited markers in place to prevent revisiting.
     *   Pass B: Iterate collected cells, compute new manhattan distance
     *           to the site's new position, mark raised cells, restore owner. */
    for (int m = 0; m < nmoved; m++) {
        int sid = moved[m].unit_idx;
        int ox = moved[m].old_x, oy = moved[m].old_y;
        int nx = moved[m].new_x, ny = moved[m].new_y;

        int32_t visited_mark = -2 - sid;

        /* Pass A: BFS to collect Voronoi cells */
        int head = 0, tail = 0;
        int oi = oy * W + ox;

        if (own[oi] == (int32_t)sid) {
            own[oi] = visited_mark;
            g_bfs_queue[tail++] = oi;
        }

        /* The BFS only enqueues cells once (via visited_mark), so tail <= total cells */
        while (head < tail) {
            int ci = g_bfs_queue[head++];
            int cy = ci / W, cx = ci % W;

            for (int dir = 0; dir < 4; dir++) {
                int ex = cx + dx[dir], ey = cy + dy[dir];
                if (ex < 1 || ex > mx || ey < 1 || ey > my) continue;
                int ei = ey * W + ex;
                if (own[ei] == (int32_t)sid) {
                    own[ei] = visited_mark;
                    g_bfs_queue[tail++] = ei;
                }
            }
        }

        /* Pass B: Update distances and restore owners for collected cells.
         * g_bfs_queue[0..tail-1] contains all cells in this site's Voronoi region. */
        for (int k = 0; k < tail; k++) {
            int ci = g_bfs_queue[k];
            int cy = ci / W, cx = ci % W;

            int new_d = abs(cx - nx) + abs(cy - ny);
            if (new_d > dist[ci]) {
                bit_set(g_raised, ci);
                g_raised_cells[n_raised++] = ci;
            }
            dist[ci] = (int16_t)new_d;
            own[ci] = sid; /* restore owner */
        }
    }

    /* PHASE 2: Repair ŌĆö BFS from boundary of raised region + new site positions */
    int head = 0, tail = 0;

    /* Seed (a): new positions of moved sites */
    for (int m = 0; m < nmoved; m++) {
        int ni = moved[m].new_y * W + moved[m].new_x;
        dist[ni] = 0;
        own[ni] = moved[m].unit_idx;
        if (!bit_test(g_in_queue, ni)) {
            g_bfs_queue[tail++] = ni;
            bit_set(g_in_queue, ni);
        }
    }

    /* Seed (b): non-raised neighbors of raised cells (using collected list) */
    for (int r = 0; r < n_raised; r++) {
        int ci = g_raised_cells[r];
        int cy = ci / W, cx = ci % W;
        for (int dir = 0; dir < 4; dir++) {
            int ex = cx + dx[dir], ey = cy + dy[dir];
            if (ex < 1 || ex > mx || ey < 1 || ey > my) continue;
            int ei = ey * W + ex;
            if (!bit_test(g_raised, ei) && !bit_test(g_in_queue, ei)) {
                g_bfs_queue[tail++] = ei;
                bit_set(g_in_queue, ei);
            }
        }
    }

    /* BFS repair */
    while (head < tail) {
        int ci = g_bfs_queue[head++];
        int cy = ci / W, cx = ci % W;
        for (int dir = 0; dir < 4; dir++) {
            int ex = cx + dx[dir], ey = cy + dy[dir];
            if (ex < 1 || ex > mx || ey < 1 || ey > my) continue;
            int ei = ey * W + ex;
            if (dist[ci] + 1 < dist[ei]) {
                dist[ei] = dist[ci] + 1;
                own[ei] = own[ci];
                if (!bit_test(g_in_queue, ei)) {
                    g_bfs_queue[tail++] = ei;
                    bit_set(g_in_queue, ei);
                }
            }
        }
    }
}

static int dist_field_get(int16_t *dist, int x, int y) {
    if (x < 1 || x >= GRID_MAX_X || y < 1 || y >= GRID_MAX_Y) return 9999;
    int16_t v = dist[y * GRID_MAX_X + x];
    return v >= 0 ? v : 9999;
}

/* Count enemies within manhattan range of (cx,cy) using the occupancy grid */
static int count_enemies_in_range(int cx, int cy, int range, int my_faction,
                                  UnitData *units) {
    int count = 0;
    for (int dy = -range; dy <= range; dy++) {
        int ax = range - abs(dy);
        for (int dx = -ax; dx <= ax; dx++) {
            int ui = grid_unit_at(cx + dx, cy + dy);
            if (ui >= 0 && units[ui].faction != my_faction && units[ui].health > 0)
                count++;
        }
    }
    return count;
}

/* Score a cell for movement using distance fields + grid */
static int score_cell(int nx, int ny, int move_type, int range,
                      int16_t *enemy_dist, int faction, UnitData *units) {
    int d = dist_field_get(enemy_dist, nx, ny);
    if (move_type == 1) {
        /* Knight: minimize distance to nearest enemy */
        return -d;
    } else {
        /* Archer: prefer being at exactly range distance */
        if (d <= range)
            return -(range - d + 1);  /* dist 1=-3, 2=-2, 3=-1 */
        else
            return -d;                /* dist 4=-4, 5=-5, ... */
    }
}

/* Second BFS queue for parallel distance field builds */
static int32_t g_bfs_queue2[BFS_MAX];

#ifndef _WIN32
/* Run fn2(arg2) on a thread while fn1(arg1) runs on main, join. */
typedef struct { void (*fn)(void *); void *arg; } ParPair;
static void *par_pair_worker(void *a) { ParPair *p = a; p->fn(p->arg); return NULL; }

typedef struct {
    int16_t *dist; int32_t *owner; UnitData *units;
    int count, faction, mx, my; int32_t *queue;
} BfsArgs;
static void bfs_wrapper(void *a) {
    BfsArgs *b = a;
    build_distance_field_q(b->dist, b->owner, b->units, b->count, b->faction, b->mx, b->my, b->queue);
}
#endif

/* Build both red and blue distance fields ŌĆö parallel when threads > 1 */
static void build_distance_fields_pair(Engine *engine, UnitData *units,
                                        int count, int mx, int my) {
#ifndef _WIN32
    if (engine->max_threads > 1) {
        BfsArgs ra = { g_dist_to_red, g_owner_red, units, count, 0, mx, my, g_bfs_queue };
        BfsArgs ba = { g_dist_to_blue, g_owner_blue, units, count, 1, mx, my, g_bfs_queue2 };
        ParPair p = { bfs_wrapper, &ba };
        pthread_t t;
        pthread_create(&t, NULL, par_pair_worker, &p);
        bfs_wrapper(&ra);
        pthread_join(t, NULL);
    } else
#endif
    {
        (void)engine;
        build_distance_field(g_dist_to_red, g_owner_red, units, count, 0, mx, my);
        build_distance_field(g_dist_to_blue, g_owner_blue, units, count, 1, mx, my);
    }
}

/* ŌöĆŌöĆ build_distance_fields (Reset phase) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

/* Pre-build distance fields during Reset phase so they're ready for Move.
 * Runs in parallel with despawn and start_of_turn. Ignores dead units. */
static int g_df_mx = 0, g_df_my = 0;

static void avk_build_distance_fields(Engine *engine) {
    if (is_simulation_paused(engine)) return;

    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    g_df_mx = 10; g_df_my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { g_df_mx = *(const int32_t *)ms; g_df_my = *((const int32_t *)ms + 1); }
    }

    static UnitData df_units[65536];
    int count = collect_units(engine, df_units, 65536);
    if (count == 0) return;

    perf_begin_turn(engine);
    build_distance_fields_pair(engine, df_units, count, g_df_mx, g_df_my);
    perf_record_df_full(engine); /* red */
    perf_record_df_full(engine); /* blue */
}

/* ŌöĆŌöĆ Shared unit snapshot for Move ŌåÆ Act phase data passing ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
static UnitData g_act_units[65536];
static int g_act_count = 0;
static bool g_act_prefilled = false;

/* ŌöĆŌöĆ movement: per-unit move decision (thread-safe) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

/* Forward-declared: written by decide_moves_range, consumed by Phase 2 */
typedef struct { int bx, by; bool found; } MoveDecision;
static MoveDecision g_move_decisions[65536];

/* Decide moves for units in [start, end). Thread-safe: reads shared immutable
 * data (units, distance fields, occupancy grid), writes only to
 * g_move_decisions[i] for i in [start, end). */
static void decide_moves_range(UnitData *units, int count, int mx, int my,
                                const int dirs[][2], int start, int end) {
    for (int i = start; i < end; i++) {
        g_move_decisions[i].found = false;
        g_move_decisions[i].bx = units[i].x;
        g_move_decisions[i].by = units[i].y;

        UnitData *ent = &units[i];
        if (ent->energy <= 0) continue;

        int16_t *enemy_dist = (ent->faction == 0) ? g_dist_to_blue : g_dist_to_red;

        int cand_x[5], cand_y[5], cand_score[5], ncand = 0;
        int best_score = -999999;

        for (int d = 0; d < 5; d++) {
            int nx = ent->x + dirs[d][0];
            int ny = ent->y + dirs[d][1];
            if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
            if (d != 4 && grid_occupied(nx, ny)) continue;

            int score = score_cell(nx, ny, ent->move_type, ent->range,
                                   enemy_dist, ent->faction, units);
            cand_x[ncand] = nx;
            cand_y[ncand] = ny;
            cand_score[ncand] = score;
            ncand++;
            if (score > best_score) best_score = score;
        }

        /* Tiebreaker 1 (knights): prefer backed by ally */
        int best_backed = 0;
        if (ent->move_type == 1) {
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (ally >= 0 && ally != i && units[ally].faction == ent->faction) {
                    best_backed = 1; break;
                }
            }
        }

        /* Tiebreaker 2: farthest from nearest wall */
        int best_wdist = -1;
        for (int c = 0; c < ncand; c++) {
            if (cand_score[c] != best_score) continue;
            if (ent->move_type == 1 && best_backed) {
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                    continue;
            }
            int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
            int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
            int wd = wx < wy ? wx : wy;
            if (wd > best_wdist) best_wdist = wd;
        }

        /* Tiebreaker 3: prefer reducing the larger axis to target enemy */
        int32_t *enemy_own = (ent->faction == 0) ? g_owner_blue : g_owner_red;
        int tgt_idx = enemy_own[ent->y * GRID_MAX_X + ent->x];
        int best_axis = 0;
        if (tgt_idx >= 0 && tgt_idx < count) {
            int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
            int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
            if (adx != ady) {
                for (int c = 0; c < ncand; c++) {
                    if (cand_score[c] != best_score) continue;
                    if (ent->move_type == 1 && best_backed) {
                        int bk_x = 2 * ent->x - cand_x[c];
                        int bk_y = 2 * ent->y - cand_y[c];
                        int ally = grid_unit_at(bk_x, bk_y);
                        if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                            continue;
                    }
                    int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                    int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                    int wd = wx < wy ? wx : wy;
                    if (wd != best_wdist) continue;
                    int pref = (adx >= ady)
                        ? (abs(cand_x[c] - tx) < adx)
                        : (abs(cand_y[c] - ty) < ady);
                    if (pref > best_axis) best_axis = pref;
                }
            }
        }

        /* Pick first matching candidate */
        int bx = ent->x, by = ent->y;
        bool found = false;
        for (int c = 0; c < ncand; c++) {
            if (cand_score[c] != best_score) continue;
            if (ent->move_type == 1 && best_backed) {
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                    continue;
            }
            int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
            int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
            int wd = wx < wy ? wx : wy;
            if (wd != best_wdist) continue;
            if (best_axis && tgt_idx >= 0 && tgt_idx < count) {
                int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                int pref = (adx >= ady)
                    ? (abs(cand_x[c] - tx) < adx)
                    : (abs(cand_y[c] - ty) < ady);
                if (!pref) continue;
            }
            bx = cand_x[c]; by = cand_y[c];
            found = true;
            break;
        }

        g_move_decisions[i].bx = bx;
        g_move_decisions[i].by = by;
        g_move_decisions[i].found = found;
    }
}

#ifndef _WIN32
typedef struct {
    UnitData *units; int count, mx, my; const int (*dirs)[2]; int start, end;
} MoveWorkerArgs;
static void *decide_moves_worker(void *a) {
    MoveWorkerArgs *m = a;
    decide_moves_range(m->units, m->count, m->mx, m->my, m->dirs, m->start, m->end);
    return NULL;
}
#endif

/* ŌöĆŌöĆ movement ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

/* Original movement algorithm ŌĆö verbatim from commit 08d6454.
 * Iterative convergence: BFS ŌåÆ decide ŌåÆ apply ŌåÆ rebuild distance fields ŌåÆ repeat.
 * The only addition is the combat snapshot sharing at the end for pipeline mode. */
static void avk_movement(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    double _t0, _t1;
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    _t0 = perf_us();
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_collect), _t1 - _t0);

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Set energy */
    for (int i = 0; i < count; i++) units[i].energy = units[i].speed;

    /* Build spatial grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};

    /* Debug logging */
    static FILE *dbg = NULL;
    static int dbg_checked = 0;
    if (!dbg_checked) {
        dbg_checked = 1;
        const char *dbg_path = getenv("FLECS_DEBUG_MOVEMENT");
        if (dbg_path) {
            dbg = fopen(dbg_path, "w");
            if (dbg) { fprintf(dbg, "debug enabled\n"); fflush(dbg); }
        }
    }
    static int dbg_turn = 0;
    dbg_turn++;

    /* Pending moves buffer ŌĆö applied in batch after each pass */
    static int pend_idx[65536], pend_x[65536], pend_y[65536];

    /* MovedSite buffers for incremental update */
    static MovedSite moved_red[65536], moved_blue[65536];

    int incr_threshold = count / 8;
    if (incr_threshold < 32) incr_threshold = 32;

    /* Build initial distance fields with owner tracking (full BFS) */
    _t0 = perf_us();
    build_distance_field(g_dist_to_red, g_owner_red, units, count, 0, mx, my);
    build_distance_field(g_dist_to_blue, g_owner_blue, units, count, 1, mx, my);
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_df_rebuild), _t1 - _t0);

    bool any_moved = true;
    while (any_moved) {
        any_moved = false;
        perf_record_iteration(engine);
        _t0 = perf_us();

        /* Phase 1: decide moves for all units */
        int npend = 0;
        for (int i = 0; i < count; i++) {
            UnitData *ent = &units[i];
            if (ent->energy <= 0) continue;

            int16_t *enemy_dist = (ent->faction == 0) ? g_dist_to_blue : g_dist_to_red;

            int cand_x[5], cand_y[5], cand_score[5], ncand = 0;
            int best_score = -999999;

            for (int d = 0; d < 5; d++) {
                int nx = ent->x + dirs[d][0];
                int ny = ent->y + dirs[d][1];
                if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
                if (d != 4 && grid_occupied(nx, ny)) continue;
                int score = score_cell(nx, ny, ent->move_type, ent->range,
                                       enemy_dist, ent->faction, units);
                cand_x[ncand] = nx;
                cand_y[ncand] = ny;
                cand_score[ncand] = score;
                ncand++;
                if (score > best_score) best_score = score;
            }

            /* Tiebreaker 1 (knights): prefer backed by ally */
            int best_backed = 0;
            if (ent->move_type == 1) {
                for (int c = 0; c < ncand; c++) {
                    if (cand_score[c] != best_score) continue;
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (ally >= 0 && ally != i && units[ally].faction == ent->faction) {
                        best_backed = 1; break;
                    }
                }
            }

            /* Tiebreaker 2: farthest from nearest wall */
            int best_wdist = -1;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                int wd = wx < wy ? wx : wy;
                if (wd > best_wdist) best_wdist = wd;
            }

            /* Tiebreaker 3: prefer reducing the larger axis to target enemy */
            int32_t *enemy_own = (ent->faction == 0) ? g_owner_blue : g_owner_red;
            int tgt_idx = enemy_own[ent->y * GRID_MAX_X + ent->x];
            int best_axis = 0;
            if (tgt_idx >= 0 && tgt_idx < count) {
                int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                if (adx != ady) {
                    for (int c = 0; c < ncand; c++) {
                        if (cand_score[c] != best_score) continue;
                        if (ent->move_type == 1 && best_backed) {
                            int bk_x = 2 * ent->x - cand_x[c];
                            int bk_y = 2 * ent->y - cand_y[c];
                            int ally = grid_unit_at(bk_x, bk_y);
                            if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                                continue;
                        }
                        int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                        int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                        int wd = wx < wy ? wx : wy;
                        if (wd != best_wdist) continue;
                        int pref = (adx >= ady)
                            ? (abs(cand_x[c] - tx) < adx)
                            : (abs(cand_y[c] - ty) < ady);
                        if (pref > best_axis) best_axis = pref;
                    }
                }
            }

            /* Pick first matching candidate */
            int bx = ent->x, by = ent->y;
            bool found = false;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                int wd = wx < wy ? wx : wy;
                if (wd != best_wdist) continue;
                if (best_axis && tgt_idx >= 0 && tgt_idx < count) {
                    int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                    int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                    int pref = (adx >= ady)
                        ? (abs(cand_x[c] - tx) < adx)
                        : (abs(cand_y[c] - ty) < ady);
                    if (!pref) continue;
                }
                bx = cand_x[c]; by = cand_y[c];
                found = true;
                break;
            }

            if (dbg) {
                const char *type = ent->faction == 0 ? "Archer" : "Knight";
                fprintf(dbg, "turn:%d %s at(%d,%d) best_score:%d candidates:",
                        dbg_turn, type, ent->x, ent->y, best_score);
                for (int c = 0; c < ncand; c++) {
                    int wx2 = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                    int wy2 = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                    int wd2 = wx2 < wy2 ? wx2 : wy2;
                    fprintf(dbg, " (%d,%d)s=%d,w=%d%s",
                            cand_x[c], cand_y[c], cand_score[c], wd2,
                            (cand_score[c] == best_score) ? "*" : "");
                }
                fprintf(dbg, " -> (%d,%d)\n", bx, by);
                fflush(dbg);
            }

            if (found && (bx != ent->x || by != ent->y)) {
                pend_idx[npend] = i;
                pend_x[npend] = bx;
                pend_y[npend] = by;
                npend++;
            } else if (!found) {
                ent->energy = 0;
            }
        }

        _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_decide), _t1 - _t0);
        _t0 = _t1;

        /* Phase 2: apply moves */
        int n_moved_red = 0, n_moved_blue = 0;
        for (int p = 0; p < npend; p++) {
            int i = pend_idx[p];
            UnitData *ent = &units[i];
            if (grid_occupied(pend_x[p], pend_y[p])) continue;

            int old_x = ent->x, old_y = ent->y;
            g_occ_grid[ent->y * GRID_MAX_X + ent->x] = 0;
            ent->x = pend_x[p]; ent->y = pend_y[p];
            grid_set(ent->x, ent->y, i);
            ent->energy--;

            int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, ent->eid, loc_comp);
            if (loc) { loc[0] = ent->x; loc[1] = ent->y; ecs_modified_id(engine->world, ent->eid, loc_comp); }
            any_moved = true;

            if (ent->faction == 0) {
                moved_red[n_moved_red].unit_idx = i;
                moved_red[n_moved_red].old_x = old_x;
                moved_red[n_moved_red].old_y = old_y;
                moved_red[n_moved_red].new_x = ent->x;
                moved_red[n_moved_red].new_y = ent->y;
                n_moved_red++;
            } else {
                moved_blue[n_moved_blue].unit_idx = i;
                moved_blue[n_moved_blue].old_x = old_x;
                moved_blue[n_moved_blue].old_y = old_y;
                moved_blue[n_moved_blue].new_x = ent->x;
                moved_blue[n_moved_blue].new_y = ent->y;
                n_moved_blue++;
            }
        }

        _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_apply), _t1 - _t0);
        _t0 = _t1;

        /* Phase 3: Update distance fields ŌĆö incremental if few moved, else full rebuild */
        if (any_moved) {
            if (n_moved_red > 0) {
                if (n_moved_red > incr_threshold) {
                    build_distance_field(g_dist_to_red, g_owner_red, units, count, 0, mx, my);
                    perf_record_df_full(engine);
                } else {
                    incremental_update(g_dist_to_red, g_owner_red, moved_red, n_moved_red, units, mx, my);
                    perf_record_df_incremental(engine);
                }
            }
            if (n_moved_blue > 0) {
                if (n_moved_blue > incr_threshold) {
                    build_distance_field(g_dist_to_blue, g_owner_blue, units, count, 1, mx, my);
                    perf_record_df_full(engine);
                } else {
                    incremental_update(g_dist_to_blue, g_owner_blue, moved_blue, n_moved_blue, units, mx, my);
                    perf_record_df_incremental(engine);
                }
            }
        }
        _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_df_rebuild), _t1 - _t0);
    }

    /* Pipeline integration: share unit snapshot with combat phase */
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData) * count);
        g_act_count = count;
        g_act_prefilled = true;
    }
}

/* ŌöĆŌöĆ movement_intent: Intent Graph with Vacancy Propagation ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * Algorithm: Build BFS once ŌåÆ declare intents ŌåÆ build functional graph ŌåÆ
 * resolve vacancy chains ŌåÆ blocked units reconsider ŌåÆ resolve cycles ŌåÆ apply.
 *
 * Each unit has exactly one outgoing edge (target cell). The graph is
 * functional: every connected component has at most one cycle.
 *
 * Resolution order:
 * 1. Stationary units lock their cells
 * 2. Free movers (targeting empty cells) process by priority
 * 3. Vacancy propagates: when A moves out, anyone waiting on A's cell becomes free
 * 4. Blocked units (lost tiebreak) get one reconsideration
 * 5. Remaining WAITING units are in cycles ŌĆö rotate same-faction, block cross-faction len-2
 * 6. Apply all committed moves to ECS
 */

/* Unit status during intent resolution */
enum IntentStatus {
    INTENT_UNDECIDED = 0,
    INTENT_STATIONARY,  /* chose to stay */
    INTENT_FREE,        /* targeting empty cell */
    INTENT_WAITING,     /* targeting occupied cell, depends on occupant */
    INTENT_COMMITTED,   /* move confirmed */
    INTENT_BLOCKED      /* lost tiebreak, staying put */
};

static void avk_movement_intent(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    double _t0, _t1;
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    _t0 = perf_us();
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_collect), _t1 - _t0);

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Build spatial grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Phase 1: Build distance fields ONCE */
    _t0 = perf_us();
    if (!engine->pipeline_active || g_df_mx == 0) {
        build_distance_fields_pair(engine, units, count, mx, my);
    }
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_df_rebuild), _t1 - _t0);

    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};

    /* Phase 2: Declare intent ŌĆö each unit picks best cell from snapshot */
    _t0 = perf_us();
    decide_moves_range(units, count, mx, my, dirs, 0, count);
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_decide), _t1 - _t0);

    /* Per-unit intent: target cell coordinates and status */
    static int intent_x[65536], intent_y[65536];
    static enum IntentStatus status[65536];
    /* Priority for tiebreaking: archers > knights, closer-to-enemy > farther */
    static int priority[65536];

    /* Reverse map: for each grid cell, first claimant unit index (-1 = none) */
    /* Use a grid-sized array for O(1) lookup */
    static int32_t cell_claimant[GRID_MAX_Y * GRID_MAX_X]; /* unit index, -1 = none */
    memset(cell_claimant, -1, (size_t)(my + 1) * GRID_MAX_X * sizeof(int32_t));

    /* Worklist for vacancy propagation */
    static int worklist[65536];
    int wl_head = 0, wl_tail = 0;

    /* Reverse map: for each cell, linked list of WAITING units targeting it.
     * cell_waiters[cell_index] = first waiter unit index, -1 = none.
     * waiter_next[unit_index] = next waiter for same cell, -1 = end. */
    static int32_t cell_waiters[GRID_MAX_Y * GRID_MAX_X];
    static int32_t waiter_next[65536];
    memset(cell_waiters, -1, (size_t)(my + 1) * GRID_MAX_X * sizeof(int32_t));

    /* Phase 2b: Classify each unit and build reverse map */
    for (int i = 0; i < count; i++) {
        int tx, ty;
        if (g_move_decisions[i].found) {
            tx = g_move_decisions[i].bx;
            ty = g_move_decisions[i].by;
        } else {
            tx = units[i].x;
            ty = units[i].y;
        }
        intent_x[i] = tx;
        intent_y[i] = ty;

        /* Compute priority: archers (faction 0) get a large boost.
         * Within faction, urgency = how much the unit needs to move.
         * Knights: closer to enemy = higher priority (front line first).
         * Archers: further from optimal range = higher priority (must reposition). */
        int16_t *enemy_dist = (units[i].faction == 0) ? g_dist_to_blue : g_dist_to_red;
        int d = dist_field_get(enemy_dist, units[i].x, units[i].y);
        int urgency;
        if (units[i].move_type == 1) { /* knight: charge */
            urgency = 10000 - d; /* closer = higher urgency */
        } else { /* archer: kite */
            urgency = abs(d - units[i].range) + 10000; /* archers always above knights */
        }
        priority[i] = urgency * 100000 + units[i].entity_id;

        if (tx == units[i].x && ty == units[i].y) {
            /* Staying put */
            status[i] = INTENT_STATIONARY;
            /* Lock this cell ŌĆö nobody can claim it */
            cell_claimant[ty * GRID_MAX_X + tx] =i;
        } else if (!grid_occupied(tx, ty)) {
            /* Target cell is empty in the snapshot */
            status[i] = INTENT_FREE;
        } else {
            /* Target cell is occupied ŌĆö we depend on the occupant leaving */
            status[i] = INTENT_WAITING;
            /* Add to waiter list for target cell */
            int wci = ty * GRID_MAX_X + tx;
            waiter_next[i] = cell_waiters[wci];
            cell_waiters[wci] =i;
        }
    }

    _t0 = perf_us();
    /* Phase 3a: Resolve collisions for FREE units and seed the worklist.
     * Process FREE units: check if anyone else wants the same cell.
     * Higher priority wins. */
    for (int i = 0; i < count; i++) {
        if (status[i] != INTENT_FREE) continue;
        int ci = intent_y[i] * GRID_MAX_X + intent_x[i];
        int existing = cell_claimant[ci];
        if (existing < 0) {
            /* Nobody else wants this cell ŌĆö claim it */
            cell_claimant[ci] =i;
            worklist[wl_tail++] = i;
        } else if (priority[i] > priority[existing]) {
            /* We outprioritize the existing claimant */
            /* Evict them */
            status[existing] = INTENT_BLOCKED;
            intent_x[existing] = units[existing].x;
            intent_y[existing] = units[existing].y;
            /* Lock evicted unit's cell */
            int eci = units[existing].y * GRID_MAX_X + units[existing].x;
            cell_claimant[eci] =existing;
            /* We take the cell */
            cell_claimant[ci] =i;
            worklist[wl_tail++] = i;
        } else {
            /* We lose ŌĆö stay put */
            status[i] = INTENT_BLOCKED;
            intent_x[i] = units[i].x;
            intent_y[i] = units[i].y;
            int oci = units[i].y * GRID_MAX_X + units[i].x;
            cell_claimant[oci] =i;
        }
    }

    /* Phase 3b: Process worklist ŌĆö vacancy propagation.
     * When a unit commits to move, its old cell becomes vacant.
     * WAITING units targeting that cell become FREE (via reverse map). */
    while (wl_head < wl_tail) {
        int i = worklist[wl_head++];
        status[i] = INTENT_COMMITTED;

        /* The cell this unit is LEAVING ŌĆö check waiter list */
        int old_ci = units[i].y * GRID_MAX_X + units[i].x;
        int best_waiter = -1, best_waiter_pri = -1;

        /* Find highest-priority waiter for this cell */
        for (int j = cell_waiters[old_ci]; j >= 0; j = waiter_next[j]) {
            if (status[j] != INTENT_WAITING) continue;
            if (priority[j] > best_waiter_pri) {
                best_waiter = j;
                best_waiter_pri = priority[j];
            }
        }

        if (best_waiter >= 0) {
            int j = best_waiter;
            int target_ci = intent_y[j] * GRID_MAX_X + intent_x[j];
            cell_claimant[target_ci] =j;
            status[j] = INTENT_FREE;
            worklist[wl_tail++] = j;

            /* Block other waiters for this cell */
            for (int k = cell_waiters[old_ci]; k >= 0; k = waiter_next[k]) {
                if (k == j || status[k] != INTENT_WAITING) continue;
                status[k] = INTENT_BLOCKED;
                intent_x[k] = units[k].x;
                intent_y[k] = units[k].y;
                cell_claimant[units[k].y * GRID_MAX_X + units[k].x] =k;
            }
        }
    }

    /* Phase 3c: Reconsideration ŌĆö blocked units try their second-best cell */
    for (int i = 0; i < count; i++) {
        if (status[i] != INTENT_BLOCKED) continue;

        /* Find second-best neighbor that is unoccupied and unclaimed */
        int16_t *enemy_dist = (units[i].faction == 0) ? g_dist_to_blue : g_dist_to_red;
        int best_score = -999999;
        int best_x = units[i].x, best_y = units[i].y;
        bool found = false;

        for (int d = 0; d < 4; d++) {
            int nx = units[i].x + dirs[d][0];
            int ny = units[i].y + dirs[d][1];
            if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
            int ci = ny * GRID_MAX_X + nx;
            /* Check both snapshot occupancy and claims */
            if (cell_claimant[ci] >= 0) continue;
            if (grid_occupied(nx, ny)) {
                /* Check if occupant is committed to leave */
                int occ = grid_unit_at(nx, ny);
                if (occ < 0 || status[occ] != INTENT_COMMITTED) continue;
                if (intent_x[occ] == nx && intent_y[occ] == ny) continue; /* staying */
            }

            int score = score_cell(nx, ny, units[i].move_type, units[i].range,
                                   enemy_dist, units[i].faction, units);
            if (score > best_score) {
                best_score = score;
                best_x = nx;
                best_y = ny;
                found = true;
            }
        }

        if (found && (best_x != units[i].x || best_y != units[i].y)) {
            intent_x[i] = best_x;
            intent_y[i] = best_y;
            int ci = best_y * GRID_MAX_X + best_x;
            cell_claimant[ci] =i;
            status[i] = INTENT_COMMITTED;
        }
    }

    /* Phase 3d: Resolve cycles ŌĆö remaining WAITING units.
     * In a functional graph, each component has exactly one cycle.
     * Same-faction cycles: rotate (everyone advances).
     * Cross-faction length-2: mutual block.
     * Others: rotate. */
    static bool visited[65536];
    memset(visited, 0, sizeof(bool) * count);

    for (int i = 0; i < count; i++) {
        if (status[i] != INTENT_WAITING || visited[i]) continue;

        /* Trace the chain to find the cycle */
        static int path[65536];
        int path_len = 0;
        int cur = i;

        while (cur >= 0 && !visited[cur] && status[cur] == INTENT_WAITING) {
            visited[cur] = true;
            path[path_len++] = cur;
            /* Follow the dependency: who occupies our target cell? */
            int occ = grid_unit_at(intent_x[cur], intent_y[cur]);
            if (occ < 0 || occ == cur) break;
            cur = occ;
        }

        /* Check if we hit a cycle (cur is in the path) */
        if (cur >= 0 && status[cur] == INTENT_WAITING) {
            int cycle_start = -1;
            for (int p = 0; p < path_len; p++) {
                if (path[p] == cur) { cycle_start = p; break; }
            }

            if (cycle_start >= 0) {
                int cycle_len = path_len - cycle_start;

                /* Check for cross-faction length-2 (mutual swap) */
                bool is_cross2 = false;
                if (cycle_len == 2) {
                    int a = path[cycle_start], b = path[cycle_start + 1];
                    if (units[a].faction != units[b].faction)
                        is_cross2 = true;
                }

                if (is_cross2) {
                    /* Mutual block ŌĆö neither moves */
                    for (int p = cycle_start; p < path_len; p++) {
                        status[path[p]] = INTENT_BLOCKED;
                        intent_x[path[p]] = units[path[p]].x;
                        intent_y[path[p]] = units[path[p]].y;
                    }
                } else {
                    /* Rotate the cycle ŌĆö everyone advances to their target */
                    for (int p = cycle_start; p < path_len; p++)
                        status[path[p]] = INTENT_COMMITTED;
                }

                /* Tail before cycle: resolve backward */
                for (int p = cycle_start - 1; p >= 0; p--)
                    status[path[p]] = INTENT_COMMITTED;
            }
        }
    }

    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_resolve), _t1 - _t0);
    _t0 = _t1;

    /* Phase 4: Apply all committed moves to ECS */
    for (int i = 0; i < count; i++) {
        if (status[i] != INTENT_COMMITTED) continue;
        if (intent_x[i] == units[i].x && intent_y[i] == units[i].y) continue;

        /* Update grid */
        g_occ_grid[units[i].y * GRID_MAX_X + units[i].x] = 0;
        units[i].x = intent_x[i];
        units[i].y = intent_y[i];
        grid_set(units[i].x, units[i].y, i);

        /* Write to ECS */
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, units[i].eid, loc_comp);
        if (loc) {
            loc[0] = units[i].x;
            loc[1] = units[i].y;
            ecs_modified_id(engine->world, units[i].eid, loc_comp);
        }
    }
    _t1 = perf_us(); perf_add_us(engine, PERF_OFFSET(us_apply), _t1 - _t0);

    /* Share unit snapshot with combat phase */
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData) * count);
        g_act_count = count;
        g_act_prefilled = true;
    }
}

/* ŌöĆŌöĆ movement_sequential: Sequential Priority Movement ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * Build BFS distance fields ONCE. Sort all units by priority. Process
 * units one at a time -- each unit sees the real current state (including
 * all previous units' moves) and picks its best adjacent cell. Apply
 * immediately. No while(any_moved) loop.
 */

static int seq_priority_cmp(const void *a, const void *b) {
    const UnitData *ua = (const UnitData *)a;
    const UnitData *ub = (const UnitData *)b;
    int16_t *enemy_dist_a = (ua->faction == 0) ? g_dist_to_blue : g_dist_to_red;
    int16_t *enemy_dist_b = (ub->faction == 0) ? g_dist_to_blue : g_dist_to_red;
    int da = dist_field_get(enemy_dist_a, ua->x, ua->y);
    int db = dist_field_get(enemy_dist_b, ub->x, ub->y);

    /* Knights (move_type 1): urgency = closeness to enemy (lower dist = more urgent)
     * Archers (move_type 0): urgency = deviation from optimal range */
    int urgency_a = (ua->move_type == 1) ? -da : abs(da - ua->range);
    int urgency_b = (ub->move_type == 1) ? -db : abs(db - ub->range);

    /* Higher urgency first */
    if (urgency_a != urgency_b) return urgency_b - urgency_a;
    /* Archers before knights at equal urgency */
    if (ua->faction != ub->faction) return ua->faction - ub->faction;
    /* Entity ID tiebreak for determinism */
    return ua->entity_id - ub->entity_id;
}

static void avk_movement_sequential(Engine *engine) {
    if (is_simulation_paused(engine)) return;

    /* Read MapSize */
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    /* Collect living units */
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Set energy */
    for (int i = 0; i < count; i++) units[i].energy = units[i].speed;

    /* Step 1: Build distance fields ONCE.
     * In pipeline mode, avk_build_distance_fields already ran during Reset. */
    if (!engine->pipeline_active || g_df_mx == 0) {
        build_distance_fields_pair(engine, units, count, mx, my);
    }

    /* Step 2: Build occupancy grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Step 3: Sort units by priority.
     * qsort uses distance fields at initial positions for priority ranking. */
    qsort(units, (size_t)count, sizeof(UnitData), seq_priority_cmp);

    /* Rebuild occupancy grid after sort since unit indices changed */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Step 4: Process each unit in priority order */
    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};

    for (int i = 0; i < count; i++) {
        UnitData *ent = &units[i];
        if (ent->energy <= 0) continue;

        int16_t *enemy_dist = (ent->faction == 0) ? g_dist_to_blue : g_dist_to_red;

        /* Evaluate 5 candidate cells (4 directions + stay) */
        int cand_x[5], cand_y[5], cand_score[5], ncand = 0;
        int best_score = -999999;

        for (int d = 0; d < 5; d++) {
            int nx = ent->x + dirs[d][0];
            int ny = ent->y + dirs[d][1];
            if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
            /* d==4 is "stay": always valid. Others must be unoccupied. */
            if (d != 4 && grid_occupied(nx, ny)) continue;

            int score = score_cell(nx, ny, ent->move_type, ent->range,
                                   enemy_dist, ent->faction, units);
            cand_x[ncand] = nx;
            cand_y[ncand] = ny;
            cand_score[ncand] = score;
            ncand++;
            if (score > best_score) best_score = score;
        }

        /* Tiebreaker 1 (knights): prefer cell backed by ally */
        int best_backed = 0;
        if (ent->move_type == 1) {
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (ally >= 0 && ally != i && units[ally].faction == ent->faction) {
                    best_backed = 1; break;
                }
            }
        }

        /* Tiebreaker 2: farthest from nearest wall */
        int best_wdist = -1;
        for (int c = 0; c < ncand; c++) {
            if (cand_score[c] != best_score) continue;
            if (ent->move_type == 1 && best_backed) {
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                    continue;
            }
            int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
            int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
            int wd = wx < wy ? wx : wy;
            if (wd > best_wdist) best_wdist = wd;
        }

        /* Tiebreaker 3: prefer reducing the larger axis to target enemy */
        int32_t *enemy_own = (ent->faction == 0) ? g_owner_blue : g_owner_red;
        int tgt_idx = enemy_own[ent->y * GRID_MAX_X + ent->x];
        int best_axis = 0;
        if (tgt_idx >= 0 && tgt_idx < count) {
            int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
            int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
            if (adx != ady) {
                for (int c = 0; c < ncand; c++) {
                    if (cand_score[c] != best_score) continue;
                    if (ent->move_type == 1 && best_backed) {
                        int bk_x = 2 * ent->x - cand_x[c];
                        int bk_y = 2 * ent->y - cand_y[c];
                        int ally = grid_unit_at(bk_x, bk_y);
                        if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                            continue;
                    }
                    int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                    int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                    int wd = wx < wy ? wx : wy;
                    if (wd != best_wdist) continue;
                    int pref = (adx >= ady)
                        ? (abs(cand_x[c] - tx) < adx)
                        : (abs(cand_y[c] - ty) < ady);
                    if (pref > best_axis) best_axis = pref;
                }
            }
        }

        /* Pick first matching candidate */
        int bx = ent->x, by = ent->y;
        bool found = false;
        for (int c = 0; c < ncand; c++) {
            if (cand_score[c] != best_score) continue;
            if (ent->move_type == 1 && best_backed) {
                int bk_x = 2 * ent->x - cand_x[c];
                int bk_y = 2 * ent->y - cand_y[c];
                int ally = grid_unit_at(bk_x, bk_y);
                if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                    continue;
            }
            int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
            int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
            int wd = wx < wy ? wx : wy;
            if (wd != best_wdist) continue;
            if (best_axis && tgt_idx >= 0 && tgt_idx < count) {
                int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                int pref = (adx >= ady)
                    ? (abs(cand_x[c] - tx) < adx)
                    : (abs(cand_y[c] - ty) < ady);
                if (!pref) continue;
            }
            bx = cand_x[c]; by = cand_y[c];
            found = true;
            break;
        }

        /* Apply move immediately if the unit actually moves */
        if (found && (bx != ent->x || by != ent->y)) {
            g_occ_grid[ent->y * GRID_MAX_X + ent->x] = 0;
            ent->x = bx;
            ent->y = by;
            grid_set(ent->x, ent->y, i);
            ent->energy--;

            /* Write to ECS */
            int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, ent->eid, loc_comp);
            if (loc) {
                loc[0] = ent->x;
                loc[1] = ent->y;
                ecs_modified_id(engine->world, ent->eid, loc_comp);
            }
        }
    }

    /* Share unit snapshot with combat phase to avoid redundant collect_units. */
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData) * count);
        g_act_count = count;
        g_act_prefilled = true;
    }
}

/* ŌöĆŌöĆ attack (split into select_targets + apply_damage) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

/* Per-unit attack intent: written by select_targets, consumed by apply_damage.
 * Stored in a static array indexed by unit position in the units array. */
typedef struct {
    int target_idx;  /* index into units array, -1 = no target */
    int damage;
} AttackIntent;

static AttackIntent g_attack_intents[65536];

/* Map center for attack tiebreaking ŌĆö set by combat_setup */
static int g_act_cx = 0, g_act_cy = 0;

/* Single-threaded setup: collect units + build occupancy grid for combat.
 * Must run before select_targets. */
static void avk_combat_setup(Engine *engine) {
    if (is_simulation_paused(engine)) return;

    /* In pipeline mode, movement already populated g_act_units/g_act_count. */
    if (!g_act_prefilled)
        g_act_count = collect_units(engine, g_act_units, 65536);
    g_act_prefilled = false; /* consumed ŌĆö next turn starts fresh */

    ecs_entity_t map_ent = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 320, my = 144;
    if (map_ent && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map_ent, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }
    g_act_cx = mx / 2;
    g_act_cy = my / 2;

    grid_clear(mx, my);
    for (int i = 0; i < g_act_count; i++)
        grid_set(g_act_units[i].x, g_act_units[i].y, i);
}

/* Select target for units in range [start, end). Thread-safe: reads shared
 * immutable data (units, grid), writes only to g_attack_intents[i] for i
 * in [start, end). */
static void select_targets_range(int start, int end) {
    UnitData *units = g_act_units;
    int cx = g_act_cx, cy = g_act_cy;

    for (int i = start; i < end; i++) {
        g_attack_intents[i].target_idx = -1;
        g_attack_intents[i].damage = 0;
        if (units[i].health <= 0) continue;
        int range = units[i].range;

        UnitData *target = NULL;
        int target_idx = -1;
        int target_dist = 999999;
        int target_cdist = 999999;

        for (int dy = -range; dy <= range; dy++) {
            int ax = range - abs(dy);
            for (int dx = -ax; dx <= ax; dx++) {
                int tx = units[i].x + dx;
                int ty = units[i].y + dy;
                int ui = grid_unit_at(tx, ty);
                if (ui < 0) continue;
                if (units[ui].health <= 0 || units[ui].faction == units[i].faction) continue;

                int dist = abs(dx) + abs(dy);
                int cdist = abs(tx - cx) + abs(ty - cy);
                if (!target ||
                    units[ui].health < target->health ||
                    (units[ui].health == target->health && dist < target_dist) ||
                    (units[ui].health == target->health && dist == target_dist && cdist < target_cdist) ||
                    (units[ui].health == target->health && dist == target_dist && cdist == target_cdist && units[ui].entity_id < target->entity_id)) {
                    target = &units[ui];
                    target_idx = ui;
                    target_dist = dist;
                    target_cdist = cdist;
                }
            }
        }

        if (target) {
            g_attack_intents[i].target_idx = target_idx;
            g_attack_intents[i].damage = units[i].damage;
        }
    }
}

#ifndef _WIN32
typedef struct { int start, end; } WorkerRange;
static void *select_targets_worker(void *a) { WorkerRange *r = a; select_targets_range(r->start, r->end); return NULL; }
#endif

static void avk_select_targets(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    int count = g_act_count;
#ifndef _WIN32
    int nt = engine->max_threads;
    if (nt > 1 && count > 256) {
        if (nt > 16) nt = 16;
        pthread_t threads[16];
        WorkerRange ranges[16];
        int chunk = count / nt;
        for (int t = 0; t < nt; t++) {
            ranges[t].start = t * chunk;
            ranges[t].end = (t == nt - 1) ? count : (t + 1) * chunk;
            pthread_create(&threads[t], NULL, select_targets_worker, &ranges[t]);
        }
        for (int t = 0; t < nt; t++)
            pthread_join(threads[t], NULL);
    } else
#endif
    {
        select_targets_range(0, count);
    }
}

static void avk_apply_damage(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    int count = g_act_count;
    UnitData *units = g_act_units;

    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    ecs_entity_t wpn_comp = ecs_lookup(engine->world, "Weapon");
    ecs_entity_t td_comp = ensure_took_damage_comp(engine);
    if (!hp_comp) return;

    /* Apply all attack intents. Single-threaded: safe to modify any entity. */
    for (int i = 0; i < count; i++) {
        int ti = g_attack_intents[i].target_idx;
        if (ti < 0) continue;

        units[ti].health -= g_attack_intents[i].damage;
        int32_t *hp = (int32_t *)ecs_get_mut_id(engine->world, units[ti].eid, hp_comp);
        if (hp) { *hp = units[ti].health; ecs_modified_id(engine->world, units[ti].eid, hp_comp); }

        if (td_comp) {
            ecs_add_id(engine->world, units[ti].eid, td_comp);
        }

        /* Record who this unit attacked */
        if (wpn_comp && ecs_has_id(engine->world, units[i].eid, wpn_comp)) {
            void *wpn = ecs_get_mut_id(engine->world, units[i].eid, wpn_comp);
            if (wpn) {
                ecs_entity_t *attacked = (ecs_entity_t *)((char *)wpn + sizeof(int32_t));
                *attacked = units[ti].eid;
                ecs_modified_id(engine->world, units[i].eid, wpn_comp);
            }
        }
    }
}

/* Legacy wrapper: runs all three phases sequentially (for non-pipeline mode) */
static void avk_attack(Engine *engine) {
    avk_combat_setup(engine);
    avk_select_targets(engine);
    avk_apply_damage(engine);
}

/* ŌöĆŌöĆ despawn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_despawn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    if (!hp_comp) return;

    /* Collect entities to delete (can't delete during iteration) */
    static ecs_entity_t to_delete[65536];
    int del_count = 0;

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {{ .id = hp_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count; i++) {
            const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, it.entities[i], hp_comp);
            if (hp && *hp <= 0 && del_count < 65536)
                to_delete[del_count++] = it.entities[i];
        }
    }
    ecs_query_fini(q);

    for (int i = 0; i < del_count; i++)
        ecs_delete(engine->world, to_delete[i]);
}

/* ŌöĆŌöĆ spawn ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_spawn(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t sr_comp = ecs_lookup(engine->world, "SpawnRequest");
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    if (!sr_comp || !loc_comp) return;

    /* Collect spawn requests */
    typedef struct { ecs_entity_t eid; char template[64]; int x, y; } SpawnReq;
    static SpawnReq reqs[65536];
    int req_count = 0;

    ecs_query_t *q = ecs_query(engine->world, {
        .terms = {{ .id = sr_comp }, { .id = loc_comp }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t it = ecs_query_iter(engine->world, q);
    while (ecs_query_next(&it)) {
        for (int i = 0; i < it.count && req_count < 65536; i++) {
            ecs_entity_t eid = it.entities[i];
            const void *sr = ecs_get_id(engine->world, eid, sr_comp);
            const void *loc = ecs_get_id(engine->world, eid, loc_comp);
            if (!sr || !loc) continue;

            const char *tmpl = *(const char *const *)sr;
            if (!tmpl) continue;

            reqs[req_count].eid = eid;
            snprintf(reqs[req_count].template, 64, "%s", tmpl);
            reqs[req_count].x = *(const int32_t *)loc;
            reqs[req_count].y = *((const int32_t *)loc + 1);
            req_count++;
        }
    }
    ecs_query_fini(q);

    /* Process */
    for (int i = 0; i < req_count; i++) {
        ecs_entity_t spawned = engine_entity_spawn(engine, reqs[i].template, NULL);
        if (spawned && loc_comp) {
            ecs_add_id(engine->world, spawned, loc_comp);
            int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, spawned, loc_comp);
            if (loc) {
                loc[0] = reqs[i].x; loc[1] = reqs[i].y;
                ecs_modified_id(engine->world, spawned, loc_comp);
            }
        }
        ecs_delete(engine->world, reqs[i].eid);
    }
}

/* ŌöĆŌöĆ game_over ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

static void avk_app_stop(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t red_comp = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    if (!red_comp || !blue_comp || !hp_comp) return;

    bool has_red = false, has_blue = false;

    /* Check for existing red units (not health ŌĆö despawn handles dead units next turn) */
    ecs_query_t *qr = ecs_query(engine->world, {
        .terms = {{ .id = red_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t itr = ecs_query_iter(engine->world, qr);
    while (ecs_query_next(&itr)) {
        if (itr.count > 0) { has_red = true; ecs_iter_fini(&itr); break; }
    }
    ecs_query_fini(qr);

    /* Check for existing blue units */
    ecs_query_t *qb = ecs_query(engine->world, {
        .terms = {{ .id = blue_comp }, { .id = engine->user_entity_tag }},
        .cache_kind = EcsQueryCacheNone
    });
    ecs_iter_t itb = ecs_query_iter(engine->world, qb);
    while (ecs_query_next(&itb)) {
        if (itb.count > 0) { has_blue = true; ecs_iter_fini(&itb); break; }
    }
    ecs_query_fini(qb);

    if (!has_red) {
        engine->game_over = true;
        snprintf(engine->game_over_message, sizeof(engine->game_over_message), "Knights Win");
    }
    if (!has_blue) {
        engine->game_over = true;
        snprintf(engine->game_over_message, sizeof(engine->game_over_message), "Archers Win");
    }
}

/* ŌöĆŌöĆ movement_snapshot: Pure Snapshot (SDRA) Movement ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * Simplest single-pass movement. No iteration, no intent graph, no priority sort.
 * Snapshot ŌåÆ decide ŌåÆ resolve collisions sequentially by entity_id ŌåÆ apply.
 */

static void avk_movement_snapshot(Engine *engine) {
    if (is_simulation_paused(engine)) return;

    /* Read MapSize */
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    /* Collect living units (already sorted by entity_id) */
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Step 1: Build distance fields ONCE */
    if (!engine->pipeline_active || g_df_mx == 0) {
        build_distance_fields_pair(engine, units, count, mx, my);
    }

    /* Step 2: Build occupancy grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Step 3: Each unit picks its best neighbor from the frozen snapshot */
    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};
    decide_moves_range(units, count, mx, my, dirs, 0, count);

    /* Step 4: Collision resolution ŌĆö iterate in entity_id order (already sorted).
     * Use a claimed grid: first to claim wins, others stay. */
    static bool claimed[GRID_MAX_Y * GRID_MAX_X];
    memset(claimed, 0, (size_t)(my + 1) * GRID_MAX_X * sizeof(bool));

    /* Mark all current positions as claimed (stationary default) */
    for (int i = 0; i < count; i++)
        claimed[units[i].y * GRID_MAX_X + units[i].x] = true;

    for (int i = 0; i < count; i++) {
        if (!g_move_decisions[i].found) continue;
        int bx = g_move_decisions[i].bx;
        int by = g_move_decisions[i].by;
        if (bx == units[i].x && by == units[i].y) continue;

        int target_ci = by * GRID_MAX_X + bx;
        if (claimed[target_ci]) continue; /* someone already there or claimed */

        /* Release old cell, claim new one */
        claimed[units[i].y * GRID_MAX_X + units[i].x] = false;
        claimed[target_ci] = true;

        /* Update grid */
        g_occ_grid[units[i].y * GRID_MAX_X + units[i].x] = 0;
        units[i].x = bx;
        units[i].y = by;
        grid_set(units[i].x, units[i].y, i);

        /* Write to ECS */
        int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, units[i].eid, loc_comp);
        if (loc) {
            loc[0] = units[i].x;
            loc[1] = units[i].y;
            ecs_modified_id(engine->world, units[i].eid, loc_comp);
        }
    }

    /* Share unit snapshot with combat phase */
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData) * count);
        g_act_count = count;
        g_act_prefilled = true;
    }
}

/* ŌöĆŌöĆ Registration ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

/* ŌöĆŌöĆ movement_wavefront: Layer-by-Layer from Engagement Frontier ŌöĆŌöĆŌöĆŌöĆŌöĆ */
/*
 * Layer-by-layer movement from the engagement frontier outward.
 *
 * 1. Build BFS distance fields once.
 * 2. Assign each unit a "layer" = its distance to the engagement frontier.
 *    Knights: layer = dist_to_nearest_enemy.
 *    Archers: layer = |dist_to_nearest_enemy - weapon_range|.
 *    Layer 0 units are at the frontier; layer 1 is one step back, etc.
 * 3. Process layers 0, 1, 2, ... in order:
 *    - Within each layer, process units in entity_id order (determinism).
 *    - Each unit evaluates 5 cells against the CURRENT occupancy grid
 *      (which reflects moves by all previous layers), picks best via
 *      score_cell + tiebreakers, applies immediately if cell is free.
 * 4. Write ECS locations as moves happen.
 *
 * Key insight: front-line units (layer 0) move first and claim positions.
 * Units one step back see where front-line units went and fill gaps.
 */
static void avk_movement_wavefront(Engine *engine) {
    if (is_simulation_paused(engine)) return;

    /* Read MapSize */
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }

    /* Collect living units (sorted by entity_id) */
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;

    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");

    /* Set energy */
    for (int i = 0; i < count; i++) units[i].energy = units[i].speed;

    /* Build distance fields once.
     * In pipeline mode, avk_build_distance_fields already ran during Reset. */
    if (!engine->pipeline_active || g_df_mx == 0) {
        build_distance_fields_pair(engine, units, count, mx, my);
    }

    /* Build occupancy grid */
    grid_clear(mx, my);
    for (int i = 0; i < count; i++)
        grid_set(units[i].x, units[i].y, i);

    /* Assign layers. Max possible layer ~ grid diagonal. */
    int max_layer = mx + my;  /* upper bound */
    static int unit_layer[65536];
    for (int i = 0; i < count; i++) {
        int16_t *enemy_dist = (units[i].faction == 0) ? g_dist_to_blue : g_dist_to_red;
        int d = dist_field_get(enemy_dist, units[i].x, units[i].y);
        if (units[i].move_type == 1) {
            /* Knight: layer = distance to nearest enemy */
            unit_layer[i] = d;
        } else {
            /* Archer: layer = deviation from optimal range */
            unit_layer[i] = abs(d - units[i].range);
        }
    }

    /* Bucket sort: scan units per layer (units already in entity_id order) */
    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};

    for (int layer = 0; layer <= max_layer; layer++) {
        for (int i = 0; i < count; i++) {
            if (unit_layer[i] != layer) continue;

            UnitData *ent = &units[i];
            if (ent->energy <= 0) continue;

            int16_t *enemy_dist = (ent->faction == 0) ? g_dist_to_blue : g_dist_to_red;

            /* Evaluate 5 candidate cells (4 directions + stay) */
            int cand_x[5], cand_y[5], cand_score[5], ncand = 0;
            int best_score = -999999;

            for (int d = 0; d < 5; d++) {
                int nx = ent->x + dirs[d][0];
                int ny = ent->y + dirs[d][1];
                if (nx < 1 || nx > mx || ny < 1 || ny > my) continue;
                if (d != 4 && grid_occupied(nx, ny)) continue;

                int score = score_cell(nx, ny, ent->move_type, ent->range,
                                       enemy_dist, ent->faction, units);
                cand_x[ncand] = nx;
                cand_y[ncand] = ny;
                cand_score[ncand] = score;
                ncand++;
                if (score > best_score) best_score = score;
            }

            /* Tiebreaker 1 (knights): prefer cell backed by ally */
            int best_backed = 0;
            if (ent->move_type == 1) {
                for (int c = 0; c < ncand; c++) {
                    if (cand_score[c] != best_score) continue;
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (ally >= 0 && ally != i && units[ally].faction == ent->faction) {
                        best_backed = 1; break;
                    }
                }
            }

            /* Tiebreaker 2: farthest from nearest wall */
            int best_wdist = -1;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                int wd = wx < wy ? wx : wy;
                if (wd > best_wdist) best_wdist = wd;
            }

            /* Tiebreaker 3: prefer reducing the larger axis to target enemy */
            int32_t *enemy_own = (ent->faction == 0) ? g_owner_blue : g_owner_red;
            int tgt_idx = enemy_own[ent->y * GRID_MAX_X + ent->x];
            int best_axis = 0;
            if (tgt_idx >= 0 && tgt_idx < count) {
                int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                if (adx != ady) {
                    for (int c = 0; c < ncand; c++) {
                        if (cand_score[c] != best_score) continue;
                        if (ent->move_type == 1 && best_backed) {
                            int bk_x = 2 * ent->x - cand_x[c];
                            int bk_y = 2 * ent->y - cand_y[c];
                            int ally = grid_unit_at(bk_x, bk_y);
                            if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                                continue;
                        }
                        int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                        int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                        int wd = wx < wy ? wx : wy;
                        if (wd != best_wdist) continue;
                        int pref = (adx >= ady)
                            ? (abs(cand_x[c] - tx) < adx)
                            : (abs(cand_y[c] - ty) < ady);
                        if (pref > best_axis) best_axis = pref;
                    }
                }
            }

            /* Pick first matching candidate */
            int bx = ent->x, by = ent->y;
            bool found = false;
            for (int c = 0; c < ncand; c++) {
                if (cand_score[c] != best_score) continue;
                if (ent->move_type == 1 && best_backed) {
                    int bk_x = 2 * ent->x - cand_x[c];
                    int bk_y = 2 * ent->y - cand_y[c];
                    int ally = grid_unit_at(bk_x, bk_y);
                    if (!(ally >= 0 && ally != i && units[ally].faction == ent->faction))
                        continue;
                }
                int wx = cand_x[c] - 1 < mx - cand_x[c] ? cand_x[c] - 1 : mx - cand_x[c];
                int wy = cand_y[c] - 1 < my - cand_y[c] ? cand_y[c] - 1 : my - cand_y[c];
                int wd = wx < wy ? wx : wy;
                if (wd != best_wdist) continue;
                if (best_axis && tgt_idx >= 0 && tgt_idx < count) {
                    int tx = units[tgt_idx].x, ty = units[tgt_idx].y;
                    int adx = abs(ent->x - tx), ady = abs(ent->y - ty);
                    int pref = (adx >= ady)
                        ? (abs(cand_x[c] - tx) < adx)
                        : (abs(cand_y[c] - ty) < ady);
                    if (!pref) continue;
                }
                bx = cand_x[c]; by = cand_y[c];
                found = true;
                break;
            }

            /* Apply move immediately */
            if (found && (bx != ent->x || by != ent->y)) {
                g_occ_grid[ent->y * GRID_MAX_X + ent->x] = 0;
                ent->x = bx;
                ent->y = by;
                grid_set(ent->x, ent->y, i);
                ent->energy--;

                /* Write to ECS */
                int32_t *loc = (int32_t *)ecs_get_mut_id(engine->world, ent->eid, loc_comp);
                if (loc) {
                    loc[0] = ent->x;
                    loc[1] = ent->y;
                    ecs_modified_id(engine->world, ent->eid, loc_comp);
                }
            }
        }
    }

    /* Share unit snapshot with combat phase */
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData) * count);
        g_act_count = count;
        g_act_prefilled = true;
    }
}

/* ŌöĆŌöĆ movement_hybrid: Intent Graph + Second BFS Re-evaluation ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */
static void avk_movement_hybrid(Engine *engine) {
    if (is_simulation_paused(engine)) return;
    ecs_entity_t map = ecs_lookup(engine->world, "Map");
    ecs_entity_t ms_comp = ecs_lookup(engine->world, "MapSize");
    int mx = 10, my = 10;
    if (map && ms_comp) {
        const void *ms = ecs_get_id(engine->world, map, ms_comp);
        if (ms) { mx = *(const int32_t *)ms; my = *((const int32_t *)ms + 1); }
    }
    static UnitData units[65536];
    int count = collect_units(engine, units, 65536);
    if (count == 0) return;
    ecs_entity_t loc_comp = ecs_lookup(engine->world, "Location");
    grid_clear(mx, my);
    for (int i = 0; i < count; i++) grid_set(units[i].x, units[i].y, i);
    static const int dirs[][2] = {{0,-1},{0,1},{-1,0},{1,0},{0,0}};

    /* Pass 1: Intent graph */
    build_distance_field(g_dist_to_red, g_owner_red, units, count, 0, mx, my);
    build_distance_field(g_dist_to_blue, g_owner_blue, units, count, 1, mx, my);
    decide_moves_range(units, count, mx, my, dirs, 0, count);

    static int hi_x[65536], hi_y[65536];
    static enum IntentStatus hs[65536];
    static int hp[65536];
    static int32_t hcc[GRID_MAX_Y * GRID_MAX_X];
    static int32_t hcw[GRID_MAX_Y * GRID_MAX_X];
    static int32_t hwn[65536];
    static int hwl[65536];
    int wh = 0, wt = 0;
    memset(hcc, -1, (size_t)(my+1) * GRID_MAX_X * sizeof(int32_t));
    memset(hcw, -1, (size_t)(my+1) * GRID_MAX_X * sizeof(int32_t));

    for (int i = 0; i < count; i++) {
        int tx = g_move_decisions[i].found ? g_move_decisions[i].bx : units[i].x;
        int ty = g_move_decisions[i].found ? g_move_decisions[i].by : units[i].y;
        hi_x[i] = tx; hi_y[i] = ty;
        int16_t *ed = (units[i].faction==0) ? g_dist_to_blue : g_dist_to_red;
        int d = dist_field_get(ed, units[i].x, units[i].y);
        int u = (units[i].move_type==1) ? (10000-d) : (abs(d-units[i].range)+10000);
        hp[i] = u * 100000 + units[i].entity_id;
        if (tx==units[i].x && ty==units[i].y) {
            hs[i] = INTENT_STATIONARY; hcc[ty*GRID_MAX_X+tx] =i;
        } else if (!grid_occupied(tx, ty)) {
            hs[i] = INTENT_FREE;
        } else {
            hs[i] = INTENT_WAITING;
            int wci = ty*GRID_MAX_X+tx; hwn[i] = hcw[wci]; hcw[wci] =i;
        }
    }
    for (int i = 0; i < count; i++) {
        if (hs[i] != INTENT_FREE) continue;
        int ci = hi_y[i]*GRID_MAX_X+hi_x[i]; int ex = hcc[ci];
        if (ex < 0) { hcc[ci]=i; hwl[wt++]=i; }
        else if (hp[i]>hp[ex]) {
            hs[ex]=INTENT_BLOCKED; hi_x[ex]=units[ex].x; hi_y[ex]=units[ex].y;
            hcc[units[ex].y*GRID_MAX_X+units[ex].x]=ex;
            hcc[ci]=i; hwl[wt++]=i;
        } else {
            hs[i]=INTENT_BLOCKED; hi_x[i]=units[i].x; hi_y[i]=units[i].y;
            hcc[units[i].y*GRID_MAX_X+units[i].x]=i;
        }
    }
    while (wh < wt) {
        int i = hwl[wh++]; hs[i] = INTENT_COMMITTED;
        int oci = units[i].y*GRID_MAX_X+units[i].x;
        int bw=-1, bp=-1;
        for (int j=hcw[oci]; j>=0; j=hwn[j]) { if (hs[j]!=INTENT_WAITING) continue; if (hp[j]>bp) { bw=j; bp=hp[j]; } }
        if (bw>=0) {
            hcc[hi_y[bw]*GRID_MAX_X+hi_x[bw]]=bw; hs[bw]=INTENT_FREE; hwl[wt++]=bw;
            for (int k=hcw[oci]; k>=0; k=hwn[k]) {
                if (k==bw||hs[k]!=INTENT_WAITING) continue;
                hs[k]=INTENT_BLOCKED; hi_x[k]=units[k].x; hi_y[k]=units[k].y;
                hcc[units[k].y*GRID_MAX_X+units[k].x]=k;
            }
        }
    }
    /* Apply pass 1 */
    int p1m = 0;
    for (int i = 0; i < count; i++) {
        if (hs[i]==INTENT_COMMITTED && (hi_x[i]!=units[i].x||hi_y[i]!=units[i].y)) {
            g_occ_grid[units[i].y*GRID_MAX_X+units[i].x]=0;
            units[i].x=hi_x[i]; units[i].y=hi_y[i];
            grid_set(units[i].x, units[i].y, i); p1m++;
        }
    }
    /* Pass 2: Rebuild BFS, re-evaluate stuck units */
    if (p1m > 0) {
        build_distance_field(g_dist_to_red, g_owner_red, units, count, 0, mx, my);
        perf_record_df_full(engine);
        build_distance_field(g_dist_to_blue, g_owner_blue, units, count, 1, mx, my);
        perf_record_df_full(engine);
        for (int i = 0; i < count; i++) {
            if (hs[i]!=INTENT_BLOCKED && hs[i]!=INTENT_WAITING) continue;
            int16_t *ed = (units[i].faction==0) ? g_dist_to_blue : g_dist_to_red;
            int bs=-999999, bx=units[i].x, by=units[i].y; bool f=false;
            for (int d=0; d<4; d++) {
                int nx=units[i].x+dirs[d][0], ny=units[i].y+dirs[d][1];
                if (nx<1||nx>mx||ny<1||ny>my) continue;
                if (grid_occupied(nx,ny)) continue;
                int s=score_cell(nx,ny,units[i].move_type,units[i].range,ed,units[i].faction,units);
                if (s>bs) { bs=s; bx=nx; by=ny; f=true; }
            }
            if (f && (bx!=units[i].x||by!=units[i].y) && !grid_occupied(bx,by)) {
                g_occ_grid[units[i].y*GRID_MAX_X+units[i].x]=0;
                units[i].x=bx; units[i].y=by;
                grid_set(units[i].x, units[i].y, i); hs[i]=INTENT_COMMITTED;
            }
        }
    }
    for (int i = 0; i < count; i++) {
        if (hs[i]!=INTENT_COMMITTED) continue;
        int32_t *loc=(int32_t*)ecs_get_mut_id(engine->world,units[i].eid,loc_comp);
        if (loc) { loc[0]=units[i].x; loc[1]=units[i].y; ecs_modified_id(engine->world,units[i].eid,loc_comp); }
    }
    if (engine->pipeline_active) {
        memcpy(g_act_units, units, sizeof(UnitData)*count);
        g_act_count=count; g_act_prefilled=true;
    }
}

/* Select movement function based on engine->movement_model.
 * Returns function pointer and sets *out_name to the C function name. */
static NativeSystemFn select_movement_fn(Engine *engine, const char **out_name) {
    const char *model = engine->movement_model;
    struct { const char *model; NativeSystemFn fn; const char *name; } table[] = {
        { "original",   avk_movement,            "movement" },
        { "intent",     avk_movement_intent,     "movement_intent" },
        { "sequential", avk_movement_sequential,  "movement_sequential" },
        { "snapshot",   avk_movement_snapshot,    "movement_snapshot" },
        { "wavefront",  avk_movement_wavefront,   "movement_wavefront" },
        { "hybrid",     avk_movement_hybrid,      "movement_hybrid" },
    };
    for (int i = 0; i < 6; i++) {
        if (strcmp(model, table[i].model) == 0) {
            *out_name = table[i].name;
            return table[i].fn;
        }
    }
    if (model[0] == '\0') {
        *out_name = "movement";
        return avk_movement;
    }
    fprintf(stderr, "Unknown movement model '%s', using original\n", model);
    *out_name = "movement";
    return avk_movement;
}

void avk_register_native_systems(Engine *engine) {
    /* Ensure TookDamage component exists */
    ensure_took_damage_comp(engine);

    const char *movement_name = NULL;
    NativeSystemFn movement_fn = select_movement_fn(engine, &movement_name);

    if (engine->pipeline_active) {
        /* Pipeline mode: register as Flecs system entities with phases */

        /* Phase: Init ŌĆö app_start (rewind registered separately in app.c) */
        engine_system_register_pipeline(
            engine, "app_start", avk_app_start,
            engine->phase_init, false, 0);

        /* Phase: Reset ŌĆö despawn, start_of_turn, build_distance_fields
         * No ordering between them ŌĆö they operate on independent data. */
        engine_system_register_pipeline(
            engine, "despawn", avk_despawn,
            engine->phase_reset, false, 0);
        engine_system_register_pipeline(
            engine, "start_of_turn", avk_start_of_turn,
            engine->phase_reset, false, 0);
        engine_system_register_pipeline(
            engine, "build_distance_fields", avk_build_distance_fields,
            engine->phase_reset, false, 0);

        /* Phase: Move ŌĆö selected movement model */
        engine_system_register_pipeline(
            engine, movement_name, movement_fn,
            engine->phase_move, false, 0);

        /* Phase: Act ŌĆö combat_setup ŌåÆ select_targets ŌåÆ apply_damage */
        ecs_entity_t sys_setup = engine_system_register_pipeline(
            engine, "combat_setup", avk_combat_setup,
            engine->phase_act, false, 0);
        ecs_entity_t sys_select = engine_system_register_pipeline(
            engine, "select_targets", avk_select_targets,
            engine->phase_act, false, sys_setup);
        engine_system_register_pipeline(
            engine, "apply_damage", avk_apply_damage,
            engine->phase_act, false, sys_select);

        /* Phase: Finalize ŌĆö spawn, then app_stop */
        ecs_entity_t sys_spawn = engine_system_register_pipeline(
            engine, "spawn", avk_spawn,
            engine->phase_finalize, false, 0);
        engine_system_register_pipeline(
            engine, "app_stop", avk_app_stop,
            engine->phase_finalize, false, sys_spawn);
    } else {
        /* Legacy mode: flat registration, execution order from app.yaml */
        engine_system_register_native(engine, "start_of_turn", avk_start_of_turn);
        engine_system_register_native(engine, "app_start", avk_app_start);
        engine_system_register_native(engine, movement_name, movement_fn);
        engine_system_register_native(engine, "attack", avk_attack);
        engine_system_register_native(engine, "despawn", avk_despawn);
        engine_system_register_native(engine, "spawn", avk_spawn);
        engine_system_register_native(engine, "app_stop", avk_app_stop);
    }
}
#ifndef AVK_SYSTEMS_H
#define AVK_SYSTEMS_H

#include "engine/engine.h"

/* Register all native archer systems on an engine.
   Replaces Lua systems with C implementations for the same names. */
void avk_register_native_systems(Engine *engine);

#endif
#include "test.h"
#include "../src/engine/engine.h"
#include "../src/engine/simulation.h"
#include "../src/engine/app.h"
#include "../src/engine/history.h"
#include "../src/engine/components.h"

static Engine *engine;

static void count_factions(int *archers, int *knights) {
    *archers = 0; *knights = 0;
    ecs_entity_t hp_comp = ecs_lookup(engine->world, "Health");
    ecs_entity_t red_comp = ecs_lookup(engine->world, "RedFaction");
    ecs_entity_t blue_comp = ecs_lookup(engine->world, "BlueFaction");
    if (!hp_comp) return;
    EntityList list = engine_entity_list(engine);
    for (int i = 0; i < list.count; i++) {
        ecs_entity_t eid = list.items[i].id;
        const int32_t *hp = (const int32_t *)ecs_get_id(engine->world, eid, hp_comp);
        if (!hp || *hp <= 0) continue;
        if (red_comp && ecs_has_id(engine->world, eid, red_comp)) (*archers)++;
        else if (blue_comp && ecs_has_id(engine->world, eid, blue_comp)) (*knights)++;
    }
    engine_entity_list_free(&list);
}

static void setup_game(int map_size) {
    engine = engine_init(NULL);
    snprintf(engine->sandboxes_dir, sizeof(engine->sandboxes_dir), "./sandboxes/");
    engine_sandbox_select(engine, "avk");
    AppStartResult asr;
    engine_app_start(engine, NULL, &asr);
    ecs_entity_t map = engine_entity_create(engine, "Map");
    char vals[64];
    snprintf(vals, sizeof(vals), "x: %d, y: %d", map_size, map_size);
    engine_entity_add_component(engine, map, "MapSize", vals);
}

static void advance(int turns) {
    for (int i = 0; i < turns; i++) {
        TurnResult tr;
        if (!engine_sim_turn(engine, &tr)) break;
        engine_turn_result_free(&tr);
    }
}

static void unpause(void) {
    ecs_entity_t gs = ecs_lookup(engine->world, "GameState");
    ecs_entity_t sp = ecs_lookup(engine->world, "SimulationPaused");
    if (gs && sp) ecs_remove_id(engine->world, gs, sp);
}

/* ŌöĆŌöĆ Rewind basics ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(rewind_restores_turn_counter) {
    setup_game(100);
    advance(10);
    ASSERT_EQ(engine->turn_counter, 10);

    engine_sim_rewind(engine, 5);
    ASSERT_EQ(engine->turn_counter, 5);
    ASSERT(is_simulation_paused(engine));

    engine_fini(engine);
}

TEST(rewind_clears_game_over) {
    setup_game(100);  /* Large enough to last several turns */
    advance(1000);
    ASSERT(engine->game_over);

    /* Rewind to a turn that exists in history (before game ended) */
    int oldest = history_oldest_turn(engine);
    ASSERT(oldest > 0);

    engine_sim_rewind(engine, oldest);
    ASSERT(!engine->game_over);
    ASSERT_EQ(engine->turn_counter, oldest);

    engine_fini(engine);
}

TEST(rewind_out_of_range_fails) {
    setup_game(100);
    advance(5);

    ASSERT(!engine_sim_rewind(engine, 0));   /* before history */
    ASSERT(!engine_sim_rewind(engine, 99));  /* after history */
    ASSERT_EQ(engine->turn_counter, 5);      /* unchanged */

    engine_fini(engine);
}

/* ŌöĆŌöĆ Determinism: rewind to N, advance to M, verify counts match ŌöĆŌöĆŌöĆŌöĆ */

TEST(determinism_rewind_and_replay) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);
    int target_turn = engine->turn_counter;
    ASSERT(a_target > 0);  /* both factions still alive */
    ASSERT(k_target > 0);

    /* Rewind to 5, advance to 10 ŌĆö should match */
    engine_sim_rewind(engine, 5);
    unpause();
    advance(5);

    int a, k;
    count_factions(&a, &k);
    ASSERT_EQ(engine->turn_counter, target_turn);
    ASSERT_EQ(a, a_target);
    ASSERT_EQ(k, k_target);

    engine_fini(engine);
}

TEST(determinism_repeated_rewind_cycles) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);

    /* Rewind 5, advance 5, repeat 5 times ŌĆö every iteration should match */
    for (int trial = 0; trial < 5; trial++) {
        engine_sim_rewind(engine, 5);
        unpause();
        advance(5);

        int a, k;
        count_factions(&a, &k);
        ASSERT_EQ(a, a_target);
        ASSERT_EQ(k, k_target);
    }

    engine_fini(engine);
}

TEST(determinism_rewind_to_start) {
    setup_game(100);
    advance(10);

    int a_target, k_target;
    count_factions(&a_target, &k_target);
    int target_turn = engine->turn_counter;

    /* Rewind to turn 1, replay all the way to target */
    engine_sim_rewind(engine, 1);
    unpause();
    advance(target_turn - 1);

    int a, k;
    count_factions(&a, &k);
    ASSERT_EQ(engine->turn_counter, target_turn);
    ASSERT_EQ(a, a_target);
    ASSERT_EQ(k, k_target);

    engine_fini(engine);
}

/* ŌöĆŌöĆ Pause behavior ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(paused_turn_does_not_advance) {
    setup_game(100);
    advance(5);

    int a_before, k_before;
    count_factions(&a_before, &k_before);

    engine_sim_rewind(engine, 3);
    /* Still paused ŌĆö run a turn, nothing should change */
    TurnResult tr;
    engine_sim_turn(engine, &tr);
    engine_turn_result_free(&tr);

    ASSERT_EQ(engine->turn_counter, 3);
    ASSERT(is_simulation_paused(engine));

    engine_fini(engine);
}

TEST(unpause_resumes_simulation) {
    setup_game(100);
    advance(5);

    engine_sim_rewind(engine, 3);
    ASSERT(is_simulation_paused(engine));

    unpause();
    ASSERT(!is_simulation_paused(engine));

    /* Advance should work now */
    TurnResult tr;
    engine_sim_turn(engine, &tr);
    engine_turn_result_free(&tr);
    ASSERT_EQ(engine->turn_counter, 4);

    engine_fini(engine);
}

/* ŌöĆŌöĆ History query ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ */

TEST(history_tracks_turns) {
    setup_game(100);
    advance(10);

    ASSERT_EQ(history_newest_turn(engine), 10);
    ASSERT_EQ(history_oldest_turn(engine), 1);

    engine_fini(engine);
}

TEST(history_truncated_on_rewind) {
    setup_game(100);
    advance(10);
    ASSERT_EQ(history_newest_turn(engine), 10);

    engine_sim_rewind(engine, 5);
    ASSERT_EQ(history_newest_turn(engine), 5);

    engine_fini(engine);
}

int main(void) {
    TEST_SUITE("Rewind Basics");
    RUN(rewind_restores_turn_counter);
    RUN(rewind_clears_game_over);
    RUN(rewind_out_of_range_fails);

    TEST_SUITE("Rewind Determinism");
    RUN(determinism_rewind_and_replay);
    RUN(determinism_repeated_rewind_cycles);
    RUN(determinism_rewind_to_start);

    TEST_SUITE("Pause Behavior");
    RUN(paused_turn_does_not_advance);
    RUN(unpause_resumes_simulation);

    TEST_SUITE("History");
    RUN(history_tracks_turns);
    RUN(history_truncated_on_rewind);

    TEST_RESULTS();
}
