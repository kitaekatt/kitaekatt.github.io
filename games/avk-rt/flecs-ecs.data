/* ÔöÇÔöÇ Non-blocking input ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */

#define KEY_NONE   0
#define KEY_SPACE  1
#define KEY_RIGHT  2
#define KEY_QUIT   3
#define KEY_LEFT   4

#ifdef _WIN32
#include <conio.h>
static void input_init(void) {}
static void input_fini(void) {}
static int poll_key(void) {
    if (!_kbhit()) return KEY_NONE;
    int ch = _getch();
    if (ch == ' ') return KEY_SPACE;
    if (ch == 'q' || ch == 'Q') return KEY_QUIT;
    if (ch == 0xE0 || ch == 0) {
        ch = _getch();
        if (ch == 0x4D) return KEY_RIGHT;
        if (ch == 0x4B) return KEY_LEFT;
    }
    return KEY_NONE;
}
#else
#include <termios.h>
#include <fcntl.h>
static struct termios orig_termios;
static void input_init(void) {
    struct termios raw;
    tcgetattr(STDIN_FILENO, &orig_termios);
    raw = orig_termios;
    raw.c_lflag &= ~(ICANON | ECHO);
    raw.c_cc[VMIN] = 0;
    raw.c_cc[VTIME] = 0;
    tcsetattr(STDIN_FILENO, TCSANOW, &raw);
}
static void input_fini(void) {
    tcsetattr(STDIN_FILENO, TCSANOW, &orig_termios);
}
static int poll_key(void) {
    unsigned char ch;
    if (read(STDIN_FILENO, &ch, 1) != 1) return KEY_NONE;
    if (ch == ' ') return KEY_SPACE;
    if (ch == 'q' || ch == 'Q') return KEY_QUIT;
    if (ch == 0x1B) {
        unsigned char seq[2];
        if (read(STDIN_FILENO, &seq[0], 1) != 1) return KEY_NONE;
        if (read(STDIN_FILENO, &seq[1], 1) != 1) return KEY_NONE;
        if (seq[0] == '[' && seq[1] == 'C') return KEY_RIGHT;
        if (seq[0] == '[' && seq[1] == 'D') return KEY_LEFT;
    }
    return KEY_NONE;
}
#endif

typedef struct {
    char server[256];
    char sandbox[128];
    int map_x, map_y;
    int max_turns;
    int delay_ms;
} ClientConfig;

typedef struct {
    bool direct;
    bool benchmark;
    int benchmark_runs;
    int fps;  /* --fps: target frames per second, 0 = no delay */
    char record_path[256]; /* --record FILE, empty = no recording */
    char image_dir[256];  /* --image DIR, empty = no frame dump */
    char overrides_dir[256]; /* --overrides DIR, empty = none */
    char config_name[64];   /* --config NAME, empty = "console" */
} ClientFlags;

static bool load_config(const char *path, ClientConfig *cfg) {
    FILE *f = fopen(path, "r");
    if (!f) { fprintf(stderr, "Cannot open config: %s\n", path); return false; }

    yaml_parser_t parser;
    yaml_event_t event;
    yaml_parser_initialize(&parser);
    yaml_parser_set_input_file(&parser, f);

    char current_key[64] = {0};
    char parent_key[64] = {0};
    int depth = 0;

    snprintf(cfg->server, sizeof(cfg->server), "http://localhost:8080");
    cfg->map_x = 10; cfg->map_y = 10;
    cfg->max_turns = 300;
    cfg->delay_ms = 200;

    while (1) {
        if (!yaml_parser_parse(&parser, &event)) break;
        if (event.type == YAML_STREAM_END_EVENT) { yaml_event_delete(&event); break; }

        if (event.type == YAML_SCALAR_EVENT) {
            const char *val = (const char *)event.data.scalar.value;
            if (current_key[0] == '\0') {
                snprintf(current_key, sizeof(current_key), "%s", val);
            } else {
                if (depth > 0 && strcmp(parent_key, "map_size") == 0) {
                    if (strcmp(current_key, "x") == 0) cfg->map_x = atoi(val);
                    else if (strcmp(current_key, "y") == 0) cfg->map_y = atoi(val);
                } else {
                    if (strcmp(current_key, "server") == 0)
                        snprintf(cfg->server, sizeof(cfg->server), "%s", val);
                    else if (strcmp(current_key, "sandbox") == 0)
                        snprintf(cfg->sandbox, sizeof(cfg->sandbox), "%s", val);
                    else if (strcmp(current_key, "max_turns") == 0)
                        cfg->max_turns = atoi(val);
                    else if (strcmp(current_key, "delay_ms") == 0)
                        cfg->delay_ms = atoi(val);
                }
                current_key[0] = '\0';
            }
        } else if (event.type == YAML_MAPPING_START_EVENT) {
            if (current_key[0] != '\0') {
                snprintf(parent_key, sizeof(parent_key), "%s", current_key);
                current_key[0] = '\0';
                depth++;
            }
        } else if (event.type == YAML_MAPPING_END_EVENT) {
            if (depth > 0) { depth--; parent_key[0] = '\0'; }
        }

        yaml_event_delete(&event);
    }

    yaml_parser_delete(&parser);
    fclose(f);
    return cfg->sandbox[0] != '\0';
}

static double now_ms(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return ts.tv_sec * 1000.0 + ts.tv_nsec / 1000000.0;
}

/* ÔöÇÔöÇ REST mode ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */

typedef struct {
    int turn;
    bool game_over;
    char message[256];
    double duration_ms;
} TurnInfo;

static TurnInfo run_turn_rest(void) {
    TurnInfo info = {0};
    double t0 = now_ms();
    char *json = api_post("/api/sim/turn", NULL);
    info.duration_ms = now_ms() - t0;
    if (!json) return info;

    cJSON *root = cJSON_Parse(json);
    if (root) {
        cJSON *t = cJSON_GetObjectItemCaseSensitive(root, "turn");
        if (t) info.turn = t->valueint;

        cJSON *msg = cJSON_GetObjectItemCaseSensitive(root, "message");
        if (msg && cJSON_IsString(msg)) {
            snprintf(info.message, sizeof(info.message), "%s", msg->valuestring);
            info.game_over = true;
        }
        cJSON *go = cJSON_GetObjectItemCaseSensitive(root, "game_over_message");
        if (go && cJSON_IsString(go)) {
            snprintf(info.message, sizeof(info.message), "%s", go->valuestring);
            info.game_over = true;
        }
        cJSON_Delete(root);
    }
    free(json);
    return info;
}

static bool setup_rest(ClientConfig *cfg) {
    api_init(cfg->server);

    char body[256];
    snprintf(body, sizeof(body), "{\"name\":\"%s\"}", cfg->sandbox);
    char *r = api_post("/api/sandbox/select", body);
    if (!r || strstr(r, "error")) {
        fprintf(stderr, "Failed to select sandbox: %s\n", r ? r : "no response");
        free(r); return false;
    }
    free(r);

    r = api_post("/api/app/start", NULL);
    if (!r || strstr(r, "error")) {
        fprintf(stderr, "Failed to start game: %s\n", r ? r : "no response");
        free(r); return false;
    }
    free(r);
    return true;
}

/* ÔöÇÔöÇ Direct mode ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */

static Engine *setup_direct(ClientConfig *cfg, const char *overrides_dir,
                            const char *config_name) {
    Engine *engine = engine_init(NULL);
    if (!engine) { fprintf(stderr, "Failed to init engine\n"); return NULL; }

    if (overrides_dir && overrides_dir[0])
        engine_set_overrides(engine, overrides_dir);

    if (!engine_sandbox_select(engine, cfg->sandbox)) {
        fprintf(stderr, "Failed to select sandbox '%s'\n", cfg->sandbox);
        engine_fini(engine); return NULL;
    }

    const char *cn = (config_name && config_name[0]) ? config_name : "console";
    AppStartResult asr;
    if (!engine_app_start(engine, cn, &asr)) {
        fprintf(stderr, "Failed to start app for sandbox '%s'\n", cfg->sandbox);
        engine_fini(engine); return NULL;
    }

    return engine;
}

static TurnInfo run_turn_direct(Engine *engine) {
    TurnInfo info = {0};
    double t0 = now_ms();

    TurnResult tr;
    if (!engine_sim_turn(engine, &tr)) {
        info.duration_ms = now_ms() - t0;
        if (engine->game_over) {
            info.game_over = true;
            snprintf(info.message, sizeof(info.message), "%s", engine->game_over_message);
            info.turn = engine->turn_counter;
        }
        return info;
    }

    info.duration_ms = now_ms() - t0;
    info.turn = tr.turn;

    if (engine->game_over) {
        info.game_over = true;
        snprintf(info.message, sizeof(info.message), "%s", engine->game_over_message);
    }

    engine_turn_result_free(&tr);
    return info;
}

static GameState game_state_fetch_direct(Engine *engine) {
    GameState state = {0};

    EntityList list = engine_entity_list(engine);
    state.units = calloc(list.count, sizeof(Unit));

    for (int i = 0; i < list.count; i++) {
        const char *name = list.items[i].name;
        if (!name) continue;
        if (strcmp(name, "Map") == 0) continue;
        if (strcmp(name, "Archer") == 0 || strcmp(name, "Knight") == 0) continue;

        ecs_entity_t eid = list.items[i].id;
        Unit *u = &state.units[state.unit_count];
        snprintf(u->name, sizeof(u->name), "%s", name);
        u->eid = (int)eid;

        /* Location */
        char *loc = engine_entity_get_component(engine, eid, "Location");
        if (loc) {
            sscanf(loc, "x: %d, y: %d", &u->x, &u->y);
            free(loc);
        }

        /* Health */
        char *hp = engine_entity_get_component(engine, eid, "Health");
        if (hp) {
            sscanf(hp, "base: %d", &u->health);
            free(hp);
        }

        /* Faction (marker components) */
        ecs_entity_t red_c = ecs_lookup(engine->world, "RedFaction");
        ecs_entity_t blue_c = ecs_lookup(engine->world, "BlueFaction");
        if (red_c && ecs_has_id(engine->world, eid, red_c))
            snprintf(u->faction, sizeof(u->faction), "red");
        else if (blue_c && ecs_has_id(engine->world, eid, blue_c))
            snprintf(u->faction, sizeof(u->faction), "blue");

        /* Unit type from name */
        if (strstr(name, "Archer"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Archer");
        else if (strstr(name, "Knight"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Knight");

        /* TookDamage */
        ecs_entity_t td_comp = ecs_lookup(engine->world, "TookDamage");
        if (td_comp && ecs_has_id(engine->world, eid, td_comp)) {
            const ecs_bool_t *td = (const ecs_bool_t *)ecs_get_id(engine->world, eid, td_comp);
            u->took_damage = td && *td;
        }

        state.unit_count++;
    }

    engine_entity_list_free(&list);
    return state;
}

/* ÔöÇÔöÇ Main ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */

int main(int argc, char *argv[]) {
    if (argc < 2) {
        fprintf(stderr, "Usage: %s <config.yaml> [--fps N] [--benchmark N]\n", argv[0]);
        return 1;
    }

    ClientConfig cfg;
    if (!load_config(argv[1], &cfg)) {
        fprintf(stderr, "Failed to load config\n");
        return 1;
    }

    ClientFlags flags = { .direct = true };
    for (int i = 2; i < argc; i++) {
        if (strcmp(argv[i], "--rest") == 0) flags.direct = false;
        else if (strcmp(argv[i], "--benchmark") == 0 && i + 1 < argc) {
            flags.benchmark = true;
            flags.benchmark_runs = atoi(argv[++i]);
        }
        else if (strcmp(argv[i], "--fps") == 0 && i + 1 < argc) {
            flags.fps = atoi(argv[++i]);
        }
        else if (strcmp(argv[i], "--record") == 0 && i + 1 < argc) {
            snprintf(flags.record_path, sizeof(flags.record_path), "%s", argv[++i]);
        }
        else if (strcmp(argv[i], "--image") == 0 && i + 1 < argc) {
            snprintf(flags.image_dir, sizeof(flags.image_dir), "%s", argv[++i]);
        }
        else if (strcmp(argv[i], "--overrides") == 0 && i + 1 < argc) {
            snprintf(flags.overrides_dir, sizeof(flags.overrides_dir), "%s", argv[++i]);
        }
        else if (strcmp(argv[i], "--config") == 0 && i + 1 < argc) {
            snprintf(flags.config_name, sizeof(flags.config_name), "%s", argv[++i]);
        }
    }

    if (flags.benchmark) {
        /* Benchmark mode: run N games, report timing + win stats */
        double total_turn_ms = 0;
        int total_turns = 0;
        double total_wall_ms = 0;
        int wins_k = 0, wins_a = 0, draws = 0;

        const char *mode = flags.direct ? "native" : "REST";
        printf("Benchmarking %d games (%s mode)...\n", flags.benchmark_runs, mode);

        Engine *engine = NULL;

        for (int run = 0; run < flags.benchmark_runs; run++) {
            double game_start = now_ms();

            if (flags.direct) {
                engine = setup_direct(&cfg, flags.overrides_dir, flags.config_name);
                if (!engine) return 1;
            } else {
                if (!setup_rest(&cfg)) return 1;
            }

            TurnInfo last_info = {0};
            for (int t = 1; t <= cfg.max_turns; t++) {
                last_info = flags.direct ?
                    run_turn_direct(engine) : run_turn_rest();
                total_turn_ms += last_info.duration_ms;
                total_turns++;
                if (last_info.game_over) break;
            }

            if (strstr(last_info.message, "Knights")) wins_k++;
            else if (strstr(last_info.message, "Archers")) wins_a++;
            else draws++;

            double game_ms = now_ms() - game_start;
            total_wall_ms += game_ms;

            if (flags.direct) {
                engine_fini(engine);
                engine = NULL;
            }
        }

        int total_decided = wins_k + wins_a;
        printf("\nResults (%s):\n", mode);
        printf("  Games:          %d\n", flags.benchmark_runs);
        printf("  Knights:        %d (%d%%)\n", wins_k, total_decided ? wins_k * 100 / total_decided : 0);
        printf("  Archers:        %d (%d%%)\n", wins_a, total_decided ? wins_a * 100 / total_decided : 0);
        if (draws) printf("  Draws:          %d\n", draws);
        printf("  Avg turns/game: %.1f\n", (double)total_turns / flags.benchmark_runs);
        printf("  Avg turn time:  %.3f ms\n", total_turn_ms / total_turns);
        printf("  Avg game time:  %.1f ms\n", total_wall_ms / flags.benchmark_runs);
        printf("  Total wall:     %.1f ms\n", total_wall_ms);

        if (!flags.direct) api_fini();
        return 0;
    }

    /* Setup engine/REST */
    Engine *engine = NULL;
    if (flags.direct) {
        engine = setup_direct(&cfg, flags.overrides_dir, flags.config_name);
        if (!engine) return 1;
    } else {
        if (!setup_rest(&cfg)) return 1;
    }

    int fps = flags.fps > 0 ? flags.fps : (1000 / cfg.delay_ms);

    /* ÔöÇÔöÇ Recording mode ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
    if (flags.record_path[0]) {
        /* Do a dummy render to get grid dimensions */
        GameState dummy = {0};
        dummy.turn = 0;
        CellGrid sample = render_to_cellgrid(&dummy, cfg.map_x, cfg.map_y);

        GifRecorder *rec = gif_recorder_open(flags.record_path,
            8, 14, sample.cols, sample.rows, fps > 0 ? fps : 15);
        cellgrid_free(&sample);

        if (!rec) {
            if (flags.direct) engine_fini(engine);
            else api_fini();
            return 1;
        }

        fprintf(stderr, "Recording to %s (%dx%d, %d fps)\n",
                flags.record_path, cfg.map_x, cfg.map_y, fps > 0 ? fps : 15);

        bool finished_rec = false;
        for (int t = 1; t <= cfg.max_turns; t++) {
            TurnInfo info = flags.direct ?
                run_turn_direct(engine) : run_turn_rest();

            GameState state = flags.direct ?
                game_state_fetch_direct(engine) : game_state_fetch();
            state.turn = t;
            state.game_over = info.game_over;
            if (info.message[0])
                snprintf(state.game_over_message, sizeof(state.game_over_message),
                         "%s", info.message);

            CellGrid grid = render_to_cellgrid(&state, cfg.map_x, cfg.map_y);
            gif_recorder_write_frame(rec, &grid);
            cellgrid_free(&grid);

            fprintf(stderr, "\r  Turn %d", t);
            game_state_free(&state);

            if (info.game_over) {
                fprintf(stderr, ": %s\n", info.message);
                /* Hold final frame ~2s */
                int hold = (fps > 0 ? fps : 15) * 2;
                GameState final = flags.direct ?
                    game_state_fetch_direct(engine) : game_state_fetch();
                final.turn = t;
                final.game_over = true;
                snprintf(final.game_over_message, sizeof(final.game_over_message),
                         "%s", info.message);
                CellGrid fgrid = render_to_cellgrid(&final, cfg.map_x, cfg.map_y);
                for (int h = 0; h < hold; h++)
                    gif_recorder_write_frame(rec, &fgrid);
                cellgrid_free(&fgrid);
                game_state_free(&final);
                finished_rec = true;
                break;
            }
        }
        if (!finished_rec) fprintf(stderr, "\n");

        gif_recorder_close(rec);
        fprintf(stderr, "  Done: %s\n", flags.record_path);

        if (flags.direct) engine_fini(engine);
        else api_fini();
        return 0;
    }

    /* ÔöÇÔöÇ Image frame dump mode ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
    if (flags.image_dir[0]) {
#ifdef _WIN32
        _mkdir(flags.image_dir);
#else
        mkdir(flags.image_dir, 0755);
#endif

        GameState dummy = {0};
        CellGrid sample = render_to_cellgrid(&dummy, cfg.map_x, cfg.map_y);

        GifRecorder *rec = gif_recorder_open_frames(flags.image_dir,
            8, 14, sample.cols, sample.rows);
        cellgrid_free(&sample);

        if (!rec) {
            if (flags.direct) engine_fini(engine);
            else api_fini();
            return 1;
        }

        fprintf(stderr, "Writing frames to %s/ (%dx%d)\n",
                flags.image_dir, cfg.map_x, cfg.map_y);

        int frame_num = 0;
        for (int t = 1; t <= cfg.max_turns; t++) {
            TurnInfo info = flags.direct ?
                run_turn_direct(engine) : run_turn_rest();

            GameState state = flags.direct ?
                game_state_fetch_direct(engine) : game_state_fetch();
            state.turn = t;
            state.game_over = info.game_over;
            if (info.message[0])
                snprintf(state.game_over_message, sizeof(state.game_over_message),
                         "%s", info.message);

            CellGrid grid = render_to_cellgrid(&state, cfg.map_x, cfg.map_y);
            gif_recorder_write_frame(rec, &grid);
            frame_num++;
            cellgrid_free(&grid);

            fprintf(stderr, "\r  Turn %d", t);
            game_state_free(&state);

            if (info.game_over) {
                fprintf(stderr, ": %s\n", info.message);
                break;
            }
        }

        gif_recorder_close(rec);
        fprintf(stderr, "\n  Done: %d frames in %s/\n", frame_num, flags.image_dir);

        if (flags.direct) engine_fini(engine);
        else api_fini();
        return 0;
    }

    /* ÔöÇÔöÇ Interactive mode ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
    int delay = fps > 0 ? (1000 / fps) : 0;
    bool auto_advance = true;
    bool step = false;
    bool finished = false;
    int t = 0;

    input_init();

    while (t < cfg.max_turns && !finished) {
        /* Poll input */
        int key = poll_key();
        if (key == KEY_QUIT) break;

        bool sim_paused = flags.direct && is_simulation_paused(engine);

        if (key == KEY_LEFT && flags.direct) {
            /* Rewind one turn */
            auto_advance = false;
            int oldest = history_oldest_turn(engine);
            int current = engine->turn_counter;
            if (current > oldest) {
                engine_sim_rewind(engine, current - 1);
                t = engine->turn_counter;

                GameState state = game_state_fetch_direct(engine);
                state.turn = t;
                render(&state, cfg.map_x, cfg.map_y);
                int newest = history_newest_turn(engine);
                printf("[rewind: turn %d/%d] LEFT/RIGHT=browse  SPACE=resume  Q=quit\n",
                       t, newest);
                game_state_free(&state);
            }
            continue;

        } else if (key == KEY_RIGHT) {
            if (sim_paused) {
                /* Browse forward in history or unpause */
                int newest = history_newest_turn(engine);
                if (engine->turn_counter < newest) {
                    engine_sim_rewind(engine, engine->turn_counter + 1);
                    t = engine->turn_counter;

                    GameState state = game_state_fetch_direct(engine);
                    state.turn = t;
                    render(&state, cfg.map_x, cfg.map_y);
                    printf("[rewind: turn %d/%d] LEFT/RIGHT=browse  SPACE=resume  Q=quit\n",
                           t, newest);
                    game_state_free(&state);
                    continue;
                } else {
                    /* At latest ÔÇö unpause and step forward */
                    ecs_entity_t gs = ecs_lookup(engine->world, "GameState");
                    ecs_entity_t sp = ecs_lookup(engine->world, "SimulationPaused");
                    if (gs && sp) ecs_remove_id(engine->world, gs, sp);
                    step = true;
                }
            } else {
                if (auto_advance) {
                    auto_advance = false;
                } else {
                    step = true;
                }
            }

        } else if (key == KEY_SPACE) {
            if (sim_paused) {
                /* Unpause and resume auto-advance */
                ecs_entity_t gs = ecs_lookup(engine->world, "GameState");
                ecs_entity_t sp = ecs_lookup(engine->world, "SimulationPaused");
                if (gs && sp) ecs_remove_id(engine->world, gs, sp);
                auto_advance = true;
                step = false;
            } else {
                auto_advance = !auto_advance;
                step = false;
            }
        }

        if (sim_paused && !step) {
            usleep(10000);
            continue;
        }

        if (!auto_advance && !step) {
            usleep(10000); /* 10ms idle poll */
            continue;
        }
        step = false;

        double frame_start = now_ms();
        t++;

        TurnInfo info = flags.direct ?
            run_turn_direct(engine) : run_turn_rest();

        GameState state = flags.direct ?
            game_state_fetch_direct(engine) : game_state_fetch();
        state.turn = t;
        state.game_over = info.game_over;
        if (info.message[0])
            snprintf(state.game_over_message, sizeof(state.game_over_message),
                     "%s", info.message);

        render(&state, cfg.map_x, cfg.map_y);
        printf(auto_advance ? "[auto] " : "[paused] ");
        printf("SPACE=play/pause  RIGHT=step  LEFT=rewind  Q=quit\n");
        game_state_free(&state);

        if (info.game_over) { finished = true; break; }

        /* Frame delay with input polling */
        if (auto_advance && delay > 0) {
            while (now_ms() - frame_start < delay) {
                int k = poll_key();
                if (k == KEY_QUIT) { finished = true; break; }
                if (k == KEY_SPACE) { auto_advance = false; break; }
                if (k == KEY_RIGHT) { auto_advance = false; break; }
                if (k == KEY_LEFT && flags.direct) {
                    auto_advance = false;
                    /* Rewind from delay loop */
                    int oldest = history_oldest_turn(engine);
                    if (engine->turn_counter > oldest) {
                        engine_sim_rewind(engine, engine->turn_counter - 1);
                        t = engine->turn_counter;
                        GameState rs = game_state_fetch_direct(engine);
                        rs.turn = t;
                        render(&rs, cfg.map_x, cfg.map_y);
                        int newest = history_newest_turn(engine);
                        printf("[rewind: turn %d/%d] LEFT/RIGHT=browse  SPACE=resume  Q=quit\n",
                               t, newest);
                        game_state_free(&rs);
                    }
                    break;
                }
                usleep(10000);
            }
        }
    }

    if (!finished && t >= cfg.max_turns) {
        GameState final_state = flags.direct ?
            game_state_fetch_direct(engine) : game_state_fetch();
        final_state.turn = cfg.max_turns;
        snprintf(final_state.game_over_message,
                 sizeof(final_state.game_over_message), "Turn limit reached");
        final_state.game_over = true;
        render(&final_state, cfg.map_x, cfg.map_y);
        game_state_free(&final_state);
    }

    input_fini();
    if (flags.direct) engine_fini(engine);
    else api_fini();
    return 0;
}
#include "render.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

CellGrid render_to_cellgrid(const GameState *state, int map_w, int map_h) {
    int gw = map_w;  /* grid cells: 1..map_w */
    int gh = map_h;  /* grid cells: 1..map_h */

    /* Count units by faction */
    int archers = 0, knights = 0;
    for (int i = 0; i < state->unit_count; i++) {
        if (strcmp(state->units[i].faction, "red") == 0) archers++;
        else if (strcmp(state->units[i].faction, "blue") == 0) knights++;
    }

    /* Header text */
    char header[128];
    snprintf(header, sizeof(header), "Turn %d: Knights(%d) vs Archers(%d)",
             state->turn, knights, archers);

    int border_w = gw + 2;  /* | + cells + | */
    int cols = (int)strlen(header) > border_w ? (int)strlen(header) : border_w;
    int rows = 1 + 1 + gh + 1;  /* header + top border + grid rows + bottom border */
    if (state->game_over) rows++;

    CellGrid grid = cellgrid_create(rows, cols);
    int row = 0;

    /* Header */
    cellgrid_puts(&grid, row, 0, header, COLOR_WHITE);
    row++;

    /* Top border */
    cellgrid_set(&grid, row, 0, '+', COLOR_GRAY);
    for (int x = 0; x < gw; x++)
        cellgrid_set(&grid, row, 1 + x, '-', COLOR_GRAY);
    cellgrid_set(&grid, row, 1 + gw, '+', COLOR_GRAY);
    row++;

    /* Build occupancy lookup (1-based: index by y*gw+x, x/y start at 1) */
    int *occ = malloc((gw + 1) * (gh + 1) * sizeof(int));
    memset(occ, -1, (gw + 1) * (gh + 1) * sizeof(int));
    for (int i = 0; i < state->unit_count; i++) {
        int x = state->units[i].x;
        int y = state->units[i].y;
        if (x >= 1 && x <= gw && y >= 1 && y <= gh)
            occ[y * (gw + 1) + x] = i;
    }

    /* Grid rows (top = max y, bottom = 1) */
    for (int y = map_h; y >= 1; y--) {
        cellgrid_set(&grid, row, 0, '|', COLOR_GRAY);
        for (int x = 1; x <= gw; x++) {
            int idx = occ[y * (gw + 1) + x];
            if (idx >= 0) {
                const Unit *u = &state->units[idx];
                char letter = (strcmp(u->unit_type, "Archer") == 0) ? 'A' : 'K';
                uint8_t color;
                if (u->took_damage)
                    color = COLOR_WHITE;
                else if (strcmp(u->faction, "red") == 0)
                    color = COLOR_RED;
                else
                    color = COLOR_BLUE;
                cellgrid_set(&grid, row, x, letter, color);
            }
            /* empty cells stay black (default from calloc) */
        }
        cellgrid_set(&grid, row, 1 + gw, '|', COLOR_GRAY);
        row++;
    }

    /* Bottom border */
    cellgrid_set(&grid, row, 0, '+', COLOR_GRAY);
    for (int x = 0; x < gw; x++)
        cellgrid_set(&grid, row, 1 + x, '-', COLOR_GRAY);
    cellgrid_set(&grid, row, 1 + gw, '+', COLOR_GRAY);
    row++;

    free(occ);

    /* Game over message with survivor count */
    if (state->game_over) {
        int survivors = 0;
        if (strstr(state->game_over_message, "Archers")) survivors = archers;
        else if (strstr(state->game_over_message, "Knights")) survivors = knights;
        char msg[300];
        snprintf(msg, sizeof(msg), ">>> %s (%d survivors) <<<",
                 state->game_over_message, survivors);
        cellgrid_puts(&grid, row, 0, msg, COLOR_YELLOW);
    }

    return grid;
}

/* ANSI color codes indexed by our color constants */
static const char *ANSI_COLORS[] = {
    "\033[0m",   /* 0: black (reset) */
    "\033[31m",  /* 1: red */
    "\033[34m",  /* 2: blue */
    "\033[97m",  /* 3: white (bright) */
    "\033[90m",  /* 4: gray (dark) */
    "\033[33m",  /* 5: yellow */
};

void render_terminal(const CellGrid *grid) {
    printf("\033[2J\033[H");  /* clear screen */
    for (int r = 0; r < grid->rows; r++) {
        for (int c = 0; c < grid->cols; c++) {
            Cell *cell = &grid->cells[r * grid->cols + c];
            if (cell->ch == 0) {
                putchar(' ');
            } else if (cell->color == COLOR_BLACK) {
                putchar(cell->ch);
            } else {
                printf("%s%c\033[0m", ANSI_COLORS[cell->color], cell->ch);
            }
        }
        putchar('\n');
    }
}

void render(const GameState *state, int map_w, int map_h) {
    CellGrid grid = render_to_cellgrid(state, map_w, map_h);
    render_terminal(&grid);
    cellgrid_free(&grid);
}
#ifndef CLIENT_RENDER_H
#define CLIENT_RENDER_H

#include "state.h"
#include "cellgrid.h"

/* Build abstract cell grid from game state (single source of truth) */
CellGrid render_to_cellgrid(const GameState *state, int map_w, int map_h);

/* Output cell grid to terminal with ANSI colors */
void render_terminal(const CellGrid *grid);

/* Convenience: build grid + output to terminal (preserves old API) */
void render(const GameState *state, int map_w, int map_h);

#endif
#include "state.h"
#include "api.h"
#include <cJSON.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>

GameState game_state_fetch(void) {
    GameState state = {0};

    /* Get entity list */
    char *json = api_get("/api/entities");
    if (!json) return state;

    cJSON *root = cJSON_Parse(json);
    free(json);
    if (!root) return state;

    cJSON *entities = cJSON_GetObjectItemCaseSensitive(root, "entities");
    if (!entities || !cJSON_IsArray(entities)) {
        cJSON_Delete(root);
        return state;
    }

    int count = cJSON_GetArraySize(entities);
    state.units = calloc(count, sizeof(Unit));

    cJSON *ent;
    cJSON_ArrayForEach(ent, entities) {
        cJSON *name_j = cJSON_GetObjectItemCaseSensitive(ent, "name");
        if (!cJSON_IsString(name_j)) continue;
        const char *name = name_j->valuestring;

        /* Skip non-unit entities (Map, prefabs) */
        if (strcmp(name, "Map") == 0) continue;
        if (strcmp(name, "Archer") == 0 || strcmp(name, "Knight") == 0) continue;

        /* Fetch entity details */
        char path[128];
        snprintf(path, sizeof(path), "/api/entities/%s", name);
        char *detail_json = api_get(path);
        if (!detail_json) continue;

        cJSON *detail = cJSON_Parse(detail_json);
        free(detail_json);
        if (!detail) continue;

        cJSON *comps = cJSON_GetObjectItemCaseSensitive(detail, "components");
        if (!comps) { cJSON_Delete(detail); continue; }

        /* Extract Location */
        cJSON *loc = cJSON_GetObjectItemCaseSensitive(comps, "Location");
        cJSON *health_j = cJSON_GetObjectItemCaseSensitive(comps, "Health");
        if (!loc || !health_j) { cJSON_Delete(detail); continue; }

        Unit *u = &state.units[state.unit_count];
        snprintf(u->name, sizeof(u->name), "%s", name);

        cJSON *x = cJSON_GetObjectItemCaseSensitive(loc, "x");
        cJSON *y = cJSON_GetObjectItemCaseSensitive(loc, "y");
        u->x = cJSON_IsNumber(x) ? x->valueint : 0;
        u->y = cJSON_IsNumber(y) ? y->valueint : 0;

        cJSON *hp = cJSON_GetObjectItemCaseSensitive(health_j, "base");
        u->health = cJSON_IsNumber(hp) ? hp->valueint : 0;

        if (cJSON_GetObjectItemCaseSensitive(comps, "RedFaction"))
            snprintf(u->faction, sizeof(u->faction), "red");
        else if (cJSON_GetObjectItemCaseSensitive(comps, "BlueFaction"))
            snprintf(u->faction, sizeof(u->faction), "blue");

        /* Determine unit type from name prefix */
        if (strstr(name, "Archer"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Archer");
        else if (strstr(name, "Knight"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Knight");

        cJSON *eid_j = cJSON_GetObjectItemCaseSensitive(comps, "EntityId");
        if (eid_j) {
            cJSON *id = cJSON_GetObjectItemCaseSensitive(eid_j, "id");
            u->eid = cJSON_IsNumber(id) ? id->valueint : 0;
        }

        state.unit_count++;
        cJSON_Delete(detail);
    }

    cJSON_Delete(root);
    return state;
}

void game_state_free(GameState *state) {
    if (state) {
        free(state->units);
        state->units = NULL;
        state->unit_count = 0;
    }
}
#ifndef CLIENT_STATE_H
#define CLIENT_STATE_H

#include <stdbool.h>

typedef struct {
    int eid;
    char name[64];
    int x, y;
    int health;
    char faction[16];   /* "red" or "blue" */
    char unit_type[16]; /* "Archer" or "Knight" */
    bool took_damage;
} Unit;

typedef struct {
    Unit *units;
    int unit_count;
    int turn;
    bool game_over;
    char game_over_message[256];
} GameState;

/* Fetch game state from server. Caller must call game_state_free. */
GameState game_state_fetch(void);

/* Free game state internals */
void game_state_free(GameState *state);

#endif
# AvK Real-Time Client (wasm-rt)

Real-time visual client for AvK. Renders turn-based simulation with animated phase transitions.

## Architecture

Two-world MVC pattern:
- **ModelWorld**: identical to AvK, managed by the WASM engine
- **ViewWorld**: persistent view units in JavaScript, tracks animation state

The client advances one ModelWorld turn, then visualizes it over 500ms (4 phases ├Ś 125ms).

## Phase Animation

Each turn plays through four sequential phases:
1. **Movement** (125ms): units slide from previous position to new position
2. **Attack** (125ms): weapon sprites move toward attack target
3. **Reaction** (125ms): hit units flash through hit animation (frames 1-8)
4. **Defeat** (125ms): dying units shrink (frames 9-16), weapon hidden

## View Units (Persistent)

View units persist across turns. They are NOT rebuilt from model snapshots each turn.

- `updateViewForTurn()`: after model advances, updates existing view units with new positions/state, removes dead units, adds new spawns
- `initViewFromModel()`: used on game start and rewind to sync view from model
- Previous positions tracked in view units, not via before/after model snapshots

## Sprite System

Sprite sheets in `assets/sprites/`:
- `knight_body/`: 17 frames (idle=0, hit=1-8, defeat=9-16), 64x64px
- `archer_body/`: 17 frames (same layout)
- `knight_weapon/`: 1 frame (short arrow, pointing up)
- `archer_weapon/`: 1 frame (long arrow, pointing up)

Each sheet has a `sheet.yaml` manifest. Weapons rotate to face attack target via canvas transform.

## WASM Exports Used

| Function | Purpose |
|----------|---------|
| `wasm_init_with_config(name)` | Start game with named config (e.g. "wasm-rt") |
| `wasm_turn()` | Advance one ModelWorld turn |
| `wasm_get_unit_entity_id(i)` | Stable entity ID for view unit tracking |
| `wasm_get_unit_x/y(i)` | Position after turn |
| `wasm_get_unit_health(i)` | Health (<=0 = dying) |
| `wasm_get_unit_faction(i)` | 0=archer, 1=knight |
| `wasm_get_unit_took_damage(i)` | Hit this turn |
| `wasm_get_unit_attacked_id(i)` | Entity ID of attack target |
| `wasm_rewind(turn)` | Rewind to specific turn |

## Layout

Responsive 16:9 canvas (1024x576 internal, CSS-scaled). Header/footer with min/max pixel budgets. Canvas fills remaining space.

## Config

Uses `wasm-rt` named config from app.yaml: 4 archers vs 8 knights on 15x8 (16x9 cells) board.
