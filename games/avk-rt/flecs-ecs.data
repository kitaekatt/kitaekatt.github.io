#include "state.h"
#include "api.h"
#include <cJSON.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>

GameState game_state_fetch(void) {
    GameState state = {0};

    /* Get entity list */
    char *json = api_get("/api/entities");
    if (!json) return state;

    cJSON *root = cJSON_Parse(json);
    free(json);
    if (!root) return state;

    cJSON *entities = cJSON_GetObjectItemCaseSensitive(root, "entities");
    if (!entities || !cJSON_IsArray(entities)) {
        cJSON_Delete(root);
        return state;
    }

    int count = cJSON_GetArraySize(entities);
    state.units = calloc(count, sizeof(Unit));

    cJSON *ent;
    cJSON_ArrayForEach(ent, entities) {
        cJSON *name_j = cJSON_GetObjectItemCaseSensitive(ent, "name");
        if (!cJSON_IsString(name_j)) continue;
        const char *name = name_j->valuestring;

        /* Skip non-unit entities (Map, prefabs) */
        if (strcmp(name, "Map") == 0) continue;
        if (strcmp(name, "Archer") == 0 || strcmp(name, "Knight") == 0) continue;

        /* Fetch entity details */
        char path[128];
        snprintf(path, sizeof(path), "/api/entities/%s", name);
        char *detail_json = api_get(path);
        if (!detail_json) continue;

        cJSON *detail = cJSON_Parse(detail_json);
        free(detail_json);
        if (!detail) continue;

        cJSON *comps = cJSON_GetObjectItemCaseSensitive(detail, "components");
        if (!comps) { cJSON_Delete(detail); continue; }

        /* Extract Location */
        cJSON *loc = cJSON_GetObjectItemCaseSensitive(comps, "Location");
        cJSON *health_j = cJSON_GetObjectItemCaseSensitive(comps, "Health");
        if (!loc || !health_j) { cJSON_Delete(detail); continue; }

        Unit *u = &state.units[state.unit_count];
        snprintf(u->name, sizeof(u->name), "%s", name);

        cJSON *x = cJSON_GetObjectItemCaseSensitive(loc, "x");
        cJSON *y = cJSON_GetObjectItemCaseSensitive(loc, "y");
        u->x = cJSON_IsNumber(x) ? x->valueint : 0;
        u->y = cJSON_IsNumber(y) ? y->valueint : 0;

        cJSON *hp = cJSON_GetObjectItemCaseSensitive(health_j, "base");
        u->health = cJSON_IsNumber(hp) ? hp->valueint : 0;

        if (cJSON_GetObjectItemCaseSensitive(comps, "RedFaction"))
            snprintf(u->faction, sizeof(u->faction), "red");
        else if (cJSON_GetObjectItemCaseSensitive(comps, "BlueFaction"))
            snprintf(u->faction, sizeof(u->faction), "blue");

        /* Determine unit type from name prefix */
        if (strstr(name, "Archer"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Archer");
        else if (strstr(name, "Knight"))
            snprintf(u->unit_type, sizeof(u->unit_type), "Knight");

        cJSON *eid_j = cJSON_GetObjectItemCaseSensitive(comps, "EntityId");
        if (eid_j) {
            cJSON *id = cJSON_GetObjectItemCaseSensitive(eid_j, "id");
            u->eid = cJSON_IsNumber(id) ? id->valueint : 0;
        }

        state.unit_count++;
        cJSON_Delete(detail);
    }

    cJSON_Delete(root);
    return state;
}

void game_state_free(GameState *state) {
    if (state) {
        free(state->units);
        state->units = NULL;
        state->unit_count = 0;
    }
}
#ifndef CLIENT_STATE_H
#define CLIENT_STATE_H

#include <stdbool.h>

typedef struct {
    int eid;
    char name[64];
    int x, y;
    int health;
    char faction[16];   /* "red" or "blue" */
    char unit_type[16]; /* "Archer" or "Knight" */
    bool took_damage;
} Unit;

typedef struct {
    Unit *units;
    int unit_count;
    int turn;
    bool game_over;
    char game_over_message[256];
} GameState;

/* Fetch game state from server. Caller must call game_state_free. */
GameState game_state_fetch(void);

/* Free game state internals */
void game_state_free(GameState *state);

#endif
/**
 * Game controls: play/pause, step, rewind, hold behavior, button states.
 *
 * Usage:
 *   const ctrl = GameControls.init({
 *       btnPlay, btnStep, btnRewind, btnNew,
 *       onStep: () => { ... },
 *       onRewind: () => { ... },
 *       onNewGame: () => { ... },
 *       onPlay: () => { ... },
 *       canStep: () => boolean,
 *       canRewind: () => boolean,
 *   });
 *   // Call ctrl.updateButtons() after state changes
 *   // Call ctrl.isPlaying() to check play state
 */
var GameControls = (function() {
    function init(cfg) {
        var playing = false;
        var holdTimeout = null;
        var holdInterval = null;
        var heldKey = null;

        function updateButtons() {
            if (playing) {
                cfg.btnRewind.disabled = false;
                cfg.btnStep.disabled = false;
            } else {
                cfg.btnRewind.disabled = !cfg.canRewind();
                cfg.btnStep.disabled = !cfg.canStep();
            }
        }

        function startHold(action) {
            stopHold();
            action();
            holdTimeout = setTimeout(function() {
                holdInterval = setInterval(action, 33);
            }, 300);
        }

        function stopHold() {
            if (holdTimeout) { clearTimeout(holdTimeout); holdTimeout = null; }
            if (holdInterval) { clearInterval(holdInterval); holdInterval = null; }
        }

        function togglePlay() {
            if (cfg.onAnyAction) cfg.onAnyAction();
            if (!playing && cfg.isGameOver && cfg.isGameOver()) {
                cfg.onNewGame();
            }
            playing = !playing;
            cfg.btnPlay.textContent = playing ? 'Pause' : 'Play';
            cfg.btnPlay.classList.toggle('active', playing);
            if (playing && cfg.onPlay) cfg.onPlay();
            updateButtons();
        }

        function doStep() {
            if (cfg.onAnyAction) cfg.onAnyAction();
            if (playing) togglePlay();
            cfg.onStep();
            updateButtons();
        }

        function doRewind() {
            if (cfg.onAnyAction) cfg.onAnyAction();
            if (playing) togglePlay();
            cfg.onRewind();
            updateButtons();
        }

        function doNewGame() {
            if (cfg.onAnyAction) cfg.onAnyAction();
            stopHold();
            if (playing) togglePlay();
            cfg.onNewGame();
            updateButtons();
        }

        /* Button events */
        cfg.btnPlay.addEventListener('click', togglePlay);
        cfg.btnNew.addEventListener('click', doNewGame);
        cfg.btnStep.addEventListener('mousedown', function() { startHold(doStep); });
        cfg.btnRewind.addEventListener('mousedown', function() { startHold(doRewind); });
        document.addEventListener('mouseup', stopHold);

        /* Keyboard */
        document.addEventListener('keydown', function(e) {
            if (e.repeat) return;
            if (e.code === 'Space') { e.preventDefault(); togglePlay(); }
            else if (e.code === 'ArrowRight') {
                e.preventDefault();
                heldKey = 'right';
                startHold(doStep);
            }
            else if (e.code === 'ArrowLeft') {
                e.preventDefault();
                heldKey = 'left';
                startHold(doRewind);
            }
        });
        document.addEventListener('keyup', function(e) {
            if (e.code === 'ArrowRight' && heldKey === 'right') { stopHold(); heldKey = null; }
            else if (e.code === 'ArrowLeft' && heldKey === 'left') { stopHold(); heldKey = null; }
        });

        function reset() {
            stopHold();
            playing = false;
            cfg.btnPlay.textContent = 'Play';
            cfg.btnPlay.classList.remove('active');
            updateButtons();
        }

        updateButtons();

        return {
            updateButtons: updateButtons,
            reset: reset,
            isPlaying: function() { return playing; },
            togglePlay: togglePlay,
        };
    }

    return { init: init };
})();
/**
 * Debug: toggleable profiling overlay + board state YAML copy.
 *
 * If cfg.getTiming is provided, the Debug button toggles a live overlay.
 * Otherwise, clicking Debug copies board YAML to clipboard (legacy behavior).
 */
var GameDebug = (function() {
    var overlay = null;
    var showing = false;
    var rafId = null;
    var debugBtn = null;

    function init(cfg) {
        debugBtn = cfg.btnDebug;
        if (cfg.getTiming) {
            debugBtn.addEventListener('click', function() {
                if (showing) close(); else open(cfg);
            });
        } else {
            /* Legacy: click = copy YAML */
            debugBtn.addEventListener('click', function() { copyYaml(cfg); });
        }
    }

    function open(cfg) {
        if (overlay) overlay.remove();
        overlay = document.createElement('pre');
        overlay.id = 'debug-overlay';
        overlay.style.cssText = [
            'position:fixed', 'bottom:28px', 'right:4px',
            'background:rgba(10,10,25,0.88)', 'color:#aaa',
            'font:11px/1.5 monospace', 'padding:8px 10px',
            'border:1px solid #333', 'border-radius:4px',
            'z-index:20', 'pointer-events:auto',
            'min-width:220px', 'max-width:360px',
            'margin:0', 'user-select:text'
        ].join(';');
        document.body.appendChild(overlay);
        showing = true;
        debugBtn.classList.add('active');
        tick(cfg);
    }

    function close() {
        if (overlay) overlay.remove();
        overlay = null;
        showing = false;
        if (debugBtn) debugBtn.classList.remove('active');
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
    }

    function tick(cfg) {
        if (!showing) return;
        renderOverlay(cfg);
        rafId = requestAnimationFrame(function() { tick(cfg); });
    }

    function renderOverlay(cfg) {
        var d = cfg.getTiming();
        var c = d.current;
        var a = d.avg;
        var lines = [];

        lines.push('Turn ' + d.turn + '  |  ' + d.unitCount + ' units');
        lines.push('--- Turn (last / avg' + d.historySize + ') ---');
        lines.push('engine:  ' + fmt(c.engine) + ' / ' + fmt(a.engine) + ' ms');

        /* Per-system breakdown */
        if (d.systems.length > 0) {
            var othersMs = 0;
            for (var i = 0; i < d.systems.length; i++) {
                var s = d.systems[i];
                var pct = d.wasmTotal > 0 ? (s.time / d.wasmTotal * 100) : 0;
                if (pct >= 3) {
                    lines.push('  ' + pad(s.name, 14) + fmt(s.time) + ' ms  (' + pct.toFixed(0) + '%)');
                } else {
                    othersMs += s.time;
                }
            }
            if (othersMs > 0.001) {
                lines.push('  ' + pad('others', 14) + fmt(othersMs) + ' ms');
            }
            lines.push('  ' + pad('collect', 14) + fmt(d.collectTime) + ' ms');
        }

        lines.push('view:    ' + fmt(c.view) + ' / ' + fmt(a.view) + ' ms');
        lines.push('anim:    ' + fmt(c.anim) + ' / ' + fmt(a.anim) + ' ms (' + (d.animFrames || 0) + 'f)');
        lines.push('total:   ' + fmt(c.total) + ' / ' + fmt(a.total) + ' ms');
        lines.push('--- Render ---------------------');
        lines.push('draw:    ' + fmt(d.render.draw) + ' ms');

        overlay.innerHTML = lines.join('\n')
            + '\n<a href="#" id="debug-copy-yaml" style="color:#4dabf7;text-decoration:none;font-size:10px;">Copy board YAML</a>';

        var link = document.getElementById('debug-copy-yaml');
        if (link) link.onclick = function(e) { e.preventDefault(); copyYaml(cfg); };
    }

    function fmt(v) {
        if (v === undefined || v === null || isNaN(v)) return '   ---';
        return v < 10 ? v.toFixed(2).padStart(6) : v.toFixed(0).padStart(6);
    }

    function pad(s, n) {
        return (s + ':').padEnd(n);
    }

    function copyYaml(cfg) {
        var size = cfg.getMapSize();
        var units = cfg.getUnits();
        var lines = ['map: ' + size[0] + ' ' + size[1], 'units:'];
        for (var i = 0; i < units.length; i++) {
            var u = units[i];
            lines.push('  - ' + u.type + ' ' + u.x + ' ' + u.y + ' health:' + u.health);
        }
        var yaml = lines.join('\n') + '\n';

        var ta = document.createElement('textarea');
        ta.value = yaml;
        ta.style.cssText = 'position:fixed;left:0;top:0;width:1px;height:1px;opacity:0;';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        var ok = false;
        try { ok = document.execCommand('copy'); } catch(e) {}
        document.body.removeChild(ta);

        if (ok) {
            cfg.btnDebug.textContent = 'Copied!';
            setTimeout(function() { cfg.btnDebug.textContent = 'Debug'; }, 1500);
        } else {
            prompt('Copy this scenario YAML:', yaml);
        }
    }

    return {
        init: init,
        close: close,
        isShowing: function() { return showing; },
    };
})();
/**
 * Responsive canvas layout with aspect ratio preservation.
 *
 * Usage:
 *   const lay = GameLayout.init({
 *       canvas: canvasEl,
 *       headerEl: headerEl,    // optional: element above canvas
 *       footerEl: footerEl,    // optional: element below canvas
 *       middleEl: middleEl,    // optional: canvas container
 *       aspect: 16 / 9,
 *       headerMin: 40, headerMax: 60,
 *       footerMin: 40, footerMax: 60,
 *       gameMin: 240,
 *       onResize: (cw, ch) => { ... },  // optional callback after layout
 *   });
 *   lay.resize();  // force re-layout
 */
var GameLayout = (function() {
    function init(cfg) {
        var canvas = cfg.canvas;
        var aspect = cfg.aspect || 16 / 9;
        var headerMin = cfg.headerMin || 60;
        var headerMax = cfg.headerMax || 90;
        var footerMin = cfg.footerMin || 40;
        var footerMax = cfg.footerMax || 60;
        var gameMin = cfg.gameMin || 240;

        function resize() {
            var totalH = window.innerHeight, totalW = window.innerWidth;
            var chromeMin = headerMin + footerMin;
            var headerH, footerH, gameH;

            if (totalH <= chromeMin) {
                headerH = totalH / 2; footerH = totalH / 2; gameH = 0;
            } else if (totalH < chromeMin + gameMin) {
                headerH = headerMin; footerH = footerMin; gameH = totalH - chromeMin;
            } else {
                var avail = totalH - chromeMin - gameMin;
                var extra = (headerMax - headerMin) + (footerMax - footerMin);
                var t = Math.min(1, avail / extra);
                headerH = headerMin + (headerMax - headerMin) * t;
                footerH = footerMin + (footerMax - footerMin) * t;
                gameH = totalH - headerH - footerH;
            }

            if (cfg.headerEl) cfg.headerEl.style.height = Math.floor(headerH) + 'px';
            if (cfg.footerEl) cfg.footerEl.style.height = Math.floor(footerH) + 'px';
            if (cfg.middleEl) cfg.middleEl.style.height = Math.floor(gameH) + 'px';

            var cw = gameH * aspect, ch = gameH;
            if (cw > totalW) { cw = totalW; ch = cw / aspect; }
            canvas.style.width = Math.floor(cw) + 'px';
            canvas.style.height = Math.floor(ch) + 'px';

            if (cfg.onResize) cfg.onResize(Math.floor(cw), Math.floor(ch));
        }

        resize();
        window.addEventListener('resize', resize);

        return { resize: resize };
    }

    return { init: init };
})();
# AvK Real-Time Client (wasm_3x)

Real-time visual client for AvK. Renders turn-based simulation with animated phase transitions.

## Architecture

Two-world MVC pattern:
- **ModelWorld**: identical to AvK, managed by the WASM engine
- **ViewWorld**: persistent view units in JavaScript, tracks animation state

The client advances one ModelWorld turn, then visualizes it over `TARGET_TURN_MS` (default 400ms) with overlapping phase animations.

## Phase Animation (Overlapping Timeline)

Phases run concurrently on a timeline, not sequentially. Each phase has a start% and end% of the turn. Movement runs the full turn as a backdrop; other phases overlay on top.

```
Turn progress:  0%              50%     75%    87.5%      100%
                |               |       |      |          |
Movement:       Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł
Attack:         Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł|
Reaction:                       Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł|
Defeat:                                 Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł
```

| Phase | Start | End | What it does |
|-------|-------|-----|-------------|
| Movement | 0% | 100% | Interpolate position from previous to current (continuous sliding) |
| Attack | 0% | 75% | Weapon sprite animates toward attack target |
| Reaction | 75% | 87.5% | Hit units flash through frames 1-8 |
| Defeat | 87.5% | 100% | Dying units shrink (frames 9-16), weapon hidden |

Configured in the `TIMELINE` object in `index.html`. Each system's local `t` (0ŌåÆ1) is computed from turn progress `p` via: `t = clamp((p - start) / (end - start), 0, 1)`.

### Dynamic Turn Duration

Total animation time adjusts each turn to compensate for engine + view update overhead:
```
animDurationMs = TARGET_TURN_MS - (engine_ms + view_update_ms)
```
This keeps actual wall time close to the target regardless of computation cost.

### Turn Progress Graph Convention

Use this format to visualize phase timelines in documentation:
```
Turn progress:  0%      33%             75%    87.5%      100%
                |       |               |      |          |
Phase1:         Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł
Phase2:                 Ō¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢łŌ¢ł|
```
Tick marks show phase boundaries. `Ō¢łŌ¢łŌ¢łŌ¢ł` blocks show when each phase is active.

## View Units (Persistent)

View units persist across turns. They are NOT rebuilt from model snapshots each turn.

- `updateViewForTurn()`: after model advances, updates existing view units with new positions/state, removes dead units, adds new spawns
- `initViewFromModel()`: used on game start and rewind to sync view from model
- Previous positions tracked in view units, not via before/after model snapshots

## Sprite System

Sprite sheets in `assets/sprites/`:
- `knight_body/`: 17 frames (idle=0, hit=1-8, defeat=9-16), 64x64px
- `archer_body/`: 17 frames (same layout)
- `knight_weapon/`: 1 frame (short arrow, pointing up)
- `archer_weapon/`: 1 frame (long arrow, pointing up)

Each sheet has a `sheet.yaml` manifest. Weapons rotate to face attack target via canvas transform.

## WASM Exports Used

| Function | Purpose |
|----------|---------|
| `wasm_init_with_config(name)` | Start game with named config (e.g. "wasm_3x"). Map entity and units don't exist until first `wasm_turn()` runs `app_start`. |
| `wasm_turn()` | Advance one ModelWorld turn. Also calls `read_map_size()` and `collect_wasm_units()`, so `getMapX/Y` and unit accessors are valid after this returns. |
| `wasm_get_unit_entity_id(i)` | Stable entity ID for view unit tracking |
| `wasm_get_unit_x/y(i)` | Position after turn |
| `wasm_get_unit_health(i)` | Health (<=0 = dying) |
| `wasm_get_unit_faction(i)` | 0=archer, 1=knight |
| `wasm_get_unit_took_damage(i)` | Hit this turn |
| `wasm_get_unit_attacked_id(i)` | Entity ID of attack target |
| `wasm_get_map_x/y()` | Map dimensions. Only valid after first `wasm_turn()`. |
| `wasm_rewind(turn)` | Rewind to specific turn |

## Layout

Responsive 16:9 canvas (1024x576 internal, CSS-scaled). Header/footer with min/max pixel budgets. Canvas fills remaining space.

## Config

