    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
}
h1 {
    font-size: 1.4em;
    margin-bottom: 8px;
    color: #f0f0f0;
}
#status {
    font-size: 0.95em;
    margin-bottom: 8px;
    height: 1.4em;
    color: #aaa;
}
#game-over-msg {
    font-size: 1.1em;
    font-weight: bold;
    color: #ffd700;
    height: 1.4em;
    margin-bottom: 4px;
}
canvas {
    border: 1px solid #333;
    border-radius: 4px;
    image-rendering: pixelated;
    max-width: 100%;
    max-height: 60vh;
    object-fit: contain;
}
#controls {
    margin-top: 12px;
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
}
button {
    background: #2a2a4a;
    color: #e0e0e0;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 8px 16px;
    font-size: 0.9em;
    cursor: pointer;
    min-width: 70px;
}
button:hover { background: #3a3a5a; }
button:active { background: #4a4a6a; }
button.active { background: #4a6a4a; border-color: #6a8a6a; }
#speed-group {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
}
#speed-group label { font-size: 0.85em; color: #aaa; }
#speed-label { font-size: 0.85em; min-width: 56px; text-align: right; }
#fps-bar-outer {
    width: 200px;
    height: 16px;
    background: #2a2a4a;
    border-radius: 3px;
    overflow: hidden;
