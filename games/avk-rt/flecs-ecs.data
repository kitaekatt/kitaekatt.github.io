/*
 * Minimal 8x14 bitmap font for ASCII 32-126.
 * Each character is 14 rows of 8 bits (MSB = leftmost pixel).
 * Index: font_8x14[ch - 32][row]
 * Derived from the classic VGA/CP437 8x14 font (public domain).
 */
